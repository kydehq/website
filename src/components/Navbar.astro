---
const navLinks = [
  { label: 'Platform',   href: '/platform'   },
  { label: 'Use Cases',  href: '/use-cases'  },
  { label: 'Resources',  href: '/resources'  },
  { label: 'Company',    href: '/company'    },
  { label: 'KYDE Labs',  href: '/labs'       },
];

const currentPath = Astro.url.pathname;
---

<header class="fixed top-0 left-0 right-0 z-50 border-b border-white/5 bg-black/80 backdrop-blur-md">
  <nav class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4">
    <!-- Logo -->
    <a href="/" class="inline-flex items-center border border-zinc-700 px-3 py-1.5 font-mono text-sm font-bold tracking-widest text-white hover:border-zinc-500 transition-colors">
      KYDE
    </a>

    <!-- Nav links (desktop) -->
    <ul class="hidden md:flex items-center gap-8">
      {navLinks.map(({ label, href }) => (
        <li>
          <a
            href={href}
            class={[
              'text-sm font-medium transition-colors',
              currentPath.startsWith(href)
                ? 'text-white'
                : 'text-white/50 hover:text-white',
            ].join(' ')}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>

    <!-- CTA (desktop) -->
    <button
      onclick="openModal()"
      class="hidden md:inline-flex items-center gap-2 bg-white px-4 py-2 text-sm font-semibold text-black transition-colors hover:bg-zinc-200"
    >
      Book Demo →
    </button>

    <!-- Mobile menu button -->
    <button
      id="mobile-menu-btn"
      class="md:hidden flex flex-col gap-1.5 p-1"
      aria-label="Open menu"
      aria-expanded="false"
    >
      <span class="block h-px w-6 bg-white transition-all duration-200" id="burger-1"></span>
      <span class="block h-px w-6 bg-white transition-all duration-200" id="burger-2"></span>
      <span class="block h-px w-6 bg-white transition-all duration-200" id="burger-3"></span>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden border-t border-zinc-800 bg-black px-6 py-6"
  >
    <ul class="flex flex-col gap-6 mb-8">
      {navLinks.map(({ label, href }) => (
        <li>
          <a
            href={href}
            class={[
              'font-mono text-sm uppercase tracking-widest transition-colors',
              currentPath.startsWith(href)
                ? 'text-white'
                : 'text-zinc-400 hover:text-white',
            ].join(' ')}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
    <button
      onclick="openModal(); document.getElementById('mobile-menu').classList.add('hidden');"
      class="w-full bg-white px-4 py-3 text-sm font-semibold text-black hover:bg-zinc-200 transition-all"
    >
      Book Demo →
    </button>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const b1 = document.getElementById('burger-1');
  const b2 = document.getElementById('burger-2');
  const b3 = document.getElementById('burger-3');

  btn?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('hidden') === false;
    btn.setAttribute('aria-expanded', String(isOpen));
    // animate to X
    if (isOpen) {
      b1?.classList.add('translate-y-[7.5px]', 'rotate-45');
      b2?.classList.add('opacity-0');
      b3?.classList.add('-translate-y-[7.5px]', '-rotate-45');
    } else {
      b1?.classList.remove('translate-y-[7.5px]', 'rotate-45');
      b2?.classList.remove('opacity-0');
      b3?.classList.remove('-translate-y-[7.5px]', '-rotate-45');
    }
  });
</script>
