---
const FORMSPREE_ID = "xwvrwlge";
---

<!-- Modal overlay -->
<div
  id="demo-modal"
  class="hidden fixed inset-0 z-[100] flex items-center justify-center p-4"
  aria-modal="true"
  role="dialog"
>
  <div class="absolute inset-0 bg-black/80 backdrop-blur-sm" id="demo-modal-backdrop"></div>

  <div class="relative w-full max-w-lg rounded-sm border border-zinc-700 bg-zinc-900 shadow-2xl transition-all">

    <!-- Close -->
    <button
      id="demo-modal-close"
      class="absolute top-4 right-4 text-zinc-400 hover:text-white transition-colors"
      aria-label="Close"
    >
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M18 6L6 18M6 6l12 12" />
      </svg>
    </button>

    <div class="p-8">
      <h3 class="text-xl font-bold text-white">Book a Compliance Demo</h3>
      <p class="mt-2 text-sm text-zinc-300">
        See how KYDE provides tamper-evident audit trails for your AI agents. 30 min, no commitment.
      </p>

      <!-- Form -->
      <form
        id="demo-form"
        class="mt-6 space-y-4"
        action={`https://formspree.io/f/${FORMSPREE_ID}`}
        method="POST"
      >
        <div>
          <label for="demo-name" class="block text-xs font-medium text-zinc-400 mb-1.5">Name</label>
          <input
            type="text" id="demo-name" name="name" required
            placeholder="Jane Smith"
            class="w-full rounded-sm border border-zinc-600 bg-zinc-800 px-4 py-2.5 text-sm text-white placeholder-zinc-500 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500 transition-colors"
          />
        </div>
        <div>
          <label for="demo-email" class="block text-xs font-medium text-zinc-400 mb-1.5">Work Email</label>
          <input
            type="email" id="demo-email" name="email" required
            placeholder="jane@company.com"
            class="w-full rounded-sm border border-zinc-600 bg-zinc-800 px-4 py-2.5 text-sm text-white placeholder-zinc-500 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500 transition-colors"
          />
        </div>
        <div>
          <label for="demo-company" class="block text-xs font-medium text-zinc-400 mb-1.5">Company</label>
          <input
            type="text" id="demo-company" name="company"
            placeholder="Acme Corp"
            class="w-full rounded-sm border border-zinc-600 bg-zinc-800 px-4 py-2.5 text-sm text-white placeholder-zinc-500 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500 transition-colors"
          />
        </div>
        <div>
          <label for="demo-agents" class="block text-xs font-medium text-zinc-400 mb-1.5">How many AI agents do you run?</label>
          <select
            id="demo-agents" name="agents"
            class="w-full rounded-sm border border-zinc-600 bg-zinc-800 px-4 py-2.5 text-sm text-white focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500 transition-colors"
          >
            <option value="1-5">1–5</option>
            <option value="6-20">6–20</option>
            <option value="21-100">21–100</option>
            <option value="100+">100+</option>
          </select>
        </div>
        <input type="hidden" name="_subject" value="KYDE Demo Request" />
        <button
          type="submit" id="demo-submit"
          class="w-full rounded-sm bg-blue-600 px-4 py-3 text-sm font-semibold text-white shadow-lg shadow-blue-600/25 hover:bg-blue-500 transition-all"
        >
          Request Demo
        </button>
        <p class="text-xs text-zinc-500 text-center">We'll get back to you within 24 hours.</p>
      </form>

      <!-- Success state -->
      <div id="demo-success" class="hidden mt-6 text-center py-8">
        <div class="mx-auto mb-4 inline-flex h-12 w-12 items-center justify-center rounded-full bg-emerald-400/10">
          <svg class="h-6 w-6 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M5 13l4 4L19 7" />
          </svg>
        </div>
        <h4 class="text-lg font-semibold text-white">Request received!</h4>
        <p class="mt-2 text-sm text-zinc-300">We'll be in touch within 24 hours.</p>
      </div>
    </div>
  </div>
</div>

<script>
  // Open / close
  function openModal() {
    document.getElementById('demo-modal')?.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    document.getElementById('demo-modal')?.classList.add('hidden');
    document.body.style.overflow = '';
  }

  // Expose globally
  (window as any).openModal = openModal;
  (window as any).closeModal = closeModal;

  // Close on backdrop / ESC
  document.getElementById('demo-modal-backdrop')?.addEventListener('click', closeModal);
  document.getElementById('demo-modal-close')?.addEventListener('click', closeModal);
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });

  // Form submit
  const form = document.getElementById('demo-form') as HTMLFormElement | null;
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('demo-submit') as HTMLButtonElement;
    btn.textContent = 'Sending…';
    btn.disabled = true;

    try {
      const res = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
        headers: { Accept: 'application/json' },
      });
      if (res.ok) {
        form.classList.add('hidden');
        document.getElementById('demo-success')?.classList.remove('hidden');
      } else {
        throw new Error('server error');
      }
    } catch {
      btn.textContent = 'Request Demo';
      btn.disabled = false;
      alert('Something went wrong. Please email hello@kyde.com directly.');
    }
  });
</script>
