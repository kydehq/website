---
import Base from "../layouts/Base.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
---

<Base
    title="Platform — KYDE"
    description="KYDE WITNESS is a model-agnostic governance proxy that sits between your AI agents and every LLM provider. Identity, roles, budgets, and tamper-evident accountability — without touching agent code."
>
    <Navbar />

    <main>

        <!-- ══════════ HERO ══════════ -->
        <section class="relative overflow-hidden pt-36 pb-24 md:pt-48 md:pb-36">
            <div class="bg-grid absolute inset-0 pointer-events-none"></div>
            <div class="relative max-w-7xl mx-auto px-6">

                <div class="mb-10">
                    <div class="flex items-center gap-3 mb-3">
                        <span class="h-1.5 w-1.5 rounded-full bg-zinc-500 shrink-0"></span>
                        <span class="font-mono text-xs uppercase tracking-[0.2em] text-amber-300">↳ Kyde Witness — Platform</span>
                    </div>
                    <div class="h-px w-full bg-zinc-800"></div>
                </div>

                <h1 class="hero-h1 max-w-5xl text-5xl text-white uppercase tracking-tight md:text-6xl lg:text-7xl">
                    One proxy. Your entire agent fleet.<br />
                    <span class="gradient-text">Full operational control.</span>
                </h1>

                <div class="mt-16 border-t border-zinc-800 pt-10 grid md:grid-cols-[200px_1fr] gap-8 items-start">
                    <div>
                        <p class="text-xs font-bold uppercase tracking-[0.15em] text-white">Governance Proxy</p>
                        <p class="mt-2 font-mono text-xs text-zinc-600">[KYDE WITNESS]</p>
                    </div>
                    <div class="space-y-10">
                        <p class="text-sm uppercase tracking-wide leading-relaxed text-zinc-400">
                            KYDE WITNESS is a model-agnostic governance proxy that sits between your AI agents and every LLM provider. It gives every agent an identity, enforces role-based boundaries, and produces a tamper-evident evidence trail — without touching agent code.
                        </p>

                        <!-- Stats -->
                        <div class="grid grid-cols-3 divide-x divide-zinc-800 border border-zinc-800">
                            {[
                                { value: "<100ms", label: "Added latency" },
                                { value: "100%", label: "Provider coverage" },
                                { value: "0", label: "Code changes required" },
                            ].map(({ value, label }) => (
                                <div class="px-6 py-5">
                                    <p class="font-mono text-2xl font-bold text-white">{value}</p>
                                    <p class="mt-1 text-xs text-zinc-500 uppercase tracking-widest">{label}</p>
                                </div>
                            ))}
                        </div>

                        <!-- CTAs -->
                        <div class="flex flex-col sm:flex-row items-start gap-4">
                            <button
                                onclick="openModal()"
                                class="inline-flex items-center gap-2 bg-white px-6 py-3.5 text-sm font-semibold text-black hover:bg-zinc-200 transition-all"
                            >
                                Book Demo →
                            </button>
                            <a
                                href="/resources"
                                class="inline-flex items-center gap-2 border border-zinc-700 px-6 py-3.5 text-sm font-semibold text-zinc-300 hover:border-zinc-500 hover:text-white transition-all"
                            >
                                View Integration Docs
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- ══════════ HOW IT WORKS ══════════ -->
        <section class="relative border-t border-zinc-800/60 py-24 md:py-32">
            <div class="relative max-w-7xl mx-auto px-6">

                <div class="mb-12">
                    <div class="flex items-center gap-3 mb-3">
                        <span class="h-1.5 w-1.5 rounded-full bg-zinc-600 shrink-0"></span>
                        <span class="font-mono text-xs uppercase tracking-[0.2em] text-amber-300">↳ How it works</span>
                    </div>
                    <div class="h-px w-full bg-zinc-800"></div>
                </div>

                <div class="grid md:grid-cols-2 gap-16 items-start">
                    <div>
                        <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-white mb-6">
                            The proxy intercepts. Signs. Chains. Forwards.
                        </h2>
                        <p class="text-zinc-400 leading-relaxed mb-8">
                            KYDE WITNESS runs as a local or hosted HTTP proxy, fully compatible with the OpenAI API schema. Any agent that can be pointed at a base URL can be governed.
                        </p>
                        <div class="border border-zinc-800 bg-zinc-900/80 rounded-sm mb-8">
                            <div class="flex items-center gap-2 border-b border-zinc-700 px-4 py-3">
                                <span class="h-3 w-3 rounded-full bg-red-400/60"></span>
                                <span class="h-3 w-3 rounded-full bg-amber-400/60"></span>
                                <span class="h-3 w-3 rounded-full bg-emerald-400/60"></span>
                                <span class="ml-2 text-xs text-zinc-500 font-mono">terminal</span>
                            </div>
                            <div class="p-5 font-mono text-sm">
                                <p class="text-zinc-400"><span class="text-emerald-400">$</span><span class="text-zinc-200"> export OPENAI_BASE_URL=https://witness.intranet/v1</span></p>
                            </div>
                        </div>
                        <p class="font-mono text-sm text-zinc-500">One environment variable. No SDK dependency. No code changes required.</p>
                    </div>

                    <div class="space-y-px border border-zinc-800">
                        {[
                            { n: "01", title: "Intercept", body: "Every request from every agent routes through the proxy. The agent sees no difference." },
                            { n: "02", title: "Register", body: "The request is matched to an agent identity and role. Budget and policy checks run before the call is forwarded." },
                            { n: "03", title: "Sign & Chain", body: "An Ed25519-signed, SHA-256 hash-chained entry is written. Alter any record — every subsequent link breaks." },
                            { n: "04", title: "Forward", body: "The original request continues to the LLM provider. Total added latency: under 100ms." },
                        ].map(({ n, title, body }) => (
                            <div class="grid grid-cols-[48px_1fr] bg-zinc-900/40 hover:bg-zinc-800/40 transition-all">
                                <div class="flex items-start justify-center pt-6 border-r border-zinc-800">
                                    <span class="font-mono text-xs text-zinc-600">{n}</span>
                                </div>
                                <div class="p-6">
                                    <h3 class="font-mono text-sm font-bold text-white uppercase tracking-widest mb-2">{title}</h3>
                                    <p class="text-sm text-zinc-400 leading-relaxed">{body}</p>
                                </div>
                            </div>
                        ))}
                    </div>
                </div>
            </div>
        </section>

        <!-- ══════════ WHAT GETS CAPTURED ══════════ -->
        <section class="relative border-t border-zinc-800/60 py-24 md:py-32">
            <div class="relative max-w-7xl mx-auto px-6">

                <div class="mb-12">
                    <div class="flex items-center gap-3 mb-3">
                        <span class="h-1.5 w-1.5 rounded-full bg-zinc-600 shrink-0"></span>
                        <span class="font-mono text-xs uppercase tracking-[0.2em] text-amber-300">↳ Evidence capture</span>
                    </div>
                    <div class="h-px w-full bg-zinc-800"></div>
                </div>

                <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-white mb-16">
                    Every entry answers five questions.
                </h2>

                <div class="grid md:grid-cols-2 gap-12 items-start">

                    <!-- Field table -->
                    <div class="border border-zinc-800 divide-y divide-zinc-800">
                        {[
                            { field: "Who", desc: "Agent ID, role, machine ID, user identity" },
                            { field: "What", desc: "Prompt, model, tool calls, response" },
                            { field: "Why", desc: "Last 5 messages as causal context" },
                            { field: "When", desc: "Millisecond-precise UTC timestamp" },
                            { field: "Proof", desc: "Ed25519 signature + SHA-256 hash chain link" },
                        ].map(({ field, desc }) => (
                            <div class="grid grid-cols-[80px_1fr] divide-x divide-zinc-800">
                                <div class="px-4 py-4 bg-zinc-900/60">
                                    <p class="font-mono text-sm font-bold text-white">{field}</p>
                                </div>
                                <div class="px-4 py-4">
                                    <p class="text-sm text-zinc-400 leading-relaxed">{desc}</p>
                                </div>
                            </div>
                        ))}
                    </div>

                    <!-- JSON entry -->
                    <div class="rounded-sm border border-zinc-800 bg-zinc-900">
                        <div class="flex items-center gap-2 border-b border-zinc-800 px-4 py-3">
                            <span class="h-2 w-2 rounded-full bg-zinc-600"></span>
                            <span class="h-2 w-2 rounded-full bg-zinc-600"></span>
                            <span class="h-2 w-2 rounded-full bg-zinc-600"></span>
                            <span class="ml-2 text-xs text-zinc-500 font-mono">audit_entry.json</span>
                        </div>
                        <pre class="overflow-x-auto p-5 font-mono text-xs leading-relaxed text-zinc-400"><code>{`{
  `}<span class="text-zinc-200">"entry_id"</span>{`: `}<span class="text-zinc-500">"e_7f3a2b1c"</span>{`,
  `}<span class="text-zinc-200">"sequence"</span>{`: `}<span class="text-white">1847</span>{`,
  `}<span class="text-zinc-200">"agent_id"</span>{`: `}<span class="text-zinc-500">"sales_bot_prod"</span>{`,
  `}<span class="text-zinc-200">"role"</span>{`: `}<span class="text-zinc-500">"customer_facing"</span>{`,
  `}<span class="text-zinc-200">"timestamp"</span>{`: `}<span class="text-zinc-500">"2026-03-15T14:23:07Z"</span>{`,
  `}<span class="text-zinc-200">"action"</span>{`: `}<span class="text-zinc-500">"chat.completion"</span>{`,
  `}<span class="text-zinc-200">"provider"</span>{`: `}<span class="text-zinc-500">"openai"</span>{`,
  `}<span class="text-zinc-200">"model"</span>{`: `}<span class="text-zinc-500">"gpt-4o"</span>{`,
  `}<span class="text-zinc-200">"tool_calls"</span>{`: [`}<span class="text-zinc-500">"crm.update_deal"</span>{`, `}<span class="text-zinc-500">"slack.send_message"</span>{`],
  `}<span class="text-zinc-200">"input_hash"</span>{`: `}<span class="text-zinc-500">"sha256:9f86d0..."</span>{`,
  `}<span class="text-zinc-200">"entry_hash"</span>{`: `}<span class="text-zinc-500">"sha256:7b2e4d..."</span>{`,
  `}<span class="text-zinc-200">"prev_hash"</span>{`: `}<span class="text-zinc-500">"sha256:1c3f8a..."</span>{`,
  `}<span class="text-zinc-200">"signature"</span>{`: `}<span class="text-zinc-500">"ed25519:Mk3nR9..."</span>{`
}`}</code></pre>
                    </div>
                </div>
            </div>
        </section>

        <!-- ══════════ FLEET MANAGEMENT ══════════ -->
        <section class="relative border-t border-zinc-800/60 py-24 md:py-32">
            <div class="relative max-w-7xl mx-auto px-6">

                <div class="mb-12">
                    <div class="flex items-center gap-3 mb-3">
                        <span class="h-1.5 w-1.5 rounded-full bg-zinc-600 shrink-0"></span>
                        <span class="font-mono text-xs uppercase tracking-[0.2em] text-amber-300">↳ Fleet management</span>
                    </div>
                    <div class="h-px w-full bg-zinc-800"></div>
                </div>

                <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-white mb-4">
                    Roles. Budgets. Boundaries. Per agent.
                </h2>
                <p class="text-zinc-400 leading-relaxed mb-16 max-w-2xl">
                    Every agent in your fleet gets a distinct identity and an assigned role. Roles determine what an agent is permitted to do — and what it costs you when it does it.
                </p>

                <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
                    {[
                        {
                            title: "Identity & Roles",
                            body: "Register every agent with a unique ID. Assign roles — infrastructure, customer_facing, internal_research, intern_sandbox. Roles carry permissions, not agents.",
                            tag: "Core",
                        },
                        {
                            title: "Priority & Resource Allocation",
                            body: "Your production infrastructure agent gets priority over your intern's research bot. When token budgets run tight, critical agents aren't the ones that queue.",
                            tag: "Fleet",
                        },
                        {
                            title: "Token & Cost Budgets",
                            body: "Set hard limits per agent, per role, or per team. Daily, weekly, monthly. No agent runs up a bill you didn't authorize.",
                            tag: "Fleet",
                        },
                        {
                            title: "API Allowlists & Blocklists",
                            body: "Define which endpoints each role is permitted to reach. Your billing agent talks to the payment API. Your support agent doesn't.",
                            tag: "Policy",
                        },
                        {
                            title: "Behavioral Baselines & Anomaly Detection",
                            body: "Kyde learns what normal looks like for each role. When an agent deviates — unusual call volume, unexpected endpoints, out-of-pattern tool usage — you get alerted before it becomes an incident.",
                            tag: "Coming Soon",
                        },
                    ].map(({ title, body, tag }) => (
                        <div class="rounded-sm border border-zinc-800 bg-zinc-900/50 p-6 hover:bg-zinc-800/50 transition-all">
                            <div class="mb-4 flex items-center justify-between">
                                <span class="font-mono text-xs uppercase tracking-widest text-zinc-600">{tag}</span>
                            </div>
                            <h3 class="mb-3 text-base font-semibold text-white">{title}</h3>
                            <p class="text-sm leading-relaxed text-zinc-400">{body}</p>
                        </div>
                    ))}
                </div>
            </div>
        </section>

        <!-- ══════════ ARCHITECTURE ══════════ -->
        <section class="relative border-t border-zinc-800/60 py-24 md:py-32">
            <div class="relative max-w-7xl mx-auto px-6">

                <div class="mb-12">
                    <div class="flex items-center gap-3 mb-3">
                        <span class="h-1.5 w-1.5 rounded-full bg-zinc-600 shrink-0"></span>
                        <span class="font-mono text-xs uppercase tracking-[0.2em] text-amber-300">↳ Architecture</span>
                    </div>
                    <div class="h-px w-full bg-zinc-800"></div>
                </div>

                <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-white mb-16">
                    Gateway, not endpoint.
                </h2>

                <div class="grid md:grid-cols-2 gap-8">

                    <!-- Gateway model -->
                    <div class="border border-zinc-700 bg-zinc-900/40 p-8">
                        <p class="font-mono text-xs uppercase tracking-widest text-zinc-300 mb-6">KYDE WITNESS — Gateway Model</p>
                        <div class="font-mono text-sm text-zinc-400 space-y-1 mb-8">
                            <p><span class="text-zinc-300">Agent A</span> ──┐</p>
                            <p><span class="text-zinc-300">Agent B</span> ──┼──► <span class="text-amber-300">KYDE WITNESS</span> ──► <span class="text-zinc-300">LLM API</span></p>
                            <p><span class="text-zinc-300">Agent C</span> ──┘</p>
                            <p class="mt-4 text-zinc-600">               ↓</p>
                            <p class="text-zinc-500">        Central DB · One record</p>
                        </div>
                        <ul class="space-y-2">
                            {[
                                "One deployment covers the entire fleet",
                                "Works with every agent, framework, and LLM",
                                "Central visibility — no aggregation required",
                                "No per-agent installation or configuration",
                            ].map((item) => (
                                <li class="flex items-center gap-3 text-sm text-zinc-300">
                                    <svg class="h-4 w-4 shrink-0 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 13l4 4L19 7" /></svg>
                                    {item}
                                </li>
                            ))}
                        </ul>
                    </div>

                    <!-- Endpoint model -->
                    <div class="border border-zinc-800 bg-zinc-950 p-8">
                        <p class="font-mono text-xs uppercase tracking-widest text-zinc-600 mb-6">Endpoint / Runtime Solutions</p>
                        <div class="font-mono text-sm text-zinc-600 space-y-1 mb-8">
                            <p>Agent A + Runtime ──► LLM API &nbsp; ↓ Log A</p>
                            <p>Agent B + Runtime ──► LLM API &nbsp; ↓ Log B</p>
                            <p>Agent C + Runtime ──► LLM API &nbsp; ↓ Log C</p>
                        </div>
                        <ul class="space-y-2">
                            {[
                                "Install on every agent separately",
                                "Framework- and runtime-specific",
                                "Fragmented logs — difficult to aggregate",
                            ].map((item) => (
                                <li class="flex items-center gap-3 text-sm text-zinc-600">
                                    <svg class="h-4 w-4 shrink-0 text-zinc-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M18 12H6" /></svg>
                                    {item}
                                </li>
                            ))}
                        </ul>
                    </div>
                </div>

                <!-- Comparison table -->
                <div class="mt-8 border border-zinc-800 divide-y divide-zinc-800">
                    <div class="grid grid-cols-3 divide-x divide-zinc-800 bg-zinc-900/60">
                        <div class="px-6 py-3"><p class="font-mono text-xs uppercase tracking-widest text-zinc-500">Property</p></div>
                        <div class="px-6 py-3"><p class="font-mono text-xs uppercase tracking-widest text-white">KYDE WITNESS</p></div>
                        <div class="px-6 py-3"><p class="font-mono text-xs uppercase tracking-widest text-zinc-600">Endpoint Solutions</p></div>
                    </div>
                    {[
                        { prop: "Deployment effort", kyde: "One ENV variable", other: "Per-agent installation" },
                        { prop: "Agent coverage", kyde: "All agents, automatically", other: "Each agent separately" },
                        { prop: "Fleet management", kyde: "Central roles, budgets, policies", other: "Per-agent configuration" },
                        { prop: "Audit trail", kyde: "Single, tamper-evident record", other: "Fragmented per agent" },
                        { prop: "Code changes needed", kyde: "None", other: "Typically required" },
                    ].map(({ prop, kyde, other }) => (
                        <div class="grid grid-cols-3 divide-x divide-zinc-800">
                            <div class="px-6 py-4"><p class="text-sm text-zinc-500">{prop}</p></div>
                            <div class="px-6 py-4"><p class="text-sm text-zinc-200">{kyde}</p></div>
                            <div class="px-6 py-4"><p class="text-sm text-zinc-600">{other}</p></div>
                        </div>
                    ))}
                </div>
            </div>
        </section>

        <!-- ══════════ SIGNING LAYER ══════════ -->
        <section class="relative border-t border-zinc-800/60 py-24 md:py-32">
            <div class="relative max-w-7xl mx-auto px-6">

                <div class="mb-12">
                    <div class="flex items-center gap-3 mb-3">
                        <span class="h-1.5 w-1.5 rounded-full bg-zinc-600 shrink-0"></span>
                        <span class="font-mono text-xs uppercase tracking-[0.2em] text-amber-300">↳ Root of trust</span>
                    </div>
                    <div class="h-px w-full bg-zinc-800"></div>
                </div>

                <div class="grid md:grid-cols-2 gap-16 items-start">
                    <div>
                        <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-white mb-6">
                            Root of trust.<br />From software to silicon.
                        </h2>
                        <p class="text-zinc-400 leading-relaxed mb-6">
                            Each entry is signed with an Ed25519 keypair generated locally on first initialization. The hash chain ensures sequential integrity — tamper with any single entry, and every subsequent link breaks.
                        </p>
                        <p class="text-zinc-400 leading-relaxed mb-10">
                            For environments where software-only signing isn't enough, Kyde's architecture is built for hardware-rooted attestation from day one.
                        </p>
                        <p class="font-mono text-sm text-zinc-300 border-l-2 border-amber-400/60 pl-4 leading-relaxed">
                            No re-architecture required between levels. Same API. Same data format. Same evidence chain. The root of trust gets deeper — the interface stays the same.
                        </p>
                    </div>

                    <div class="border border-zinc-800 divide-y divide-zinc-800">
                        <div class="grid grid-cols-[80px_1fr_80px] divide-x divide-zinc-800 bg-zinc-900/60">
                            <div class="px-4 py-3"><p class="font-mono text-xs text-zinc-600 uppercase tracking-widest">Level</p></div>
                            <div class="px-4 py-3"><p class="font-mono text-xs text-zinc-600 uppercase tracking-widest">Mechanism</p></div>
                            <div class="px-4 py-3"><p class="font-mono text-xs text-zinc-600 uppercase tracking-widest">Status</p></div>
                        </div>
                        {[
                            { level: "Software", desc: "Ed25519 keypair, local generation", status: "LIVE", live: true },
                            { level: "HSM", desc: "PKCS#11 hardware security module", status: "ROADMAP", live: false },
                            { level: "TEE", desc: "Trusted Execution Environment (TDX/SEV-SNP)", status: "ROADMAP", live: false },
                            { level: "FIPS", desc: "FIPS 140-3 validated crypto modules", status: "ROADMAP", live: false },
                        ].map(({ level, desc, status, live }) => (
                            <div class="grid grid-cols-[80px_1fr_80px] divide-x divide-zinc-800">
                                <div class="px-4 py-4"><p class="font-mono text-sm text-white">{level}</p></div>
                                <div class="px-4 py-4"><p class="text-sm text-zinc-400">{desc}</p></div>
                                <div class="px-4 py-4">
                                    <span class={`font-mono text-[10px] tracking-widest ${live ? "text-emerald-400" : "text-zinc-600"}`}>{status}</span>
                                </div>
                            </div>
                        ))}
                    </div>
                </div>
            </div>
        </section>

        <!-- ══════════ PHASES ══════════ -->
        <section class="relative border-t border-zinc-800/60 py-24 md:py-32">
            <div class="max-w-7xl mx-auto px-6">

                <div class="mb-12">
                    <div class="flex items-center gap-3 mb-3">
                        <span class="h-1.5 w-1.5 rounded-full bg-zinc-600 shrink-0"></span>
                        <span class="font-mono text-xs uppercase tracking-[0.2em] text-amber-300">↳ Product roadmap</span>
                    </div>
                    <div class="h-px w-full bg-zinc-800"></div>
                </div>

                <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-white mb-16">
                    From visibility to resilience.
                </h2>

                <div class="grid gap-8 lg:grid-cols-3">
                    <!-- OBSERVE -->
                    <div class="rounded-sm border border-zinc-800 bg-zinc-900/60 p-8">
                        <div class="mb-6 flex items-center justify-between">
                            <span class="text-xs font-semibold uppercase tracking-widest text-zinc-500">Phase 1</span>
                            <span class="border border-zinc-700 px-3 py-1 text-xs font-mono text-zinc-400">Available Now</span>
                        </div>
                        <h3 class="mb-1 font-mono text-2xl font-bold text-white">OBSERVE</h3>
                        <p class="mb-2 text-sm font-medium text-amber-400">See everything.</p>
                        <p class="mb-6 text-sm leading-relaxed text-zinc-500">Passive observation and evidence preservation. Nothing is blocked. Nothing is altered. Complete forensic visibility with zero operational risk.</p>
                        <ul class="space-y-2">
                            {[
                                "Tamper-evident append-only database",
                                "Ed25519 signing + SHA-256 hash chaining",
                                "Agent identity registration",
                                "Causal context capture",
                                "CLI audit and verification tools",
                                "Provider-agnostic interception",
                            ].map((f) => (
                                <li class="flex items-center gap-3 text-sm">
                                    <svg class="h-4 w-4 shrink-0 text-zinc-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 13l4 4L19 7" /></svg>
                                    <span class="text-zinc-300">{f}</span>
                                </li>
                            ))}
                        </ul>
                    </div>

                    <!-- GOVERN -->
                    <div class="rounded-sm border border-zinc-700 bg-zinc-900/60 p-8">
                        <div class="mb-6 flex items-center justify-between">
                            <span class="text-xs font-semibold uppercase tracking-widest text-zinc-500">Phase 2</span>
                            <span class="border border-zinc-600 px-3 py-1 text-xs font-mono text-zinc-300">Coming Soon</span>
                        </div>
