---
import Base from "../layouts/Base.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
---

<Base
    title="Platform — KYDE"
    description="KYDE - Silicon Leash. A model-agnostic proxy that sits between your AI agents and every LLM provider. Every action signed. Every chain verifiable."
>
    <Navbar />

    <main>
        <!-- ══════════ HERO ══════════ -->
        <section class="relative overflow-hidden pt-36 pb-24 md:pt-48 md:pb-36">
            <div class="bg-grid absolute inset-0 pointer-events-none"></div>
            <div
                class="pointer-events-none absolute top-0 left-0 h-[500px] w-[700px] rounded-full bg-blue-600/5 blur-3xl"
            >
            </div>

            <div class="relative max-w-7xl mx-auto px-6">
                <p
                    class="mb-6 text-sm font-semibold uppercase tracking-widest text-blue-400"
                >
                    Platform
                </p>
                <h1
                    class="hero-h1 max-w-4xl text-6xl text-white md:text-7xl lg:text-8xl"
                >
                    Silicon Leash.<br />
                    <span class="gradient-text"
                        >The Governance Stack for AI Agents.</span
                    >
                </h1>
                <p
                    class="mt-6 max-w-2xl text-lg leading-relaxed text-zinc-300 md:text-xl"
                >
                    A model-agnostic proxy that sits between your AI agents and
                    every LLM provider. Every action signed. Every chain
                    verifiable. Every regulator satisfied.
                </p>
                <div class="mt-10 flex flex-col sm:flex-row items-start gap-4">
                    <button
                        onclick="openModal()"
                        class="inline-flex items-center gap-2 rounded-sm bg-blue-600 px-6 py-3.5 text-sm font-semibold text-white shadow-lg shadow-blue-600/25 hover:bg-blue-500 transition-all"
                    >
                        Book Compliance Demo
                    </button>
                    <a
                        href="#"
                        class="inline-flex items-center gap-2 rounded-sm border border-zinc-700 bg-zinc-900/50 px-6 py-3.5 text-sm font-semibold text-zinc-200 hover:border-zinc-500 hover:bg-zinc-800 hover:text-white transition-all"
                    >
                        View Integration Docs
                    </a>
                </div>
            </div>
        </section>

        <!-- ══════════ WHAT IT IS ══════════ -->
        <section class="relative py-24 md:py-32">
            <div
                class="absolute inset-0 bg-gradient-to-b from-black via-zinc-900/30 to-black pointer-events-none"
            >
            </div>
            <div class="relative max-w-7xl mx-auto px-6">
                <div class="grid gap-16 lg:grid-cols-2 lg:items-center">
                    <div>
                        <p
                            class="mb-4 text-sm font-semibold uppercase tracking-widest text-blue-400"
                        >
                            What Silicon Leash is
                        </p>
                        <h2
                            class="text-3xl md:text-4xl font-bold tracking-tight text-white leading-tight"
                        >
                            Not a filter.<br />A cryptographic evidence layer.
                        </h2>
                        <div
                            class="mt-6 space-y-4 text-zinc-300 leading-relaxed"
                        >
                            <p>
                                Silicon Leash does not inspect, block, or
                                rate-limit your prompts by default. It is a
                                transparent proxy that records what your AI
                                agents did, in a form that cannot be altered
                                after the fact.
                            </p>
                            <p>
                                Think of it as the black box for your agent
                                fleet. It runs silently, adds less than 100ms of
                                latency, and produces a tamper-evident audit
                                trail that survives any audit, any incident
                                investigation, and any regulatory inquiry.
                            </p>
                        </div>
                        <div class="mt-8 grid grid-cols-3 gap-4">
                            {
                                [
                                    { val: "<100ms", label: "Added latency" },
                                    { val: "100%", label: "Provider coverage" },
                                    {
                                        val: "0",
                                        label: "Code changes required",
                                    },
                                ].map(({ val, label }) => (
                                    <div class="rounded-sm border border-zinc-800 bg-zinc-900/60 p-4">
                                        <p class="font-mono text-2xl font-bold text-white">
                                            {val}
                                        </p>
                                        <p class="mt-1 text-xs text-zinc-400">
                                            {label}
                                        </p>
                                    </div>
                                ))
                            }
                        </div>
                    </div>

                    <!-- Terminal -->
                    <div
                        class="glow-blue rounded-sm border border-zinc-700 bg-zinc-900"
                    >
                        <div
                            class="flex items-center gap-2 border-b border-zinc-700 px-4 py-3"
                        >
                            <span class="h-3 w-3 rounded-full bg-red-400/60"
                            ></span>
                            <span class="h-3 w-3 rounded-full bg-amber-400/60"
                            ></span>
                            <span class="h-3 w-3 rounded-full bg-emerald-400/60"
                            ></span>
                            <span class="ml-2 text-xs text-zinc-500 font-mono"
                                >terminal</span
                            >
                        </div>
                        <div class="p-6 font-mono text-sm leading-loose">
                            <p class="text-zinc-400">
                                <span class="text-emerald-400">$</span>
                                <span class="text-zinc-200"
                                    >export
                                    OPENAI_BASE_URL=http://localhost:8080/v1</span
                                >
                            </p>
                            <p class="text-zinc-400">
                                <span class="text-emerald-400">$</span>
                                <span class="text-zinc-200"
                                    >silicon-leash init</span
                                >
                            </p>
                            <p class="text-cyan-400">
                                &#10003; Proxy started on :8080
                            </p>
                            <p class="text-cyan-400">
                                &#10003; Ed25519 keypair generated
                            </p>
                            <p class="text-cyan-400">
                                &#10003; Append-only database initialized
                            </p>
                            <p class="mt-2 text-zinc-400">
                                <span class="text-emerald-400">$</span>
                                <span class="text-zinc-200"
                                    >silicon-leash verify</span
                                >
                            </p>
                            <p class="text-emerald-400">
                                &#10003; Chain integrity: OK — 1,847 entries, 0
                                anomalies
                            </p>
                            <p class="mt-2 text-zinc-400">
                                <span class="text-emerald-400">$</span>
                                <span class="text-zinc-200"
                                    >silicon-leash audit --from 2026-03-01</span
                                >
                            </p>
                            <p class="text-zinc-400 text-xs mt-1">
                                entry_id &nbsp;&nbsp;&nbsp; agent
                                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
                                action
                                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
                                verified
                            </p>
                            <p class="text-zinc-300 text-xs">
                                e_7f3a2b1c &nbsp; sales_bot
                                &nbsp;&nbsp;&nbsp;&nbsp; chat.completion &nbsp; <span
                                    class="text-emerald-400">✓</span
                                >
                            </p>
                            <p class="text-zinc-300 text-xs">
                                e_8a1c3d2e &nbsp; billing_agent &nbsp; tool.call
                                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; <span
                                    class="text-emerald-400">✓</span
                                >
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- ══════════ ARCHITECTURE ══════════ -->
        <section class="relative py-24 md:py-32">
            <div class="max-w-7xl mx-auto px-6">
                <div class="max-w-2xl">
                    <p
                        class="mb-4 text-sm font-semibold uppercase tracking-widest text-blue-400"
                    >
                        Architecture
                    </p>
                    <h2
                        class="text-3xl md:text-4xl font-bold tracking-tight text-white"
                    >
                        Three layers. One proxy.
                    </h2>
                </div>

                <div class="mt-16 grid gap-8 lg:grid-cols-3">
                    <!-- The Proxy -->
                    <div
                        class="rounded-sm border border-zinc-700 bg-zinc-900/60 p-8"
                    >
                        <div
                            class="mb-5 inline-flex rounded-sm bg-blue-400/10 p-3 text-blue-400"
                        >
                            <svg
                                class="h-6 w-6"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                                stroke-width="1.5"
                            >
                                <path
                                    d="M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5"
                                ></path>
                            </svg>
                        </div>
                        <h3 class="mb-3 text-xl font-bold text-white">
                            The Proxy
                        </h3>
                        <p class="text-sm leading-relaxed text-zinc-300 mb-4">
                            Silicon Leash runs as a local or hosted HTTP proxy,
                            fully compatible with the OpenAI API schema. Any
                            agent that can be pointed at a base URL can be
                            governed.
                        </p>
                        <div
                            class="rounded-sm bg-zinc-950 border border-zinc-800 px-4 py-3 font-mono text-xs text-emerald-400"
                        >
                            OPENAI_BASE_URL=http://localhost:8080/v1
                        </div>
                        <p class="mt-4 text-xs text-zinc-500">
                            One environment variable. No SDK dependency. No code
                            changes required.
                        </p>
                    </div>

                    <!-- The Append-Only Database -->
                    <div
                        class="rounded-sm border border-zinc-700 bg-zinc-900/60 p-8"
                    >
                        <div
                            class="mb-5 inline-flex rounded-sm bg-cyan-400/10 p-3 text-cyan-400"
                        >
                            <svg
                                class="h-6 w-6"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                                stroke-width="1.5"
                            >
                                <path
                                    d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 2.625c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125m16.5 5.625c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125"
                                ></path>
                            </svg>
                        </div>
                        <h3 class="mb-3 text-xl font-bold text-white">
                            The Append-Only Database
                        </h3>
                        <p class="text-sm leading-relaxed text-zinc-300 mb-4">
                            Every LLM interaction produces a signed,
                            hash-chained entry. Tamper with any single entry,
                            and every subsequent link breaks.
                        </p>
                        <ul class="space-y-2 text-sm text-zinc-400">
                            {
                                [
                                    [
                                        "Who acted",
                                        "agent ID, machine ID, user identity",
                                    ],
                                    [
                                        "What happened",
                                        "prompt, model, tool calls, response",
                                    ],
                                    [
                                        "Why it happened",
                                        "last 5 messages as causal context",
                                    ],
                                    [
                                        "When",
                                        "millisecond-precise UTC timestamp",
                                    ],
                                    [
                                        "Proof",
                                        "Ed25519 sig + SHA-256 hash chain",
                                    ],
                                ].map(([label, val]) => (
                                    <li class="flex gap-2">
                                        <span class="shrink-0 font-mono text-xs text-zinc-500 w-24">
                                            {label}
                                        </span>
                                        <span class="text-xs text-zinc-400">
                                            {val}
                                        </span>
                                    </li>
                                ))
                            }
                        </ul>
                    </div>

                    <!-- The Signing Layer -->
                    <div
                        class="rounded-sm border border-zinc-700 bg-zinc-900/60 p-8"
                    >
                        <div
                            class="mb-5 inline-flex rounded-sm bg-emerald-400/10 p-3 text-emerald-400"
                        >
                            <svg
                                class="h-6 w-6"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                                stroke-width="1.5"
                            >
                                <path
                                    d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"
                                ></path>
                            </svg>
                        </div>
                        <h3 class="mb-3 text-xl font-bold text-white">
                            The Signing Layer
                        </h3>
                        <p class="text-sm leading-relaxed text-zinc-300 mb-4">
                            Each entry is signed with an Ed25519 keypair
                            generated locally on first initialization.
                        </p>
                        <p class="text-sm leading-relaxed text-zinc-300">
                            In Phase 3, signing is optionally rooted in a
                            PKCS#11 hardware security module (HSM) or Trusted
                            Execution Environment (TEE) for the highest levels
                            of evidential integrity.
                        </p>
                        <div class="mt-4 flex flex-wrap gap-2">
                            {
                                [
                                    "Ed25519",
                                    "PKCS#11",
                                    "HSM",
                                    "TDX/SEV-SNP",
                                ].map((t) => (
                                    <span class="rounded-full border border-zinc-700 bg-zinc-800 px-3 py-0.5 font-mono text-xs text-zinc-300">
                                        {t}
                                    </span>
                                ))
                            }
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- ══════════ GATEWAY VS ENDPOINT ══════════ -->
        <section class="relative py-24 md:py-32">
            <div
                class="absolute inset-0 bg-gradient-to-b from-black via-zinc-900/30 to-black pointer-events-none"
            >
            </div>
            <div class="relative max-w-7xl mx-auto px-6">
                <div class="max-w-2xl mb-16">
                    <p
                        class="mb-4 text-sm font-semibold uppercase tracking-widest text-blue-400"
                    >
                        Architecture
                    </p>
                    <h2
                        class="text-3xl md:text-4xl font-bold tracking-tight text-white"
                    >
                        Gateway, not endpoint.<br />One deployment. Every agent.
                    </h2>
                    <p class="mt-4 text-lg text-zinc-400 leading-relaxed">
                        Other AI governance tools install on the agent or
                        runtime. Silicon Leash sits in the network — between
                        your entire agent fleet and the LLM API. That difference
                        changes everything.
                    </p>
                </div>

                <!-- Architecture diagrams -->
                <div class="grid gap-6 lg:grid-cols-2 mb-16">
                    <!-- Gateway diagram -->
                    <div
                        class="rounded-sm border border-emerald-400/25 bg-zinc-900/60 p-8"
                    >
                        <div class="mb-5 flex items-center gap-3">
                            <span
                                class="inline-flex items-center gap-1.5 rounded-full bg-emerald-400/10 px-3 py-1 text-xs font-medium text-emerald-400"
                                >Silicon Leash</span
                            >
                            <span
                                class="text-xs text-zinc-500 uppercase tracking-widest font-semibold"
                                >Gateway model</span
                            >
                        </div>
                        <!-- Diagram -->
                        <div class="font-mono text-xs space-y-1 mb-6">
                            <div class="flex items-center gap-2">
                                <span
                                    class="rounded border border-zinc-600 bg-zinc-800 px-2 py-1 text-zinc-300 w-28 text-center"
                                    >Agent A</span
                                >
                                <span class="text-zinc-600">──┐</span>
                            </div>
                            <div class="flex items-center gap-2">
                                <span
                                    class="rounded border border-zinc-600 bg-zinc-800 px-2 py-1 text-zinc-300 w-28 text-center"
                                    >Agent B</span
                                >
                                <span class="text-zinc-600">──┼──►</span>
                                <span
                                    class="rounded border border-blue-500/50 bg-blue-600/10 px-2 py-1 text-blue-300 font-semibold"
                                    >Silicon Leash</span
                                >
                                <span class="text-zinc-600">──►</span>
                                <span
                                    class="rounded border border-zinc-600 bg-zinc-800 px-2 py-1 text-zinc-300"
                                    >LLM API</span
                                >
                            </div>
                            <div class="flex items-center gap-2">
                                <span
                                    class="rounded border border-zinc-600 bg-zinc-800 px-2 py-1 text-zinc-300 w-28 text-center"
                                    >Agent C</span
                                >
                                <span class="text-zinc-600">──┘</span>
                            </div>
                            <div class="mt-3 flex items-start gap-2 pl-36">
                                <span class="text-zinc-600">↓</span>
                            </div>
                            <div class="flex items-start gap-2 pl-32">
                                <span
                                    class="rounded border border-emerald-400/30 bg-emerald-400/5 px-2 py-1 text-emerald-400"
                                    >Central DB · One record</span
                                >
                            </div>
                        </div>
                        <ul class="space-y-2 text-sm text-zinc-300">
                            {
                                [
                                    "One deployment covers the entire fleet",
                                    "Works with every agent, framework, and LLM",
                                    "Central visibility — no aggregation required",
                                    "No per-agent installation or configuration",
                                ].map((f) => (
                                    <li class="flex items-center gap-2">
                                        <svg
                                            class="h-4 w-4 shrink-0 text-emerald-400"
                                            fill="none"
                                            viewBox="0 0 24 24"
                                            stroke="currentColor"
                                            stroke-width="2.5"
                                        >
                                            <path d="M5 13l4 4L19 7" />
                                        </svg>
                                        {f}
                                    </li>
                                ))
                            }
                        </ul>
                    </div>

                    <!-- Endpoint diagram -->
                    <div
                        class="rounded-sm border border-zinc-700 bg-zinc-900/40 p-8"
                    >
                        <div class="mb-5 flex items-center gap-3">
                            <span
                                class="inline-flex items-center gap-1.5 rounded-full bg-zinc-700/50 px-3 py-1 text-xs font-medium text-zinc-400"
                                >Endpoint / Runtime solutions</span
                            >
                        </div>
                        <!-- Diagram -->
                        <div class="font-mono text-xs space-y-2 mb-6">
                            {
                                ["Agent A", "Agent B", "Agent C"].map(
                                    (a, i) => (
                                        <div class="flex items-center gap-2">
                                            <span class="rounded border border-zinc-700 bg-zinc-800/60 px-2 py-1 text-zinc-400 w-20 text-center">
                                                {a}
                                            </span>
                                            <span class="text-zinc-700">+</span>
                                            <span class="rounded border border-zinc-700 bg-zinc-800/60 px-2 py-1 text-zinc-500">
                                                Runtime
                                            </span>
                                            <span class="text-zinc-700">
                                                ──►
                                            </span>
                                            <span class="rounded border border-zinc-700 bg-zinc-800/60 px-2 py-1 text-zinc-500">
                                                LLM API
                                            </span>
                                        </div>
                                    ),
                                )
                            }
                            <div class="mt-3 flex gap-6 text-zinc-700">
                                <div class="flex flex-col items-center gap-1">
                                    <span>↓</span>
                                    <span
                                        class="rounded border border-zinc-800 px-2 py-1 text-zinc-600"
                                        >Log A</span
                                    >
                                </div>
                                <div
                                    class="flex flex-col items-center gap-1 ml-4"
                                >
                                    <span>↓</span>
                                    <span
                                        class="rounded border border-zinc-800 px-2 py-1 text-zinc-600"
                                        >Log B</span
                                    >
                                </div>
                                <div
                                    class="flex flex-col items-center gap-1 ml-4"
                                >
                                    <span>↓</span>
                                    <span
                                        class="rounded border border-zinc-800 px-2 py-1 text-zinc-600"
                                        >Log C</span
                                    >
                                </div>
                            </div>
                        </div>
                        <ul class="space-y-2 text-sm text-zinc-500">
                            {
                                [
                                    "Install on every agent separately",
                                    "Framework- and runtime-specific",
                                    "Fragmented logs — difficult to aggregate",
                                    "Each agent deployment is a separate project",
                                ].map((f) => (
                                    <li class="flex items-center gap-2">
                                        <svg
                                            class="h-4 w-4 shrink-0 text-zinc-600"
                                            fill="none"
                                            viewBox="0 0 24 24"
                                            stroke="currentColor"
                                            stroke-width="2"
                                        >
                                            <path d="M18 12H6" />
                                        </svg>
                                        {f}
                                    </li>
                                ))
                            }
                        </ul>
                    </div>
                </div>

                <!-- Comparison table -->
                <div class="max-w-3xl">
                    <div
                        class="rounded-sm border border-zinc-700 overflow-hidden"
                    >
                        <table class="w-full text-sm">
                            <thead>
                                <tr
                                    class="border-b border-zinc-700 bg-zinc-900/80"
                                >
                                    <th
                                        class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-widest text-zinc-400"
                                        >Property</th
                                    >
                                    <th
                                        class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-widest text-blue-400"
                                        >Silicon Leash</th
                                    >
                                    <th
                                        class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-widest text-zinc-500"
                                        >Endpoint solutions</th
                                    >
                                </tr>
                            </thead>
                            <tbody
                                class="divide-y divide-zinc-800 bg-zinc-900/40"
                            >
                                {
                                    [
                                        [
                                            "Deployment effort",
                                            "One ENV variable",
                                            "Per-agent installation",
                                        ],
                                        [
                                            "Agent coverage",
                                            "All agents, automatically",
                                            "Each agent separately",
                                        ],
                                        [
                                            "LLM provider support",
                                            "Any OpenAI-compatible API",
                                            "Varies by runtime",
                                        ],
                                        [
                                            "Audit trail",
                                            "Single, central record",
                                            "Fragmented per agent",
                                        ],
                                        [
                                            "Code changes needed",
                                            "None",
                                            "Typically required",
                                        ],
                                        [
                                            "Compliance export",
                                            "Unified, one command",
                                            "Aggregation required",
                                        ],
                                    ].map(([prop, us, them]) => (
                                        <tr class="hover:bg-zinc-800/20 transition-colors">
                                            <td class="px-6 py-4 text-zinc-400 font-medium">
                                                {prop}
                                            </td>
                                            <td class="px-6 py-4">
                                                <span class="inline-flex items-center gap-1.5 text-emerald-400 text-xs font-medium">
                                                    <svg
                                                        class="h-3.5 w-3.5"
                                                        fill="none"
                                                        viewBox="0 0 24 24"
                                                        stroke="currentColor"
                                                        stroke-width="2.5"
                                                    >
                                                        <path d="M5 13l4 4L19 7" />
                                                    </svg>
                                                    {us}
                                                </span>
                                            </td>
                                            <td class="px-6 py-4 text-zinc-500 text-xs">
                                                {them}
                                            </td>
                                        </tr>
                                    ))
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </section>

        <!-- ══════════ THREE PHASES ══════════ -->
        <section class="relative py-24 md:py-32">
            <div
                class="absolute inset-0 bg-gradient-to-b from-black via-zinc-900/30 to-black pointer-events-none"
            >
            </div>
            <div class="relative max-w-7xl mx-auto px-6">
                <div class="max-w-2xl mb-16">
                    <p
                        class="mb-4 text-sm font-semibold uppercase tracking-widest text-blue-400"
                    >
                        The Three Phases
                    </p>
                    <h2
                        class="text-3xl md:text-4xl font-bold tracking-tight text-white"
