---
import SlideBase from "../../layouts/SlideBase.astro";
---

<SlideBase title="KYDE — Seed Round 2026">
  <style slot="head">
    :root {
      --bg:  #09090b;
      --bg1: #18181b;
      --bd:  #27272a;
      --bd2: #3f3f46;
      --z3:  #e4e4e7;
      --z4:  #d4d4d8;
      --z5:  #a1a1aa;
      --z6:  #71717a;
      --am:  #fbbf24;
      --wh:  #f4f4f5;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { background: var(--bg); }
    body {
      background: var(--bg);
      color: var(--wh);
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      -webkit-font-smoothing: antialiased;
      overflow: hidden;
    }

    .slides {
      height: 100vh;
      overflow-y: scroll;
      scroll-snap-type: y mandatory;
      scrollbar-width: none;
      -ms-overflow-style: none;
    }
    .slides::-webkit-scrollbar { display: none; }

    .slide {
      height: 100vh;
      scroll-snap-align: start;
      scroll-snap-stop: always;
      position: relative;
      display: flex;
      flex-direction: column;
      padding: 48px 80px;
      overflow: hidden;
      border-bottom: 1px solid var(--bd);
    }

    .has-grid::before {
      content: '';
      position: absolute;
      inset: 0;
      background-image:
        linear-gradient(rgba(255,255,255,0.016) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.016) 1px, transparent 1px);
      background-size: 48px 48px;
      pointer-events: none;
    }

    /* Nav dots */
    .nav-dots {
      position: fixed; right: 18px; top: 50%;
      transform: translateY(-50%);
      display: flex; flex-direction: column; gap: 6px;
      z-index: 200;
    }
    .nd {
      width: 3px; height: 3px; border-radius: 50%;
      background: var(--bd2); cursor: pointer;
      transition: height .25s, border-radius .25s, background .25s;
    }
    .nd.on { height: 16px; border-radius: 2px; background: var(--am); }

    .counter {
      position: fixed; bottom: 22px; right: 36px;
      font-family: ui-monospace, monospace;
      font-size: 10px; letter-spacing: 0.22em; color: var(--bd2); z-index: 200;
    }

    .sn {
      position: absolute; top: 48px; right: 80px;
      font-family: ui-monospace, monospace;
      font-size: 10px; letter-spacing: 0.2em; color: var(--bd2);
    }

    /* Label row */
    .lrow { display: flex; align-items: center; gap: 10px; margin-bottom: 32px; flex-shrink: 0; }
    .lrow::after { content:''; flex:1; height:1px; background:var(--bd); }
    .lbl { font-family: ui-monospace, monospace; font-size: 10px; letter-spacing: 0.25em; text-transform: uppercase; color: var(--z6); }
    .dp  { width:6px; height:6px; border-radius:50%; background:var(--am); opacity:.7; flex-shrink:0; animation:pulse 2s ease-in-out infinite; }
    @keyframes pulse { 0%,100%{opacity:.3} 50%{opacity:.9} }

    /* Typography */
    .t-hero { font-family:'Inter',sans-serif; font-size:clamp(56px,8.5vw,112px); font-weight:600; letter-spacing:-.03em; line-height:1.06; text-transform:uppercase; }
    .t-h1   { font-family:'Inter',sans-serif; font-size:clamp(34px,4.2vw,62px);  font-weight:600; letter-spacing:-.03em; line-height:1.05; }
    .t-h2   { font-family:'Inter',sans-serif; font-size:clamp(22px,2.6vw,38px);  font-weight:500; letter-spacing:-.02em; line-height:1.1; }
    .t-b    { font-size: 20px; line-height: 1.6; color: var(--z4); }
    .t-sm   { font-size: 17px; line-height: 1.6; color: var(--z5); }
    .mono   { font-family: ui-monospace, monospace; }
    .am     { color: var(--am); }
    .wh     { color: var(--wh); }
    .dim    { color: var(--z5); }

    /* Cards */
    .card   { border:1px solid var(--bd);  background:var(--bg1); padding:24px 28px; }
    .card-l { border:1px solid var(--bd2); background:var(--bg1); padding:24px 28px; border-left:2px solid var(--am); }

    /* Grids */
    .g3 { display:grid; grid-template-columns:1fr 1fr 1fr; gap:1px; background:var(--bd); }
    .g3>* { background:var(--bg); }
    .g2 { display:grid; grid-template-columns:1fr 1fr; gap:1px; background:var(--bd); }
    .g2>* { background:var(--bg); }

    /* Stacked rows */
    .rows { display:flex; flex-direction:column; gap:1px; background:var(--bd); }
    .row  { background:var(--bg); display:grid; grid-template-columns:200px 1fr; gap:24px; padding:24px 28px; align-items:start; flex:1; }

    /* Question rows */
    .qrow { display:grid; grid-template-columns:220px 1fr; gap:24px; padding:20px 28px; background:var(--bg); align-items:start; border-bottom:1px solid var(--bd); }
    .qrow:last-child { border-bottom:none; }

    /* Market numbers */
    .mnum { font-size:clamp(40px,5vw,72px); font-weight:600; letter-spacing:-.03em; color:var(--wh); line-height:1; margin-bottom:10px; }

    /* Pilot rows */
    .pilot-row { display:grid; grid-template-columns:200px 1fr; gap:20px; padding:16px 24px; background:var(--bg); align-items:start; }

    /* Workforce flip chart */
    .flip-chart {
      flex: 1;
      position: relative;
      border: 1px solid var(--bd);
      background: var(--bg1);
      overflow: hidden;
    }
    .flip-chart svg { position: absolute; inset: 0; width: 100%; height: 100%; }
  </style>

  <!-- Nav dots (12) -->
  <div class="nav-dots">
    <div class="nd on" onclick="gts(0)"></div>
    <div class="nd" onclick="gts(1)"></div>
    <div class="nd" onclick="gts(2)"></div>
    <div class="nd" onclick="gts(3)"></div>
    <div class="nd" onclick="gts(4)"></div>
    <div class="nd" onclick="gts(5)"></div>
    <div class="nd" onclick="gts(6)"></div>
    <div class="nd" onclick="gts(7)"></div>
    <div class="nd" onclick="gts(8)"></div>
    <div class="nd" onclick="gts(9)"></div>
    <div class="nd" onclick="gts(10)"></div>
    <div class="nd" onclick="gts(11)"></div>
  </div>

  <div class="counter"><span id="cn">01</span> / 12</div>

  <div class="slides" id="sl">

    <!-- 01 COVER -->
    <section class="slide has-grid">
      <span class="sn">01 / 12</span>
      <div class="lrow"><span class="dp"></span><span class="lbl">KYDE · SEED ROUND 2026</span></div>

      <div style="flex:1;display:flex;flex-direction:column;justify-content:center">
        <p class="mono am" style="font-size:11px;letter-spacing:.3em;margin-bottom:24px">KYDE</p>
        <h1 class="t-hero" style="margin-bottom:32px">
          The Trust &amp; Control Layer<br>for the Agentic Economy.
        </h1>
        <div style="display:flex;gap:12px;flex-wrap:wrap">
          <span class="mono" style="font-size:12px;letter-spacing:.12em;color:var(--z5);border:1px solid var(--bd);padding:6px 14px;">EU AI Act</span>
          <span class="mono" style="font-size:12px;letter-spacing:.12em;color:var(--z5);border:1px solid var(--bd);padding:6px 14px;">NIS-2</span>
          <span class="mono" style="font-size:12px;letter-spacing:.12em;color:var(--z5);border:1px solid var(--bd);padding:6px 14px;">DORA</span>
          <span class="mono" style="font-size:12px;letter-spacing:.12em;color:var(--z5);border:1px solid var(--bd);padding:6px 14px;">GDPR</span>
          <span class="mono am" style="font-size:12px;letter-spacing:.12em;border:1px solid rgba(251,191,36,.3);padding:6px 14px;">Audit-Ready from Day One.</span>
        </div>
      </div>

      <div style="display:flex;align-items:center;justify-content:space-between;padding-top:20px;border-top:1px solid var(--bd)">
        <div style="display:flex;gap:48px">
          <div>
            <p class="lbl" style="margin-bottom:6px">STATUS</p>
            <p class="mono am" style="font-size:13px;letter-spacing:.1em">SEED ROUND OPEN</p>
          </div>
          <div>
            <p class="lbl" style="margin-bottom:6px">TARGET</p>
            <p class="mono wh" style="font-size:13px;letter-spacing:.1em">€1.6M</p>
          </div>
        </div>
        <div style="display:flex;align-items:center;gap:16px">
          <p class="mono" style="font-size:12px;letter-spacing:.12em;color:var(--z5)">KYDE.COM</p>
          <p class="lbl" style="color:var(--bd2)">CONFIDENTIAL</p>
        </div>
      </div>
    </section>

    <!-- 02 THE PARADIGM SHIFT -->
    <section class="slide">
      <span class="sn">02 / 12</span>
      <div class="lrow"><span class="lbl">↳ THE PARADIGM SHIFT · 01 / 10</span></div>

      <h2 class="t-h1" style="margin-bottom:8px;max-width:900px">The Machine-to-Machine Economy</h2>
      <p class="t-b dim" style="margin-bottom:24px;flex-shrink:0;max-width:820px">Legacy AI built workspaces for humans. We are building the infrastructure for a world without humans in the loop.</p>

      <div style="flex:1;display:flex;gap:1px;background:var(--bd)">
        <!-- Chart visual -->
        <div style="flex:1.4;background:var(--bg);padding:28px 32px;display:flex;flex-direction:column;">
          <p class="lbl mono" style="color:var(--z6);margin-bottom:20px">WORKFORCE COMPOSITION OVER TIME</p>
          <div style="flex:1;position:relative;">
            <svg viewBox="0 0 400 200" preserveAspectRatio="none" style="width:100%;height:100%;">
              <!-- Grid lines -->
              <line x1="0" y1="50"  x2="400" y2="50"  stroke="#27272a" stroke-width="1"/>
              <line x1="0" y1="100" x2="400" y2="100" stroke="#27272a" stroke-width="1"/>
              <line x1="0" y1="150" x2="400" y2="150" stroke="#27272a" stroke-width="1"/>
              <!-- Human workforce — flat -->
              <polyline points="0,120 80,118 160,117 240,118 320,120 400,122"
                fill="none" stroke="#52525b" stroke-width="2" stroke-dasharray="6,4"/>
              <!-- AI agents — exponential -->
              <polyline points="0,185 60,180 120,168 180,148 240,118 300,78 360,32 400,8"
                fill="none" stroke="#fbbf24" stroke-width="2.5"/>
              <!-- Labels -->
              <text x="410" y="125" fill="#52525b" font-family="monospace" font-size="9" dominant-baseline="middle">HUMANS</text>
              <text x="410" y="12"  fill="#fbbf24" font-family="monospace" font-size="9" dominant-baseline="middle">AI AGENTS</text>
            </svg>
          </div>
          <div style="display:flex;gap:24px;margin-top:12px">
            <div style="display:flex;align-items:center;gap:8px">
              <div style="width:20px;height:2px;background:#52525b;border-top:2px dashed #52525b;"></div>
              <span class="mono" style="font-size:10px;color:var(--z6)">Human Workforce</span>
            </div>
            <div style="display:flex;align-items:center;gap:8px">
              <div style="width:20px;height:2px;background:var(--am);"></div>
              <span class="mono" style="font-size:10px;color:var(--am)">Autonomous Agents</span>
            </div>
          </div>
        </div>
        <!-- Text -->
        <div style="flex:1;background:var(--bg);padding:32px 36px;display:flex;flex-direction:column;gap:24px;">
          <div>
            <p class="mono am" style="font-size:10px;letter-spacing:.2em;margin-bottom:10px">THE SHIFT</p>
            <p class="t-b">Agents don't need UIs, they don't wait for human permission, and they execute at machine speed.</p>
          </div>
          <div style="height:1px;background:var(--bd);"></div>
          <div>
            <p class="mono" style="font-size:10px;letter-spacing:.2em;color:var(--z5);margin-bottom:10px">NVIDIA CEO</p>
            <p class="t-b" style="font-style:italic;color:var(--z3)">"IT is becoming the HR department for AI."</p>
          </div>
          <div style="height:1px;background:var(--bd);"></div>
          <div>
            <p class="mono" style="font-size:10px;letter-spacing:.2em;color:var(--z5);margin-bottom:10px">THE GAP</p>
            <p class="t-b">The enterprise lacks the operational <strong class="wh">System of Record</strong> to govern a workforce that operates entirely via APIs.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- 03 THE ENTERPRISE LIABILITY GAP -->
    <section class="slide">
      <span class="sn">03 / 12</span>
      <div class="lrow"><span class="lbl">↳ THE ENTERPRISE LIABILITY GAP · 02 / 10</span></div>

      <h2 class="t-h1" style="margin-bottom:8px;max-width:860px">Moving to multi-tenant production<br>breaks legacy IAM.</h2>
      <p class="t-b dim" style="margin-bottom:24px;flex-shrink:0;max-width:820px">When agents autonomously trigger sub-agents (Delegation Chains), compliance collapses. Enterprises cannot answer four critical questions:</p>

      <div style="flex:1;display:flex;flex-direction:column;gap:1px;background:var(--bd)">
        <div class="qrow">
          <div>
            <p class="mono am" style="font-size:11px;letter-spacing:.14em;margin-bottom:4px">IDENTITY</p>
            <p class="mono" style="font-size:10px;letter-spacing:.1em;color:var(--z6)">Who?</p>
          </div>
          <p class="t-b">Shared service accounts. No traceable roles or accountability.</p>
        </div>
        <div class="qrow">
          <div>
            <p class="mono" style="font-size:11px;letter-spacing:.14em;color:var(--z4);margin-bottom:4px">CAUSAL CONTEXT</p>
            <p class="mono" style="font-size:10px;letter-spacing:.1em;color:var(--z6)">Why?</p>
          </div>
          <p class="t-b">AI operates as a black box. No record of the reasoning or source documents relied upon.</p>
        </div>
        <div class="qrow">
          <div>
            <p class="mono" style="font-size:11px;letter-spacing:.14em;color:var(--z4);margin-bottom:4px">SCOPE &amp; BUDGET</p>
            <p class="mono" style="font-size:10px;letter-spacing:.1em;color:var(--z6)">Limits?</p>
          </div>
          <p class="t-b">Unrestricted access leads to massive token cost explosions and state collisions between agents.</p>
        </div>
        <div class="qrow" style="border-left:2px solid rgba(251,191,36,.2)">
          <div>
            <p class="mono" style="font-size:11px;letter-spacing:.14em;color:var(--z5);margin-bottom:4px">TAMPER-EVIDENCE</p>
            <p class="mono" style="font-size:10px;letter-spacing:.1em;color:var(--z6)">Proof?</p>
          </div>
          <p class="t-b">Self-reported, easily editable vendor logs that <strong class="wh">fail in court.</strong></p>
        </div>
      </div>
    </section>

    <!-- 04 THE SOLUTION -->
    <section class="slide">
      <span class="sn">04 / 12</span>
      <div class="lrow"><span class="lbl">↳ THE SOLUTION · 03 / 10</span></div>

      <h2 class="t-h1" style="margin-bottom:8px">Agent-Native Governance.</h2>
      <p class="t-b dim" style="margin-bottom:28px;flex-shrink:0;max-width:820px">Developers build the Agent Core. KYDE provides the Multi-Tenant Harness. We do not build agents — we authorize them and hold them legally accountable.</p>

      <div style="flex:1;display:flex;gap:1px;background:var(--bd)">
        <div style="flex:1;background:var(--bg);padding:32px 36px;display:flex;flex-direction:column;justify-content:center">
          <p class="mono" style="font-size:10px;letter-spacing:.2em;color:var(--z6);margin-bottom:20px">ARCHITECTURE</p>
          <div style="display:flex;flex-direction:column;gap:1px;margin-bottom:24px">
            <div style="background:var(--bg1);border:1px solid var(--bd);padding:16px 20px;">
              <p class="mono" style="font-size:11px;letter-spacing:.12em;color:var(--z5)">YOUR AGENT FLEET</p>
              <p class="t-sm" style="margin-top:4px">Custom enterprise agents, MCP clients, external integrations</p>
            </div>
            <div style="display:flex;align-items:center;justify-content:center;height:28px;">
              <div style="width:1px;height:28px;background:var(--am);opacity:.5;"></div>
            </div>
            <div style="background:var(--bg1);border:1px solid rgba(251,191,36,.3);border-left:2px solid var(--am);padding:16px 20px;">
              <p class="mono am" style="font-size:11px;letter-spacing:.12em;">KYDE WITNESS — INVISIBLE PROXY</p>
              <p class="t-sm" style="margin-top:4px">Identity · Budget · Signing · Enforcement · Ledger</p>
            </div>
            <div style="display:flex;align-items:center;justify-content:center;height:28px;">
              <div style="width:1px;height:28px;background:var(--bd2);opacity:.5;"></div>
            </div>
            <div style="background:var(--bg1);border:1px solid var(--bd);padding:16px 20px;">
              <p class="mono" style="font-size:11px;letter-spacing:.12em;color:var(--z5)">ANY LLM PROVIDER</p>
              <p class="t-sm" style="margin-top:4px">OpenAI · Anthropic · Gemini · Mistral · self-hosted</p>
            </div>
          </div>
        </div>
        <div style="flex:1;background:var(--bg);padding:32px 36px;display:flex;flex-direction:column;gap:20px">
          <p class="mono" style="font-size:10px;letter-spacing:.2em;color:var(--z6)">KYDE SITS AS NETWORK PROXY — ENFORCING HARD BOUNDARIES ON EVERY MACHINE DECISION</p>
          <div style="height:1px;background:var(--bd);"></div>
          <div>
            <p class="mono am" style="font-size:10px;letter-spacing:.2em;margin-bottom:8px">↳ PROVIDER-AGNOSTIC</p>
            <p class="t-b">Switching LLM provider is a config change. Governance stays intact.</p>
          </div>
          <div>
            <p class="mono" style="font-size:10px;letter-spacing:.2em;color:var(--z4);margin-bottom:8px">↳ ZERO VENDOR LOCK-IN</p>
            <p class="t-b">Your governance layer does not depend on your LLM choice.</p>
          </div>
          <div>
            <p class="mono" style="font-size:10px;letter-spacing:.2em;color:var(--z4);margin-bottom:8px">↳ ZERO DEVELOPER FRICTION</p>
            <p class="t-b">One environment variable. No SDK integration. No code refactoring.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- 05 THE CORE ENGINE -->
    <section class="slide">
      <span class="sn">05 / 12</span>
      <div class="lrow"><span class="lbl">↳ THE CORE ENGINE · 04 / 10</span></div>

      <h2 class="t-h1" style="margin-bottom:8px">Liability Firebreaks &amp;<br>Transitive Accountability.</h2>
      <p class="t-b dim" style="margin-bottom:24px;flex-shrink:0">Every machine decision — signed, chained, and policy-enforced in under 100ms.</p>

      <div style="flex:1;display:flex;gap:1px;background:var(--bd)">
        <!-- Code block -->
        <div style="flex:1.2;background:#0d0d0f;padding:28px 32px;display:flex;flex-direction:column;font-family:ui-monospace,monospace;">
          <p style="font-size:10px;letter-spacing:.15em;color:var(--z6);margin-bottom:16px">audit_entry.json</p>
          <pre style="font-size:14px;line-height:1.8;color:var(--z4);flex:1;white-space:pre-wrap;">&#123;
  <span style="color:#fbbf24">"agent_id"</span>: <span style="color:#a3e635">"billing-agent-7f3a"</span>,
  <span style="color:#fbbf24">"role"</span>:     <span style="color:#a3e635">"finance::readonly"</span>,
  <span style="color:#fbbf24">"action"</span>:  <span style="color:#a3e635">"tool_call::get_invoice"</span>,
  <span style="color:#fbbf24">"budget"</span>: &#123;
    <span style="color:#60a5fa">"limit_tokens"</span>: <span style="color:#fb923c">50000</span>,
    <span style="color:#60a5fa">"used_tokens"</span>:  <span style="color:#fb923c">12847</span>
  &#125;,
  <span style="color:#fbbf24">"signature"</span>: <span style="color:#a3e635">"ed25519::a9f2..."</span>,
  <span style="color:#fbbf24">"prev_hash"</span>: <span style="color:#a3e635">"sha256::3c8b..."</span>,
  <span style="color:#fbbf24">"timestamp"</span>: <span style="color:#a3e635">"2026-03-27T09:14:02Z"</span>
&#125;</pre>
        </div>
        <!-- Three pillars -->
        <div style="flex:1;background:var(--bg);display:flex;flex-direction:column;gap:1px;background:var(--bd)">
          <div style="background:var(--bg);padding:28px 30px;flex:1;display:flex;flex-direction:column;justify-content:center">
            <p class="mono am" style="font-size:10px;letter-spacing:.2em;margin-bottom:12px">↳ CRYPTOGRAPHIC IDENTITY</p>
            <p class="t-b" style="font-size:18px">Every agent receives a distinct, verifiable identity with strict role boundaries.</p>
          </div>
          <div style="background:var(--bg);padding:28px 30px;flex:1;display:flex;flex-direction:column;justify-content:center">
            <p class="mono" style="font-size:10px;letter-spacing:.2em;color:var(--z4);margin-bottom:12px">↳ LIABILITY FIREBREAKS</p>
            <p class="t-b" style="font-size:18px">Real-time (&lt;100ms) policy enforcement. Unauthorized or out-of-budget actions are hard-dropped before they impact external systems.</p>
          </div>
          <div style="background:var(--bg);padding:28px 30px;flex:1;display:flex;flex-direction:column;justify-content:center">
            <p class="mono" style="font-size:10px;letter-spacing:.2em;color:var(--z5);margin-bottom:12px">↳ TAMPER-EVIDENT LEDGER</p>
            <p class="t-b" style="font-size:18px;">Ed25519-signed + SHA-256 hash-chained. A <strong class="wh">mathematically proven chain of evidence</strong> for regulatory and judicial scrutiny.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- 06 THE WEDGE -->
    <section class="slide has-grid">
      <span class="sn">06 / 12</span>
      <div class="lrow"><span class="lbl">↳ THE WEDGE · GO-TO-MARKET · 05 / 10</span></div>

      <h2 class="t-h1" style="margin-bottom:8px">The Zero-Friction Proxy.</h2>
      <p class="t-b dim" style="margin-bottom:32px;flex-shrink:0">Governance without developer pushback.</p>

      <div style="flex:1;display:flex;flex-direction:column;gap:20px">
        <!-- Terminal -->
        <div style="background:#0d0d0f;border:1px solid var(--bd);padding:32px 40px;flex-shrink:0">
          <p class="mono" style="font-size:10px;letter-spacing:.15em;color:var(--z6);margin-bottom:16px">DEPLOY KYDE IN 30 SECONDS</p>
          <p class="mono wh" style="font-size:clamp(16px,2vw,26px);letter-spacing:.04em;line-height:1.8">$ export OPENAI_BASE_URL=https://witness.intranet/v1</p>
          <p class="mono" style="font-size:14px;color:var(--z6);margin-top:12px"># No SDK integration. No code refactoring. Agent sees no difference.</p>
        </div>

        <div class="g3" style="flex:1">
