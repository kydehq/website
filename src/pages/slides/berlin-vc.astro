  <script>
    if (localStorage.getItem('kyde_slides_auth') !== 'kyde_2026') {
      window.location.replace('/slides/');
    }

    const sl   = document.getElementById('sl') as HTMLElement;
    const dots = document.querySelectorAll('.nd');
    const cn   = document.getElementById('cn') as HTMLElement;
    const N    = 12;

    function gts(i: number) {
      sl.scrollTo({ top: i * window.innerHeight, behavior: 'smooth' });
    }

    function upd() {
      const i = Math.round(sl.scrollTop / window.innerHeight);
      dots.forEach((d, j) => d.classList.toggle('on', j === i));
      cn.textContent = String(i + 1).padStart(2, '0');
    }

    sl.addEventListener('scroll', upd, { passive: true });

    document.addEventListener('keydown', (e: KeyboardEvent) => {
      const i = Math.round(sl.scrollTop / window.innerHeight);
      if ((e.key === 'ArrowDown' || e.key === 'ArrowRight' || e.key === ' ') && i < N - 1) {
        e.preventDefault(); gts(i + 1);
      }
      if ((e.key === 'ArrowUp' || e.key === 'ArrowLeft') && i > 0) {
        e.preventDefault(); gts(i - 1);
      }
    });

    // expose for nav dots
    (window as any).gts = gts;
  </script>

