---
import SlideBase from "../../layouts/SlideBase.astro";
---

<SlideBase title="KYDE — Seed Round 2026">
  <style slot="head">
    :root {
      --bg:  #09090b;
      --bg1: #18181b;
      --bd:  #27272a;
      --bd2: #3f3f46;
      --z3:  #e4e4e7;
      --z4:  #d4d4d8;
      --z5:  #a1a1aa;
      --z6:  #71717a;
      --am:  #fbbf24;
      --wh:  #f4f4f5;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { background: var(--bg); }
    body {
      background: var(--bg);
      color: var(--wh);
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      -webkit-font-smoothing: antialiased;
      overflow: hidden;
    }

    .slides {
      height: 100vh;
      overflow-y: scroll;
      scroll-snap-type: y mandatory;
      scrollbar-width: none;
      -ms-overflow-style: none;
    }
    .slides::-webkit-scrollbar { display: none; }

    .slide {
      height: 100vh;
      scroll-snap-align: start;
      scroll-snap-stop: always;
      position: relative;
      display: flex;
      flex-direction: column;
      padding: 48px 80px;
      overflow: hidden;
      border-bottom: 1px solid var(--bd);
    }

    .has-grid::before {
      content: '';
      position: absolute;
      inset: 0;
      background-image:
        linear-gradient(rgba(255,255,255,0.016) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.016) 1px, transparent 1px);
      background-size: 48px 48px;
      pointer-events: none;
    }

    /* Nav dots */
    .nav-dots {
      position: fixed; right: 18px; top: 50%;
      transform: translateY(-50%);
      display: flex; flex-direction: column; gap: 6px;
      z-index: 200;
    }
    .nd {
      width: 3px; height: 3px; border-radius: 50%;
      background: var(--bd2); cursor: pointer;
      transition: height .25s, border-radius .25s, background .25s;
    }
    .nd.on { height: 16px; border-radius: 2px; background: var(--am); }

    .counter {
      position: fixed; bottom: 22px; right: 36px;
      font-family: ui-monospace, monospace;
      font-size: 10px; letter-spacing: 0.22em; color: var(--bd2); z-index: 200;
    }

    .sn {
      position: absolute; top: 48px; right: 80px;
      font-family: ui-monospace, monospace;
      font-size: 10px; letter-spacing: 0.2em; color: var(--bd2);
    }

    /* Label row */
    .lrow { display: flex; align-items: center; gap: 10px; margin-bottom: 32px; flex-shrink: 0; }
    .lrow::after { content:''; flex:1; height:1px; background:var(--bd); }
    .lbl { font-family: ui-monospace, monospace; font-size: 10px; letter-spacing: 0.25em; text-transform: uppercase; color: var(--z6); }
    .dp  { width:6px; height:6px; border-radius:50%; background:var(--am); opacity:.7; flex-shrink:0; animation:pulse 2s ease-in-out infinite; }
    @keyframes pulse { 0%,100%{opacity:.3} 50%{opacity:.9} }

    /* Typography — bumped up for PPT feel */
    .t-hero { font-family:'Inter',sans-serif; font-size:clamp(56px,8.5vw,112px); font-weight:600; letter-spacing:-.03em; line-height:1.06; text-transform:uppercase; }
    .t-h1   { font-family:'Inter',sans-serif; font-size:clamp(34px,4.2vw,62px);  font-weight:600; letter-spacing:-.03em; line-height:1.05; }
    .t-h2   { font-family:'Inter',sans-serif; font-size:clamp(22px,2.6vw,38px);  font-weight:500; letter-spacing:-.02em; line-height:1.1; }
    .t-b    { font-size: 20px; line-height: 1.6; color: var(--z4); }
    .t-sm   { font-size: 17px; line-height: 1.6; color: var(--z5); }
    .mono   { font-family: ui-monospace, monospace; }
    .am     { color: var(--am); }
    .wh     { color: var(--wh); }
    .dim    { color: var(--z5); }

    /* Cards */
    .card   { border:1px solid var(--bd);  background:var(--bg1); padding:24px 28px; }
    .card-l { border:1px solid var(--bd2); background:var(--bg1); padding:24px 28px; border-left:2px solid var(--am); }

    /* Grids */
    .g3 { display:grid; grid-template-columns:1fr 1fr 1fr; gap:1px; background:var(--bd); }
    .g3>* { background:var(--bg); }
    .g2 { display:grid; grid-template-columns:1fr 1fr; gap:1px; background:var(--bd); }
    .g2>* { background:var(--bg); }

    /* Stacked rows */
    .rows { display:flex; flex-direction:column; gap:1px; background:var(--bd); }
    .row  { background:var(--bg); display:grid; grid-template-columns:180px 1fr; gap:24px; padding:24px 28px; align-items:start; flex:1; }

    /* Step rows */
    .step   { display:grid; grid-template-columns:50px 1fr; gap:20px; padding:22px 0; border-bottom:1px solid var(--bd); align-items:start; flex:1; }
    .step:last-child { border-bottom:none; }
    .step-n { font-family:ui-monospace,monospace; font-size:11px; color:var(--am); letter-spacing:.2em; padding-top:4px; }

    /* Moat rows */
    .moat-row { display:grid; grid-template-columns:140px 1fr; gap:24px; padding:18px 0; border-bottom:1px solid var(--bd); align-items:start; flex:1; }
    .moat-row:last-child { border-bottom:none; }

    /* Pilot rows */
    .pilot-row { display:grid; grid-template-columns:200px 1fr; gap:20px; padding:16px 24px; background:var(--bg); align-items:start; }

    /* Market numbers */
    .mnum { font-size:clamp(40px,5vw,72px); font-weight:600; letter-spacing:-.03em; color:var(--wh); line-height:1; margin-bottom:10px; }

    /* Silicon Leash badge */
    .sl-badge {
      display:inline-flex; align-items:center; gap:8px;
      border:1px solid rgba(251,191,36,.25); background:rgba(251,191,36,.04);
      padding:6px 14px; flex-shrink:0;
    }
    .sl-badge span { font-family:ui-monospace,monospace; font-size:10px; letter-spacing:.2em; color:var(--am); }

    /* Question rows */
    .qrow { display:grid; grid-template-columns:180px 1fr; gap:24px; padding:20px 28px; background:var(--bg); align-items:start; border-bottom:1px solid var(--bd); }
    .qrow:last-child { border-bottom:none; }
  </style>

  <!-- Nav dots (12) -->
  <div class="nav-dots">
    <div class="nd on" onclick="gts(0)"></div>
    <div class="nd" onclick="gts(1)"></div>
    <div class="nd" onclick="gts(2)"></div>
    <div class="nd" onclick="gts(3)"></div>
    <div class="nd" onclick="gts(4)"></div>
    <div class="nd" onclick="gts(5)"></div>
    <div class="nd" onclick="gts(6)"></div>
    <div class="nd" onclick="gts(7)"></div>
    <div class="nd" onclick="gts(8)"></div>
    <div class="nd" onclick="gts(9)"></div>
    <div class="nd" onclick="gts(10)"></div>
    <div class="nd" onclick="gts(11)"></div>
  </div>

  <div class="counter"><span id="cn">01</span> / 12</div>

  <div class="slides" id="sl">

    <!-- 01 COVER -->
    <section class="slide has-grid">
      <span class="sn">01 / 12</span>
      <div class="lrow"><span class="dp"></span><span class="lbl">KYDE · SEED ROUND 2026</span></div>

      <div style="flex:1;display:flex;flex-direction:column;justify-content:center">
        <p class="mono am" style="font-size:11px;letter-spacing:.3em;margin-bottom:24px">KYDE</p>
        <h1 class="t-hero" style="margin-bottom:28px">
          Who Did That?
        </h1>
        <p class="t-h2" style="color:var(--z4);max-width:780px">
          The Trust & Control Layer<br>for the Agentic Economy.
        </p>
      </div>

      <div style="display:flex;align-items:center;justify-content:space-between;padding-top:20px;border-top:1px solid var(--bd)">
        <div style="display:flex;gap:48px">
          <div>
            <p class="lbl" style="margin-bottom:6px">STATUS</p>
            <p class="mono am" style="font-size:13px;letter-spacing:.1em">SEED ROUND OPEN</p>
          </div>
          <div>
            <p class="lbl" style="margin-bottom:6px">TARGET</p>
            <p class="mono wh" style="font-size:13px;letter-spacing:.1em">€1.6M</p>
          </div>
        </div>
        <div style="display:flex;align-items:center;gap:16px">
          <p class="mono" style="font-size:12px;letter-spacing:.12em;color:var(--z5)">KYDE.COM</p>
          <p class="lbl" style="color:var(--bd2)">CONFIDENTIAL</p>
        </div>
      </div>
    </section>

    <!-- 02 THE PROBLEM -->
    <section class="slide">
      <span class="sn">02 / 12</span>
      <div class="lrow"><span class="lbl">↳ THE PROBLEM · 01 / 10</span></div>

      <h2 class="t-h1" style="margin-bottom:8px;max-width:840px">IT is becoming the HR department<br>for AI agents.</h2>
      <p class="t-b dim" style="margin-bottom:28px;flex-shrink:0;max-width:760px">Enterprises deploy autonomous agents that negotiate contracts, move money, and orchestrate production systems. Unlike software, agents act. Unlike employees, nobody manages them.</p>

      <div style="flex:1;display:flex;flex-direction:column;gap:1px;background:var(--bd)">
        <div class="qrow">
          <p class="mono am" style="font-size:11px;letter-spacing:.14em;padding-top:3px">WHO ACTED?</p>
          <p class="t-b">Agents share service accounts. No traceable identity.</p>
        </div>
        <div class="qrow">
          <p class="mono" style="font-size:11px;letter-spacing:.14em;color:var(--z4);padding-top:3px">WHY THAT DECISION?</p>
          <p class="t-b">Nobody logged which source it relied on.</p>
        </div>
        <div class="qrow">
          <p class="mono" style="font-size:11px;letter-spacing:.14em;color:var(--z4);padding-top:3px">WHAT WERE THE LIMITS?</p>
          <p class="t-b">Token budgets don't exist. API access is unrestricted.</p>
        </div>
        <div class="qrow" style="border-left:2px solid rgba(251,191,36,.2)">
          <p class="mono" style="font-size:11px;letter-spacing:.14em;color:var(--z5);padding-top:3px">WHAT HAPPENED?</p>
          <p class="t-b">Logs are vendor-provided, self-reported, rewritable.</p>
        </div>
      </div>

      <div style="padding-top:16px;flex-shrink:0">
        <p class="t-sm" style="color:var(--z6)">Without answers, a minor hallucination cascades into a legal and financial disaster.</p>
      </div>
    </section>

    <!-- 03 THE SOLUTION -->
    <section class="slide">
      <span class="sn">03 / 12</span>
      <div class="lrow"><span class="lbl">↳ THE SOLUTION · 02 / 10</span></div>

      <h2 class="t-h1" style="margin-bottom:8px">The first Agent-Native Governance<br>and Liability Infrastructure.</h2>
      <p class="t-b dim" style="margin-bottom:28px;flex-shrink:0">We do not build agents. We authorize them and hold them accountable.</p>

      <div style="flex:1;background:var(--bg1);border:1px solid var(--bd);padding:32px 36px;display:flex;flex-direction:column;justify-content:center;margin-bottom:20px">
        <p class="mono" style="font-size:11px;letter-spacing:.2em;color:var(--z6);margin-bottom:16px">ONE ENVIRONMENT VARIABLE. NO CODE CHANGES.</p>
        <p class="mono wh" style="font-size:clamp(16px,2vw,26px);letter-spacing:.04em;line-height:1.8">export OPENAI_BASE_URL=https://witness.intranet/v1</p>
        <p class="t-sm" style="margin-top:16px;color:var(--z6)">Every agent covered. Every provider. From day one.</p>
      </div>

      <div class="g3" style="flex:1">
        <div style="padding:28px 30px;display:flex;flex-direction:column">
          <p class="lbl mono am" style="margin-bottom:14px">↳ IDENTITY & SCOPE</p>
          <p class="t-b" style="font-size:18px;margin-bottom:10px;flex:1">Every agent gets a distinct identity, role, and hard budget. Shared service accounts replaced with accountable principals.</p>
        </div>
        <div style="padding:28px 30px;display:flex;flex-direction:column">
          <p class="lbl mono" style="color:var(--z4);margin-bottom:14px">↳ CAUSAL CONTEXT</p>
          <p class="t-b" style="font-size:18px;margin-bottom:10px;flex:1">Every tool call logged with the last 5 messages. Full decision chain reconstructable. Not just what happened — why.</p>
        </div>
        <div style="padding:28px 30px;display:flex;flex-direction:column">
          <p class="lbl mono" style="color:var(--z5);margin-bottom:14px">↳ TAMPER-EVIDENT LEDGER</p>
          <p class="t-b" style="font-size:18px;flex:1">Ed25519-signed, SHA-256 hash-chained. Alter any entry and every subsequent link breaks. Chain of evidence, not a log.</p>
        </div>
      </div>
    </section>

    <!-- 04 THE PRODUCT -->
    <section class="slide">
      <span class="sn">04 / 12</span>
      <div class="lrow"><span class="lbl">↳ THE PRODUCT · 03 / 10</span></div>

      <h2 class="t-h1" style="margin-bottom:8px">Kyde sits between your agent fleet<br>and any LLM provider.</h2>
      <p class="t-b dim" style="margin-bottom:24px;flex-shrink:0">Six capabilities. One proxy. Under 100ms latency.</p>

      <div style="flex:1;display:flex;flex-direction:column;gap:1px;background:var(--bd)">
        <div class="row">
          <p class="mono am" style="font-size:11px;letter-spacing:.14em;padding-top:3px">IDENTITY & SCOPE</p>
          <p class="t-b" style="font-size:18px">Every agent gets a distinct identity, role, and hard budget. Shared service accounts replaced with accountable principals.</p>
        </div>
        <div class="row">
          <p class="mono" style="font-size:11px;letter-spacing:.14em;color:var(--z4);padding-top:3px">LIABILITY FIREBREAKS</p>
          <p class="t-b" style="font-size:18px">Unauthorized or out-of-budget actions dropped in real-time, before they reach external systems.</p>
        </div>
        <div class="row">
          <p class="mono" style="font-size:11px;letter-spacing:.14em;color:var(--z4);padding-top:3px">CAUSAL CONTEXT</p>
          <p class="t-b" style="font-size:18px">Every tool call logged with the last 5 messages. Not just what happened — why.</p>
        </div>
        <div class="row">
          <p class="mono" style="font-size:11px;letter-spacing:.14em;color:var(--z4);padding-top:3px">TAMPER-EVIDENT LEDGER</p>
          <p class="t-b" style="font-size:18px">Ed25519-signed, SHA-256 hash-chained. Alter any entry — every subsequent link breaks.</p>
        </div>
        <div class="row">
          <p class="mono" style="font-size:11px;letter-spacing:.14em;color:var(--z5);padding-top:3px">FLEET MANAGEMENT</p>
          <p class="t-b" style="font-size:18px">Role-based priorities, per-agent budgets, API allowlists. Production agents take precedence over intern bots.</p>
        </div>
        <div class="row" style="border-left:2px solid rgba(251,191,36,.15)">
          <p class="mono" style="font-size:11px;letter-spacing:.14em;color:var(--z5);padding-top:3px">ZERO-FRICTION DEPLOY</p>
          <p class="t-b" style="font-size:18px">One environment variable or Group Policy push. Agent sees no difference.</p>
        </div>
      </div>
    </section>

    <!-- 05 TRACTION -->
    <section class="slide">
      <span class="sn">05 / 12</span>
      <div class="lrow"><span class="lbl">↳ TRACTION · 04 / 10</span></div>

      <h2 class="t-h1" style="margin-bottom:8px">Deployed where governance<br>matters most.</h2>
      <p class="t-b dim" style="margin-bottom:28px;flex-shrink:0">Early partners in regulated environments.</p>

      <div style="display:flex;flex-direction:column;gap:1px;background:var(--bd);flex-shrink:0;margin-bottom:24px">
        <div class="pilot-row">
          <div>
            <p class="mono am" style="font-size:12px;letter-spacing:.1em;margin-bottom:4px">European Commission</p>
            <p class="mono" style="font-size:10px;color:var(--z6);letter-spacing:.08em">DIGIT B.1</p>
          </div>
          <p class="t-sm">AI governance mandate for the EU. Operating GPT@EC — the Commission's internal AI deployment. Direct regulatory pressure, immediate need.</p>
        </div>
        <div class="pilot-row">
          <div>
            <p class="mono" style="font-size:12px;letter-spacing:.1em;color:var(--z4);margin-bottom:4px">Allianz Life</p>
            <p class="mono" style="font-size:10px;color:var(--z6);letter-spacing:.08em">HIGH-RISK INSURANCE · BAFIN</p>
          </div>
          <p class="t-sm">High-risk insurance under BaFin. EU AI Act Article 12/13 requirements in automated decision-making systems.</p>
        </div>
        <div class="pilot-row">
          <div>
            <p class="mono" style="font-size:12px;letter-spacing:.1em;color:var(--z4);margin-bottom:4px">Bitpanda</p>
            <p class="mono" style="font-size:10px;color:var(--z6);letter-spacing:.08em">DORA / NIS-2 · CRYPTO</p>
          </div>
          <p class="t-sm">DORA/NIS-2 crypto operations. Tamper-evident audit trail for every agent action in production.</p>
        </div>
      </div>

      <div class="g3" style="flex:1">
        <div style="padding:24px 28px;display:flex;flex-direction:column;justify-content:center">
          <p class="mnum">3</p>
          <p class="t-sm">Active design partners</p>
        </div>
        <div style="padding:24px 28px;display:flex;flex-direction:column;justify-content:center">
          <p class="mnum" style="color:var(--z3)">MVP</p>
          <p class="t-sm">Live and intercepting production traffic</p>
        </div>
        <div style="padding:24px 28px;display:flex;flex-direction:column;justify-content:center">
          <p class="mnum" style="font-size:clamp(28px,3.5vw,52px);color:var(--z3)">Aug 2027</p>
          <p class="t-sm">EU AI Act enforcement — our mandate deadline</p>
        </div>
      </div>
    </section>

    <!-- 06 THE MARKET -->
    <section class="slide">
      <span class="sn">06 / 12</span>
      <div class="lrow"><span class="lbl">↳ THE MARKET · 05 / 10</span></div>

      <h2 class="t-h1" style="margin-bottom:8px">Every enterprise deploying<br>AI agents is a prospect.</h2>
      <p class="t-b dim" style="margin-bottom:28px;flex-shrink:0">That is every enterprise. Regulation makes it mandatory.</p>

      <div class="g3" style="flex:1;margin-bottom:20px">
        <div style="padding:32px 30px;display:flex;flex-direction:column">
          <p class="lbl mono am" style="margin-bottom:20px">TOTAL ADDRESSABLE MARKET</p>
          <p class="mnum">€4.3B</p>
          <p class="t-sm" style="flex:1">~50k EU enterprises × avg. 3 AI systems × €29k annual compliance cost (EU Commission Impact Assessment).</p>
        </div>
        <div style="padding:32px 30px;display:flex;flex-direction:column">
          <p class="lbl mono" style="color:var(--z4);margin-bottom:20px">SERVICEABLE ADDRESSABLE MARKET</p>
          <p class="mnum">€820M</p>
          <p class="t-sm" style="flex:1">Financial services, healthcare, critical infrastructure — ~20% of TAM. High-risk by law, immediately actionable.</p>
        </div>
        <div style="padding:32px 30px;display:flex;flex-direction:column">
          <p class="lbl mono" style="color:var(--z5);margin-bottom:20px">18-MONTH TARGET</p>
          <p class="mnum" style="font-size:clamp(28px,3.5vw,50px);color:var(--z3)">DACH + EU</p>
          <p class="t-sm" style="flex:1">Regulated enterprises in Western Europe. DORA in force. EU AI Act enforcement clock running.</p>
        </div>
      </div>

      <div style="background:var(--bg1);border:1px solid var(--bd);padding:18px 28px;display:flex;gap:48px;flex-shrink:0">
        <div>
          <p class="lbl mono am" style="margin-bottom:6px">DORA IN FORCE</p>
          <p class="mono wh" style="font-size:14px;letter-spacing:.05em">January 2025</p>
        </div>
        <div>
          <p class="lbl mono" style="color:var(--z5);margin-bottom:6px">NIS-2 TRANSPOSED</p>
          <p class="mono" style="font-size:14px;color:var(--z4);letter-spacing:.04em">October 2024</p>
        </div>
        <div>
          <p class="lbl mono am" style="margin-bottom:6px">EU AI ACT ENFORCEMENT</p>
          <p class="mono wh" style="font-size:14px;letter-spacing:.05em">August 2, 2027</p>
        </div>
        <div style="flex:1;text-align:right;display:flex;align-items:center;justify-content:flex-end">
          <p class="t-sm" style="color:var(--z6)">Kyde is not a nice-to-have. For regulated enterprises, it is the legal prerequisite for agents in production.</p>
        </div>
      </div>
    </section>

    <!-- 07 BUSINESS MODEL -->
    <section class="slide">
      <span class="sn">07 / 12</span>
      <div class="lrow"><span class="lbl">↳ BUSINESS MODEL · 06 / 10</span></div>

      <h2 class="t-h1" style="margin-bottom:8px">SaaS. Usage-based. Enterprise contracts.</h2>
      <p class="t-b dim" style="margin-bottom:24px;flex-shrink:0">Land with developers. Expand to compliance. Lock in with the ledger.</p>

      <div class="g3" style="flex:1;margin-bottom:20px">
        <div style="padding:32px 30px;display:flex;flex-direction:column">
          <p class="lbl mono" style="color:var(--z5);margin-bottom:12px">FREE / OPEN SOURCE</p>
          <p class="t-b" style="font-size:18px;margin-bottom:12px;flex:1">Core proxy, basic signing, community tier.</p>
          <p class="t-sm">Developer adoption. Bottom-up distribution. Every installation is a future enterprise account.</p>
        </div>
        <div style="padding:32px 30px;display:flex;flex-direction:column;border-left:2px solid rgba(251,191,36,.15)">
          <p class="lbl mono am" style="margin-bottom:12px">PRO</p>
          <p class="t-b" style="font-size:18px;margin-bottom:12px;flex:1">Fleet management, causal context, audit dashboard.</p>
          <p class="t-sm">Per-agent per-month pricing. Scales with fleet size.</p>
        </div>
        <div style="padding:32px 30px;display:flex;flex-direction:column">
          <p class="lbl mono" style="color:var(--z4);margin-bottom:12px">ENTERPRISE</p>
          <p class="t-b" style="font-size:18px;margin-bottom:12px;flex:1">Tamper-evident ledger, compliance exports, SLA, HSM integration.</p>
          <p class="t-sm">Annual contract. The ledger creates the lock-in.</p>
        </div>
      </div>

      <div class="card-l" style="flex-shrink:0;max-width:780px">
        <p class="t-b" style="font-size:20px;color:var(--z3);line-height:1.5">
          Switching cost: once an enterprise anchors its audit and legal defense history on Kyde's ledger, migration is structurally impossible.
        </p>
      </div>
    </section>

    <!-- 08 COMPETITION -->
    <section class="slide">
      <span class="sn">08 / 12</span>
      <div class="lrow"><span class="lbl">↳ COMPETITION · 07 / 10</span></div>

      <h2 class="t-h1" style="margin-bottom:8px">Nobody is building this exact layer.</h2>
