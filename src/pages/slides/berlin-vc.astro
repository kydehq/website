---
import SlideBase from "../../layouts/SlideBase.astro";
---

<SlideBase title="KYDE — Seed Round 2026">
  <style slot="head">
    :root {
      --bg:     #09090b;
      --bg1:    #18181b;
      --bd:     #27272a;
      --bd2:    #3f3f46;
      --z3:     #e4e4e7;
      --z4:     #d4d4d8;
      --z5:     #a1a1aa;
      --z6:     #71717a;
      --am:     #fbbf24;
      --wh:     #f4f4f5;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { background: var(--bg); }
    body {
      background: var(--bg);
      color: var(--wh);
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      -webkit-font-smoothing: antialiased;
      overflow: hidden;
    }

    .slides {
      height: 100vh;
      overflow-y: scroll;
      scroll-snap-type: y mandatory;
      scrollbar-width: none;
      -ms-overflow-style: none;
    }
    .slides::-webkit-scrollbar { display: none; }

    .slide {
      height: 100vh;
      scroll-snap-align: start;
      scroll-snap-stop: always;
      position: relative;
      display: flex;
      flex-direction: column;
      padding: 48px 80px;
      overflow: hidden;
      border-bottom: 1px solid var(--bd);
    }

    .has-grid::before {
      content: '';
      position: absolute;
      inset: 0;
      background-image:
        linear-gradient(rgba(255,255,255,0.016) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.016) 1px, transparent 1px);
      background-size: 48px 48px;
      pointer-events: none;
    }

    /* Nav dots */
    .nav-dots {
      position: fixed; right: 18px; top: 50%;
      transform: translateY(-50%);
      display: flex; flex-direction: column; gap: 6px;
      z-index: 200;
    }
    .nd {
      width: 3px; height: 3px; border-radius: 50%;
      background: var(--bd2); cursor: pointer;
      transition: height .25s, border-radius .25s, background .25s;
    }
    .nd.on { height: 16px; border-radius: 2px; background: var(--am); }

    .counter {
      position: fixed; bottom: 22px; right: 36px;
      font-family: ui-monospace, monospace;
      font-size: 10px; letter-spacing: 0.22em; color: var(--bd2); z-index: 200;
    }

    .sn {
      position: absolute; top: 48px; right: 80px;
      font-family: ui-monospace, monospace;
      font-size: 10px; letter-spacing: 0.2em; color: var(--bd2);
    }

    /* Label row */
    .lrow { display: flex; align-items: center; gap: 10px; margin-bottom: 32px; flex-shrink: 0; }
    .lrow::after { content:''; flex:1; height:1px; background:var(--bd); }
    .lbl { font-family: ui-monospace, monospace; font-size: 10px; letter-spacing: 0.25em; text-transform: uppercase; color: var(--z6); }
    .dp { width:6px; height:6px; border-radius:50%; background:var(--am); opacity:.7; flex-shrink:0; animation:pulse 2s ease-in-out infinite; }
    @keyframes pulse { 0%,100%{opacity:.3} 50%{opacity:.9} }

    /* Typography */
    .t-hero { font-family:'Inter',sans-serif; font-size:clamp(52px,8vw,104px); font-weight:600; letter-spacing:-.03em; line-height:1.08; text-transform:uppercase; }
    .t-h1   { font-family:'Inter',sans-serif; font-size:clamp(28px,3.6vw,52px); font-weight:600; letter-spacing:-.03em; line-height:1.05; }
    .t-h2   { font-family:'Inter',sans-serif; font-size:clamp(18px,2.2vw,30px); font-weight:500; letter-spacing:-.02em; line-height:1.1; }
    .t-b    { font-size:17px; line-height:1.65; color:var(--z4); }
    .t-sm   { font-size:15px; line-height:1.6; color:var(--z5); }
    .mono   { font-family: ui-monospace, monospace; }
    .am     { color: var(--am); }
    .wh     { color: var(--wh); }
    .dim    { color: var(--z5); }

    /* Cards */
    .card   { border:1px solid var(--bd);  background:var(--bg1); padding:20px 24px; }
    .card-l { border:1px solid var(--bd2); background:var(--bg1); padding:20px 24px; border-left:2px solid var(--am); }

    /* Grids */
    .g3 { display:grid; grid-template-columns:1fr 1fr 1fr; gap:1px; background:var(--bd); }
    .g3>* { background:var(--bg); }
    .g2 { display:grid; grid-template-columns:1fr 1fr; gap:40px; }

    /* Stacked rows */
    .rows { display:flex; flex-direction:column; gap:1px; background:var(--bd); }
    .row  { background:var(--bg); display:grid; grid-template-columns:160px 1fr; gap:24px; padding:20px 24px; align-items:start; flex:1; }

    /* Architecture chain */
    .chain { display:flex; flex-direction:column; }
    .cn    { display:flex; align-items:center; justify-content:space-between; border:1px solid var(--bd2); background:var(--bg1); padding:12px 18px; font-family:ui-monospace,monospace; font-size:13px; color:var(--z3); letter-spacing:.04em; }
    .cn.fin { border-color:rgba(251,191,36,.35); color:var(--am); }
    .ca    { font-family:ui-monospace,monospace; font-size:12px; color:var(--bd2); padding:4px 20px; }

    .mq  { border-left:2px solid var(--am); padding-left:20px; }

    /* Market size numbers */
    .mnum { font-size:clamp(36px,4.5vw,64px); font-weight:600; letter-spacing:-.03em; color:var(--wh); line-height:1; margin-bottom:8px; }

    /* Silicon Leash badge */
    .sl-badge {
      display:inline-flex; align-items:center; gap:8px;
      border:1px solid rgba(251,191,36,.25); background:rgba(251,191,36,.04);
      padding:6px 14px; flex-shrink:0;
    }
    .sl-badge span { font-family:ui-monospace,monospace; font-size:10px; letter-spacing:.2em; color:var(--am); }

    /* Step rows (How It Works) */
    .step { display:grid; grid-template-columns:40px 1fr; gap:20px; padding:20px 0; border-bottom:1px solid var(--bd); align-items:start; flex:1; }
    .step:last-child { border-bottom:none; }
    .step-n { font-family:ui-monospace,monospace; font-size:10px; color:var(--am); letter-spacing:.2em; padding-top:3px; }

    /* Moat rows */
    .moat-row { display:grid; grid-template-columns:120px 1fr; gap:20px; padding:16px 0; border-bottom:1px solid var(--bd); align-items:start; flex:1; }
    .moat-row:last-child { border-bottom:none; }

    /* Tight pilot rows */
    .pilot-row { display:grid; grid-template-columns:180px 1fr; gap:20px; padding:14px 20px; background:var(--bg); align-items:start; }
  </style>

  <!-- Nav dots (12) -->
  <div class="nav-dots">
    <div class="nd on" onclick="gts(0)"></div>
    <div class="nd" onclick="gts(1)"></div>
    <div class="nd" onclick="gts(2)"></div>
    <div class="nd" onclick="gts(3)"></div>
    <div class="nd" onclick="gts(4)"></div>
    <div class="nd" onclick="gts(5)"></div>
    <div class="nd" onclick="gts(6)"></div>
    <div class="nd" onclick="gts(7)"></div>
    <div class="nd" onclick="gts(8)"></div>
    <div class="nd" onclick="gts(9)"></div>
    <div class="nd" onclick="gts(10)"></div>
    <div class="nd" onclick="gts(11)"></div>
  </div>

  <div class="counter"><span id="cn">01</span> / 12</div>

  <div class="slides" id="sl">

    <!-- 01 COVER -->
    <section class="slide has-grid">
      <span class="sn">01 / 12</span>
      <div class="lrow"><span class="dp"></span><span class="lbl">KYDE · SEED ROUND 2026</span></div>

      <div style="flex:1;display:flex;flex-direction:column;justify-content:center">
        <p class="mono am" style="font-size:10px;letter-spacing:.3em;margin-bottom:20px">KYDE</p>
        <h1 class="t-hero" style="margin-bottom:24px">
          Who Did That?
        </h1>
        <p class="t-h2" style="color:var(--z4);max-width:680px;margin-bottom:0">
          Unbreakable rules for AI agents.<br>Rooted in silicon, not software.
        </p>
      </div>

      <div style="display:flex;align-items:center;justify-content:space-between;padding-top:20px;border-top:1px solid var(--bd)">
        <div style="display:flex;gap:40px">
          <div>
            <p class="lbl" style="margin-bottom:5px">STATUS</p>
            <p class="mono am" style="font-size:12px;letter-spacing:.1em">SEED ROUND OPEN</p>
          </div>
          <div>
            <p class="lbl" style="margin-bottom:5px">TARGET</p>
            <p class="mono wh" style="font-size:12px;letter-spacing:.1em">€1.6M</p>
          </div>
        </div>
        <div style="display:flex;align-items:center;gap:16px">
          <p class="mono" style="font-size:11px;letter-spacing:.12em;color:var(--z5)">KYDE.COM</p>
          <p class="lbl" style="color:var(--bd2)">CONFIDENTIAL</p>
        </div>
      </div>
    </section>

    <!-- 02 THE PROBLEM (01/10) -->
    <section class="slide">
      <span class="sn">02 / 12</span>
      <div class="lrow"><span class="lbl">↳ THE PROBLEM · 01 / 10</span></div>

      <h2 class="t-h1" style="margin-bottom:36px;max-width:760px">AI agents execute.<br>Nobody can control what they do.</h2>

      <div class="g2" style="flex:1;gap:1px;background:var(--bd)">
        <div style="background:var(--bg);padding:32px 36px;display:flex;flex-direction:column">
          <p class="lbl mono am" style="margin-bottom:20px">↳ THE CHANGE</p>
          <p class="t-b" style="margin-bottom:16px">Agents access systems, call APIs, move data, and transact — autonomously, at machine speed, 24/7.</p>
          <p class="t-b" style="flex:1">This is the largest productivity unlock in history.</p>
        </div>
        <div style="background:var(--bg);padding:32px 36px;display:flex;flex-direction:column;border-left:2px solid rgba(251,191,36,.15)">
          <p class="lbl mono" style="color:var(--z5);margin-bottom:20px">↳ THE PROBLEM</p>
          <p class="t-b" style="margin-bottom:16px">No organization will grant agents real economic power until one question is answered:</p>
          <p class="t-h2" style="color:var(--wh);flex:1;font-size:clamp(16px,1.8vw,24px)">Can you govern what your agents are allowed to do — and prove they stayed within bounds?</p>
        </div>
      </div>
    </section>

    <!-- 03 THE SOLUTION (02/10) -->
    <section class="slide">
      <span class="sn">03 / 12</span>
      <div class="lrow"><span class="lbl">↳ THE SOLUTION · 02 / 10</span></div>

      <h2 class="t-h1" style="margin-bottom:4px">One proxy. Every agent governed.</h2>
      <p class="t-b dim" style="margin-bottom:24px;flex-shrink:0">Three interlocking layers. The compound is the product.</p>

      <div class="g3" style="flex:1">
        <div style="padding:28px 30px;display:flex;flex-direction:column">
          <p class="lbl mono am" style="margin-bottom:16px">↳ POLICY</p>
          <p class="t-b" style="margin-bottom:12px;font-size:16px">A machine-readable power of attorney for every agent.</p>
          <p class="t-sm" style="flex:1">"Max €100/day, only category X, escalate above €50." Cryptographically signed by the org. Unmodifiable by the agent.</p>
        </div>
        <div style="padding:28px 30px;display:flex;flex-direction:column">
          <p class="lbl mono" style="color:var(--z4);margin-bottom:16px">↳ ENFORCEMENT (KYDE GUARD)</p>
          <p class="t-b" style="margin-bottom:12px;font-size:16px">A transparent Rust proxy that governs every action in real time, before execution.</p>
          <p class="t-sm" style="flex:1">Agent exceeds its mandate? Blocked. Hardware-attested. Physically unbypassable.</p>
        </div>
        <div style="padding:28px 30px;display:flex;flex-direction:column">
          <p class="lbl mono" style="color:var(--z5);margin-bottom:16px">↳ LEDGER (KYDE WITNESS)</p>
          <p class="t-b" style="margin-bottom:12px;font-size:16px">Every decision, signed and hash-chained, with the governing policy hashed in.</p>
          <p class="t-sm" style="flex:1">Proves not just what happened, but under what authority — and that neither has been altered.</p>
        </div>
      </div>

      <div style="margin-top:1px;background:var(--bg1);border-top:1px solid var(--bd);padding:18px 24px;display:flex;align-items:center;justify-content:space-between;flex-shrink:0">
        <p class="t-sm" style="max-width:680px;color:var(--z4)">Policy without enforcement is a suggestion. Enforcement without a ledger is unverifiable. A ledger without policy is a log file.</p>
        <div class="sl-badge"><span>POWERED BY SILICON LEASH</span></div>
      </div>
    </section>

    <!-- 04 HOW IT WORKS (03/10) -->
    <section class="slide">
      <span class="sn">04 / 12</span>
      <div class="lrow"><span class="lbl">↳ HOW IT WORKS · 03 / 10</span></div>

      <h2 class="t-h1" style="margin-bottom:4px">Deploy in 15 minutes. Zero code changes.</h2>
      <p class="t-b dim" style="margin-bottom:28px;flex-shrink:0">One URL change. Full governance.</p>

      <div style="flex:1;display:flex;flex-direction:column">
        <div class="step">
          <p class="step-n">01</p>
          <div>
            <p class="t-b wh" style="font-size:16px;margin-bottom:6px">Change one URL</p>
            <p class="t-sm">Agent thinks it's talking to OpenAI. It's talking to Kyde first. Works with any LLM provider. No SDK. No framework dependency.</p>
          </div>
        </div>
        <div class="step">
          <p class="step-n">02</p>
          <div>
            <p class="t-b wh" style="font-size:16px;margin-bottom:6px">Witness (Observe)</p>
            <p class="t-sm">Every agent action is hardware-attested and logged. See what your agents actually do for the first time. WHO, WHAT, WHY — forensically complete.</p>
          </div>
        </div>
        <div class="step">
          <p class="step-n">03</p>
          <div>
            <p class="t-b wh" style="font-size:16px;margin-bottom:6px">Guard (Enforce)</p>
            <p class="t-sm">Define rules in YAML or plain English. Kyde compiles them into hardware-enforced policy. Agents physically cannot exceed their mandate.</p>
          </div>
        </div>
        <div class="step">
          <p class="step-n">04</p>
          <div>
            <p class="t-b wh" style="font-size:16px;margin-bottom:6px">Prove</p>
            <p class="t-sm">One-click audit export. Tamper-proof evidence for regulators, courts, or counterparties. Ed25519 signed, SHA-256 chained, hardware-rooted.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- 05 THE STACK (04/10) -->
    <section class="slide">
      <span class="sn">05 / 12</span>
      <div class="lrow"><span class="lbl">↳ THE STACK · 04 / 10</span></div>

      <h2 class="t-h1" style="margin-bottom:4px">Built like critical infrastructure.</h2>
      <p class="t-b dim" style="margin-bottom:28px;flex-shrink:0">Because it is.</p>

      <div style="flex:1;display:flex;flex-direction:column;gap:1px;background:var(--bd)">
        <div style="flex:1;background:var(--bg);display:grid;grid-template-columns:140px 1fr;gap:24px;padding:22px 28px;align-items:start">
          <p class="mono am" style="font-size:10px;letter-spacing:.2em;padding-top:2px">LANGUAGE</p>
          <p class="t-b" style="font-size:16px">Zero-copy Rust core. No garbage collector, no runtime exceptions in the signing path.</p>
        </div>
        <div style="flex:1;background:var(--bg);display:grid;grid-template-columns:140px 1fr;gap:24px;padding:22px 28px;align-items:start">
          <p class="mono" style="font-size:10px;letter-spacing:.2em;color:var(--z4);padding-top:2px">CRYPTO</p>
          <p class="t-b" style="font-size:16px">Ed25519 + SHA-256 hash-chained ledger. Same primitives that secure SSH and TLS.</p>
        </div>
        <div style="flex:1;background:var(--bg);display:grid;grid-template-columns:140px 1fr;gap:24px;padding:22px 28px;align-items:start">
          <p class="mono" style="font-size:10px;letter-spacing:.2em;color:var(--z4);padding-top:2px">HARDWARE</p>
          <p class="t-b" style="font-size:16px">HSM/TPM integration isolates signing keys from the entire software stack. Physically unreachable.</p>
        </div>
        <div style="flex:1;background:var(--bg);display:grid;grid-template-columns:140px 1fr;gap:24px;padding:22px 28px;align-items:start">
          <p class="mono" style="font-size:10px;letter-spacing:.2em;color:var(--z5);padding-top:2px">DEPLOY</p>
          <p class="t-b" style="font-size:16px">Single binary. &lt; 80ms latency. No JVM, no containers, no dependencies. One env variable to deploy.</p>
        </div>
      </div>

      <div style="padding-top:16px;display:flex;justify-content:flex-end;flex-shrink:0">
        <div class="sl-badge"><span>POWERED BY SILICON LEASH</span></div>
      </div>
    </section>

    <!-- 06 WHY NOW (05/10) -->
    <section class="slide">
      <span class="sn">06 / 12</span>
      <div class="lrow"><span class="lbl">↳ WHY NOW · 05 / 10</span></div>

      <h2 class="t-h1" style="margin-bottom:36px">Three forces are converging.</h2>

      <div style="flex:1;display:flex;flex-direction:column;gap:1px;background:var(--bd)">
        <div style="flex:1;background:var(--bg);padding:28px 32px;display:grid;grid-template-columns:36px 1fr;gap:20px;align-items:start">
          <p class="mono am" style="font-size:13px;font-weight:600;padding-top:4px">1/</p>
          <div>
            <p class="t-b wh" style="font-size:18px;margin-bottom:10px">Agent adoption is exploding.</p>
            <p class="t-sm">OpenClaw: 68k GitHub stars. Every enterprise is deploying agents that access production systems. The volume of autonomous actions is growing exponentially — and with it, the liability.</p>
          </div>
        </div>
        <div style="flex:1;background:var(--bg);padding:28px 32px;display:grid;grid-template-columns:36px 1fr;gap:20px;align-items:start">
          <p class="mono am" style="font-size:13px;font-weight:600;padding-top:4px">2/</p>
          <div>
            <p class="t-b wh" style="font-size:18px;margin-bottom:10px">The first major incidents are coming.</p>
            <p class="t-sm">When an agent leaks data, approves a fraudulent transaction, or hallucinates a costly recommendation — the only question that matters: can you prove what happened, and that it was authorized?</p>
          </div>
        </div>
        <div style="flex:1;background:var(--bg);padding:28px 32px;display:grid;grid-template-columns:36px 1fr;gap:20px;align-items:start;border-left:2px solid rgba(251,191,36,.2)">
          <p class="mono am" style="font-size:13px;font-weight:600;padding-top:4px">3/</p>
          <div>
            <p class="t-b wh" style="font-size:18px;margin-bottom:10px">Regulation is codifying the mandate.</p>
            <p class="t-sm">EU AI Act (2027): tamper-proof audit trails. NIS-2 + DORA (active now): 72h forensic reporting. Penalty: up to <strong class="wh">€15M or 3% of global revenue.</strong> The compliance clock is already ticking.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- 07 THE MARKET (06/10) -->
    <section class="slide">
      <span class="sn">07 / 12</span>
      <div class="lrow"><span class="lbl">↳ THE MARKET · 06 / 10</span></div>

      <h2 class="t-h1" style="margin-bottom:4px">Every enterprise deploying agents<br>needs governance.</h2>
      <p class="t-b dim" style="margin-bottom:32px;flex-shrink:0">Regulation makes it mandatory.</p>

      <div class="g3" style="flex:1">
        <div style="padding:32px 30px;display:flex;flex-direction:column">
          <p class="lbl mono am" style="margin-bottom:20px">TOTAL ADDRESSABLE MARKET</p>
          <p class="mnum">€4.3B</p>
          <p class="t-sm" style="flex:1">~50k EU enterprises × avg. 3 AI systems × €29k annual compliance cost (EU Commission Impact Assessment).</p>
        </div>
        <div style="padding:32px 30px;display:flex;flex-direction:column">
          <p class="lbl mono" style="color:var(--z4);margin-bottom:20px">SERVICEABLE ADDRESSABLE MARKET</p>
          <p class="mnum">€820M</p>
          <p class="t-sm" style="flex:1">High-risk verticals: Finance, Insurance, Critical Infrastructure = ~20% of TAM.</p>
        </div>
        <div style="padding:32px 30px;display:flex;flex-direction:column">
          <p class="lbl mono" style="color:var(--z5);margin-bottom:20px">GLOBAL</p>
          <p class="mnum" style="font-size:clamp(24px,2.8vw,44px);color:var(--z3)">Universal</p>
          <p class="t-sm" style="flex:1">SEC AI Disclosure, NIST AI RMF, NY DFS AI Guidance. Agent governance is a universal infrastructure need.</p>
        </div>
      </div>
    </section>

    <!-- 08 THE MOAT (07/10) -->
    <section class="slide">
      <span class="sn">08 / 12</span>
      <div class="lrow"><span class="lbl">↳ THE MOAT · 07 / 10</span></div>

      <h2 class="t-h1" style="margin-bottom:4px">Not antivirus.</h2>
      <p class="t-h2 dim" style="margin-bottom:28px;flex-shrink:0">Corporate law for agents.</p>

      <div style="flex:1;display:flex;flex-direction:column;gap:1px;background:var(--bd)">
        <div class="moat-row" style="background:var(--bg);padding:16px 0">
          <p class="mono am" style="font-size:10px;letter-spacing:.18em;padding-top:3px">STRUCTURAL</p>
          <p class="t-b" style="font-size:16px">LLM providers cannot legally audit themselves. The auditor must be independent. The more frontier labs scale, the bigger our mandate.</p>
        </div>
        <div class="moat-row" style="background:var(--bg);padding:16px 0">
          <p class="mono" style="font-size:10px;letter-spacing:.18em;color:var(--z4);padding-top:3px">TECHNICAL</p>
          <p class="t-b" style="font-size:16px">Software logs are a liability — agents can alter them. Silicon Leash isolates signing keys in hardware, physically unreachable by software.</p>
        </div>
        <div class="moat-row" style="background:var(--bg);padding:16px 0">
          <p class="mono" style="font-size:10px;letter-spacing:.18em;color:var(--z4);padding-top:3px">INFRASTRUCTURE</p>
          <p class="t-b" style="font-size:16px">We sit in the data path. Once installed, we own the chokepoint. Policy format becomes the standard — switching means rewriting every delegation.</p>
        </div>
        <div class="moat-row" style="background:var(--bg);padding:16px 0;border-left:2px solid rgba(251,191,36,.2);padding-left:20px">
          <p class="mono" style="font-size:10px;letter-spacing:.18em;color:var(--z5);padding-top:3px">CATEGORY</p>
          <p class="t-b" style="font-size:16px">YC W26 funded 6 agent-infra companies: identity, security, guardrails, monitoring, payments. Nobody builds governance. <strong class="wh">We are the missing layer.</strong></p>
        </div>
      </div>

      <div style="padding-top:14px;flex-shrink:0">
        <p class="t-sm" style="color:var(--z6)">Zenity/Lakera inspect inputs. Salus validates. Sentrial monitors. Kyde governs authority and proves compliance. Different layers.</p>
      </div>
    </section>

