---
import SlideBase from "../../layouts/SlideBase.astro";
---

<SlideBase title="KYDE — Seed Round 2026">
  <style slot="head">
    :root {
      --bg:     #09090b;
      --bg1:    #18181b;
      --bd:     #27272a;
      --bd2:    #3f3f46;
      --z3:     #e4e4e7;
      --z4:     #d4d4d8;
      --z5:     #a1a1aa;
      --z6:     #71717a;
      --am:     #fbbf24;
      --wh:     #f4f4f5;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { background: var(--bg); }
    body {
      background: var(--bg);
      color: var(--wh);
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      -webkit-font-smoothing: antialiased;
      overflow: hidden;
    }

    .slides {
      height: 100vh;
      overflow-y: scroll;
      scroll-snap-type: y mandatory;
      scrollbar-width: none;
      -ms-overflow-style: none;
    }
    .slides::-webkit-scrollbar { display: none; }

    .slide {
      height: 100vh;
      scroll-snap-align: start;
      scroll-snap-stop: always;
      position: relative;
      display: flex;
      flex-direction: column;
      padding: 48px 80px;
      overflow: hidden;
      border-bottom: 1px solid var(--bd);
    }

    .has-grid::before {
      content: '';
      position: absolute;
      inset: 0;
      background-image:
        linear-gradient(rgba(255,255,255,0.016) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.016) 1px, transparent 1px);
      background-size: 48px 48px;
      pointer-events: none;
    }

    /* Nav dots */
    .nav-dots {
      position: fixed; right: 18px; top: 50%;
      transform: translateY(-50%);
      display: flex; flex-direction: column; gap: 6px;
      z-index: 200;
    }
    .nd {
      width: 3px; height: 3px; border-radius: 50%;
      background: var(--bd2); cursor: pointer;
      transition: height .25s, border-radius .25s, background .25s;
    }
    .nd.on { height: 16px; border-radius: 2px; background: var(--am); }

    .counter {
      position: fixed; bottom: 22px; right: 36px;
      font-family: ui-monospace, monospace;
      font-size: 10px; letter-spacing: 0.22em; color: var(--bd2); z-index: 200;
    }

    .sn {
      position: absolute; top: 48px; right: 80px;
      font-family: ui-monospace, monospace;
      font-size: 10px; letter-spacing: 0.2em; color: var(--bd2);
    }

    /* Label row */
    .lrow { display: flex; align-items: center; gap: 10px; margin-bottom: 32px; flex-shrink: 0; }
    .lrow::after { content:''; flex:1; height:1px; background:var(--bd); }
    .lbl { font-family: ui-monospace, monospace; font-size: 10px; letter-spacing: 0.25em; text-transform: uppercase; color: var(--z6); }
    .dp { width:6px; height:6px; border-radius:50%; background:var(--am); opacity:.7; flex-shrink:0; animation:pulse 2s ease-in-out infinite; }
    @keyframes pulse { 0%,100%{opacity:.3} 50%{opacity:.9} }

    /* Typography */
    .t-hero { font-family:'Inter',sans-serif; font-size:clamp(52px,8vw,104px); font-weight:600; letter-spacing:-.03em; line-height:1.08; text-transform:uppercase; }
    .t-h1   { font-family:'Inter',sans-serif; font-size:clamp(28px,3.6vw,52px); font-weight:600; letter-spacing:-.03em; line-height:1.05; }
    .t-h2   { font-family:'Inter',sans-serif; font-size:clamp(18px,2.2vw,30px); font-weight:500; letter-spacing:-.02em; line-height:1.1; }
    .t-b    { font-size:17px; line-height:1.65; color:var(--z4); }
    .t-sm   { font-size:15px; line-height:1.6; color:var(--z5); }
    .mono   { font-family: ui-monospace, monospace; }
    .am     { color: var(--am); }
    .wh     { color: var(--wh); }
    .dim    { color: var(--z5); }

    /* Cards */
    .card   { border:1px solid var(--bd);  background:var(--bg1); padding:20px 24px; }
    .card-l { border:1px solid var(--bd2); background:var(--bg1); padding:20px 24px; border-left:2px solid var(--am); }

    /* Grids */
    .g3 { display:grid; grid-template-columns:1fr 1fr 1fr; gap:1px; background:var(--bd); }
    .g3>* { background:var(--bg); }
    .g2 { display:grid; grid-template-columns:1fr 1fr; gap:40px; }

    /* Stacked rows */
    .rows { display:flex; flex-direction:column; gap:1px; background:var(--bd); }
    .row  { background:var(--bg); display:grid; grid-template-columns:160px 1fr; gap:24px; padding:20px 24px; align-items:start; flex:1; }

    /* Regulatory table */
    .rt  { width:100%; border-top:1px solid var(--bd); display:flex; flex-direction:column; }
    .rth { display:grid; grid-template-columns:130px 110px 1fr 1fr; background:var(--bg1); border-bottom:1px solid var(--bd); flex-shrink:0; }
    .rtr { display:grid; grid-template-columns:130px 110px 1fr 1fr; border-bottom:1px solid var(--bd); flex:1; }
    .rtr:last-child { border-bottom:none; }
    .rtc { padding:16px 18px; font-size:15px; line-height:1.55; display:flex; align-items:center; }
    .rtc+.rtc { border-left:1px solid var(--bd); }

    /* Architecture chain */
    .chain { display:flex; flex-direction:column; }
    .cn    { display:flex; align-items:center; justify-content:space-between; border:1px solid var(--bd2); background:var(--bg1); padding:12px 18px; font-family:ui-monospace,monospace; font-size:13px; color:var(--z3); letter-spacing:.04em; }
    .cn.fin { border-color:rgba(251,191,36,.35); color:var(--am); }
    .ca    { font-family:ui-monospace,monospace; font-size:12px; color:var(--bd2); padding:4px 20px; }

    .mq  { border-left:2px solid var(--am); padding-left:20px; }
    .pen { border:1px solid rgba(251,191,36,.2); background:rgba(251,191,36,.03); padding:16px 22px; }

    /* Market size numbers */
    .mnum { font-size:clamp(32px,4vw,56px); font-weight:600; letter-spacing:-.03em; color:var(--wh); line-height:1; margin-bottom:8px; }
  </style>

  <!-- Nav dots (14) -->
  <div class="nav-dots">
    <div class="nd on" onclick="gts(0)"></div>
    <div class="nd" onclick="gts(1)"></div>
    <div class="nd" onclick="gts(2)"></div>
    <div class="nd" onclick="gts(3)"></div>
    <div class="nd" onclick="gts(4)"></div>
    <div class="nd" onclick="gts(5)"></div>
    <div class="nd" onclick="gts(6)"></div>
    <div class="nd" onclick="gts(7)"></div>
    <div class="nd" onclick="gts(8)"></div>
    <div class="nd" onclick="gts(9)"></div>
    <div class="nd" onclick="gts(10)"></div>
    <div class="nd" onclick="gts(11)"></div>
    <div class="nd" onclick="gts(12)"></div>
    <div class="nd" onclick="gts(13)"></div>
  </div>

  <div class="counter"><span id="cn">01</span> / 14</div>

  <div class="slides" id="sl">

    <!-- 01 TITLE -->
    <section class="slide has-grid">
      <span class="sn">01 / 14</span>
      <div class="lrow"><span class="dp"></span><span class="lbl">KYDE WITNESS · SEED ROUND 2026</span></div>

      <div style="flex:1;display:flex;flex-direction:column;justify-content:center">
        <h1 class="t-hero" style="margin-bottom:28px">
          Who Did That?
        </h1>
        <p class="t-h2" style="color:var(--z4);margin-bottom:20px;max-width:700px;text-transform:uppercase;letter-spacing:.05em;font-weight:500">
          Accountability Infrastructure for AI Agents<br>in a NIS-2 + AI Act World.
        </p>
        <p class="t-b" style="max-width:560px;color:var(--z5)">
          Cryptographic governance for autonomous AI at enterprise scale.
        </p>
      </div>

      <div style="display:flex;align-items:center;justify-content:space-between;padding-top:20px;border-top:1px solid var(--bd)">
        <div style="display:flex;gap:40px">
          <div>
            <p class="lbl" style="margin-bottom:5px">STATUS</p>
            <p class="mono am" style="font-size:12px;letter-spacing:.1em">SEED ROUND OPEN</p>
          </div>
          <div>
            <p class="lbl" style="margin-bottom:5px">TARGET</p>
            <p class="mono wh" style="font-size:12px;letter-spacing:.1em">€1.6M</p>
          </div>
          <div>
            <p class="lbl" style="margin-bottom:5px">ENFORCEMENT</p>
            <p class="mono am" style="font-size:12px;letter-spacing:.1em">AUG 2, 2026</p>
          </div>
        </div>
        <p class="lbl" style="color:var(--bd2)">CONFIDENTIAL</p>
      </div>
    </section>

    <!-- 02 THE SHIFT -->
    <section class="slide">
      <span class="sn">02 / 14</span>
      <div class="lrow"><span class="lbl">↳ THE SHIFT & THE PROBLEM</span></div>

      <h2 class="t-h1" style="margin-bottom:4px">The Economy is Going Agentic.</h2>
      <p class="t-h2 dim" style="margin-bottom:28px">But — "Who Did That?"</p>

      <div class="g3" style="flex:1">
        <div style="padding:24px 28px">
          <p class="lbl mono am" style="margin-bottom:14px">THE ECONOMIC BOOM</p>
          <p class="t-b" style="margin-bottom:10px">AI is moving from "Chat" to "Execution".</p>
          <p class="t-sm">Agents now independently plan, execute, access databases, and trigger API calls. This is the biggest productivity boom in history.</p>
        </div>
        <div style="padding:24px 28px">
          <p class="lbl mono" style="color:var(--z5);margin-bottom:14px">THE PROBLEM</p>
          <p class="t-b" style="margin-bottom:10px">Too fast, too many — no human-in-the-loop possible.</p>
          <p class="t-sm">The speed and scale of agent execution makes traditional oversight structurally impossible.</p>
        </div>
        <div style="padding:24px 28px">
          <p class="lbl mono" style="color:var(--z6);margin-bottom:14px">THE GOVERNANCE GAP</p>
          <p class="t-b" style="margin-bottom:10px">When an agent moves money or alters a database —</p>
          <p class="t-sm">Enterprises have <strong class="wh">zero independently verifiable visibility</strong> into what ran, when, or why. Operating completely in the dark.</p>
        </div>
      </div>
    </section>

    <!-- 03 THE CATALYST -->
    <section class="slide">
      <span class="sn">03 / 14</span>
      <div class="lrow"><span class="lbl">↳ THE CATALYST — THE REVENUE ENABLER</span></div>

      <h2 class="t-h1" style="margin-bottom:28px;max-width:800px">Without KYDE, you cannot safely deploy<br>revenue-generating agents.</h2>

      <div class="g2" style="flex:1;gap:32px;align-items:start">
        <!-- Left -->
        <div style="display:flex;flex-direction:column;gap:16px">
          <div class="card">
            <p class="lbl mono" style="color:var(--z5);margin-bottom:10px">THE REALITY</p>
            <p class="t-b" style="font-size:16px">Every enterprise wants to deploy autonomous agents. But <strong class="wh">Legal & Risk teams are blocking them.</strong></p>
            <p class="t-sm" style="margin-top:8px">If you don't go agentic, you lose the market. If you deploy blindly, you face ruin.</p>
          </div>
          <div class="card-l">
            <p class="lbl mono am" style="margin-bottom:10px">THE SHIFT</p>
            <p class="t-b" style="font-size:16px">KYDE isn't just a compliance cost.</p>
            <p class="t-sm" style="margin-top:8px">We are the <strong class="wh">1-click Enabler</strong> that allows the CISO to say "YES" to autonomous AI.</p>
          </div>
        </div>

        <!-- Right: Compliance Wall -->
        <div>
          <p class="lbl mono" style="color:var(--z6);margin-bottom:16px">THE COMPLIANCE WALL</p>
          <div style="display:flex;flex-direction:column;gap:1px;background:var(--bd);margin-bottom:1px">
            <div style="background:var(--bg);padding:16px 20px;display:grid;grid-template-columns:140px 1fr;gap:16px;align-items:center">
              <p class="mono am" style="font-size:11px;letter-spacing:.1em">EU AI ACT<br><span style="color:var(--z6);font-size:10px">AUG 2026</span></p>
              <p class="t-sm">Mandatory logging for High-Risk AI systems.</p>
            </div>
            <div style="background:var(--bg);padding:16px 20px;display:grid;grid-template-columns:140px 1fr;gap:16px;align-items:center">
              <p class="mono" style="font-size:11px;letter-spacing:.1em;color:var(--z4)">NIS-2 / DORA<br><span style="color:var(--z6);font-size:10px">ACTIVE NOW</span></p>
              <p class="t-sm">Legal requirement for AI audit trails in critical infra & finance.</p>
            </div>
          </div>
          <div class="pen">
            <p class="lbl mono" style="margin-bottom:6px">THE PENALTY</p>
            <p style="font-size:16px;color:var(--am)">Up to <strong>€35M</strong> or <strong>7%</strong> of global revenue.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- 04 THE SOLUTION -->
    <section class="slide">
      <span class="sn">04 / 14</span>
      <div class="lrow"><span class="lbl">↳ THE SOLUTION</span></div>

      <h2 class="t-h1" style="margin-bottom:4px">The Zero-Modification Cryptographic Witness.</h2>
      <p class="t-h2 dim" style="margin-bottom:28px">What KYDE actually is.</p>

      <div class="g2" style="flex:1;gap:1px;background:var(--bd)">
        <div style="background:var(--bg);padding:28px 32px">
          <p class="lbl mono am" style="margin-bottom:12px">ONE-LINE DEPLOYMENT</p>
          <p class="t-b" style="margin-bottom:8px">No code changes.</p>
          <p class="t-sm">The agent thinks it's talking to the LLM or an MCP server. It's talking to KYDE first.</p>
        </div>
        <div style="background:var(--bg);padding:28px 32px">
          <p class="lbl mono" style="color:var(--z4);margin-bottom:12px">ZERO-MODIFICATION</p>
          <p class="t-b" style="margin-bottom:8px">We observe and log without altering a single token.</p>
          <p class="t-sm">The enterprise safely preserves its legal status as a "Deployer" — avoiding Article 25 liability.</p>
        </div>
        <div style="background:var(--bg);padding:28px 32px">
          <p class="lbl mono" style="color:var(--z4);margin-bottom:12px">REAL-TIME ATTESTATION</p>
          <p class="t-b" style="margin-bottom:8px">Every tool call, context window, and API execution —</p>
          <p class="t-sm">Intercepted, <strong class="wh">Ed25519-signed</strong>, and pushed to an immutable ledger. In real time.</p>
        </div>
        <div style="background:var(--bg);padding:28px 32px">
          <p class="lbl mono" style="color:var(--z5);margin-bottom:12px">TRANSPARENT PROXY</p>
          <p class="t-b" style="margin-bottom:8px">Sits between your agent fleet and the outside world.</p>
          <p class="t-sm">MCP-native routing. Works with any LLM provider. No vendor lock-in.</p>
        </div>
      </div>
    </section>

    <!-- 05 REGULATORY FIT -->
    <section class="slide">
      <span class="sn">05 / 14</span>
      <div class="lrow"><span class="lbl">↳ THE REGULATORY FIT</span></div>

      <h2 class="t-h1" style="margin-bottom:4px">The law has already answered the question.</h2>
      <p class="t-b dim" style="margin-bottom:18px">What Regulators Require vs. What KYDE Delivers.</p>

      <div class="rt" style="flex:1">
        <div class="rth">
          <div class="rtc"><p class="mono" style="font-size:10px;color:var(--z6)">FRAMEWORK</p></div>
          <div class="rtc"><p class="mono" style="font-size:10px;color:var(--z6)">ENFORCEMENT</p></div>
          <div class="rtc"><p class="mono" style="font-size:10px;color:var(--z6)">REQUIREMENT</p></div>
          <div class="rtc"><p class="mono am" style="font-size:10px">KYDE PROOF</p></div>
        </div>
        <div class="rtr">
          <div class="rtc" style="background:var(--bg1)"><p class="mono" style="font-size:11px;color:var(--z5)">EU AI Act<br>Article 12</p></div>
          <div class="rtc" style="background:var(--bg1)"><p class="mono am" style="font-size:12px">Aug 2026</p></div>
          <div class="rtc"><p style="color:var(--z4)">Tamper-proof logging of every autonomous AI decision.</p></div>
          <div class="rtc"><p style="color:var(--z3)">Ed25519-signed, SHA-256 chained ledger. Tamper any entry — the entire chain breaks.</p></div>
        </div>
        <div class="rtr">
          <div class="rtc" style="background:var(--bg1)"><p class="mono" style="font-size:11px;color:var(--z5)">EU AI Act<br>Article 13</p></div>
          <div class="rtc" style="background:var(--bg1)"><p class="mono am" style="font-size:12px">Aug 2026</p></div>
          <div class="rtc"><p style="color:var(--z4)">Full traceability of the system's context prior to execution.</p></div>
          <div class="rtc"><p style="color:var(--z3)">Causal context capture. MCP routing logged to prove why the agent acted.</p></div>
        </div>
        <div class="rtr">
          <div class="rtc" style="background:var(--bg1)"><p class="mono" style="font-size:11px;color:var(--z5)">NIS-2<br>Directive</p></div>
          <div class="rtc" style="background:var(--bg1)"><p class="mono" style="font-size:12px;color:var(--z3)">Active Now</p></div>
          <div class="rtc"><p style="color:var(--z4)">Verifiable incident reporting for AI-dependent supply chains.</p></div>
          <div class="rtc"><p style="color:var(--z3)">Real-time forensic evidence. Instant, irrefutable export for auditors and SIEM.</p></div>
        </div>
        <div class="rtr">
          <div class="rtc" style="background:var(--bg1)"><p class="mono" style="font-size:11px;color:var(--z5)">DORA</p></div>
          <div class="rtc" style="background:var(--bg1)"><p class="mono" style="font-size:12px;color:var(--z3)">Active Now</p></div>
          <div class="rtc"><p style="color:var(--z4)">ICT third-party risk audit trail for external AI dependencies.</p></div>
          <div class="rtc"><p style="color:var(--z3)">Provider-agnostic proxy. Standardized logging across OpenAI, Anthropic, or Azure.</p></div>
        </div>
      </div>
    </section>

    <!-- 06 MARKET SIZE -->
    <section class="slide">
      <span class="sn">06 / 14</span>
      <div class="lrow"><span class="lbl">↳ MARKET SIZE</span></div>

      <h2 class="t-h1" style="margin-bottom:4px">The Addressable Market is Defined by Law.</h2>
      <p class="t-b dim" style="margin-bottom:32px">~50,000 enterprises in the EU must deploy High-Risk AI systems under the EU AI Act.</p>

      <div class="g3" style="flex:1">
        <div style="padding:32px 36px;display:flex;flex-direction:column;justify-content:center">
          <p class="lbl mono" style="color:var(--z6);margin-bottom:16px">TAM</p>
          <p class="mnum">€4.2B</p>
          <p class="t-sm">Annual compliance infrastructure spend across EU regulated enterprises.</p>
        </div>
        <div style="padding:32px 36px;display:flex;flex-direction:column;justify-content:center">
          <p class="lbl mono" style="color:var(--z6);margin-bottom:16px">SAM</p>
          <p class="mnum">€820M</p>
          <p class="t-sm">High-Risk AI Act verticals: Finance, HR, Insurance, Healthcare, Critical Infrastructure.</p>
        </div>
        <div style="padding:32px 36px;display:flex;flex-direction:column;justify-content:center">
          <p class="lbl mono am" style="margin-bottom:16px">SOM</p>
          <p class="mnum am">€12M ARR</p>
          <p class="t-sm">5 enterprise pilots with expansion paths over 18 months.</p>
        </div>
      </div>
    </section>

    <!-- 07 THE SECRET -->
    <section class="slide">
      <span class="sn">07 / 14</span>
      <div class="lrow"><span class="lbl">↳ THE SECRET — THIEL INSIGHT</span></div>

      <div style="flex:1;display:flex;flex-direction:column;justify-content:center;max-width:900px">
        <h2 class="t-h1" style="margin-bottom:36px">Intelligence is Common.<br>Trust is the Bottleneck.</h2>

        <div class="rows" style="flex:1;max-height:360px">
          <div class="row">
            <p class="lbl mono" style="color:var(--z6);padding-top:2px">THE BOTTLENECK</p>
            <p class="t-b">No CEO grants an agent real power if they cannot govern its mandate. The intelligence problem is largely solved. <strong class="wh">The trust problem is not.</strong></p>
          </div>
          <div class="row">
            <p class="lbl mono" style="color:var(--z4);padding-top:2px">DETERMINISTIC<br>VS. PROBABILISTIC</p>
            <div>
              <p class="t-b" style="margin-bottom:8px"><strong class="wh">Others (Probabilistic):</strong> Use "AI to watch AI". Best-guess, prone to jailbreaks.</p>
              <p class="t-b"><strong class="wh">KYDE (Deterministic):</strong> Hard cryptographic boundaries. We don't "guess" if an action is safe — we verify it against a signed policy.</p>
            </div>
          </div>
          <div class="row">
            <p class="lbl mono am" style="padding-top:2px">THE ANALOGY</p>
            <p class="t-b">Competitors are <strong class="wh">Antivirus</strong> — reactive, probabilistic, bypassable.<br>KYDE is <strong class="wh">Corporate Law</strong> — structural, deterministic, unbypassable.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- 08 STRUCTURAL MOAT -->
    <section class="slide">
      <span class="sn">08 / 14</span>
      <div class="lrow"><span class="lbl">↳ THE STRUCTURAL MOAT</span></div>

      <div style="flex:1;display:flex;flex-direction:column;justify-content:center;max-width:900px">
        <h2 class="t-h1" style="margin-bottom:36px">Frontier Labs Will Eat Software.<br>They Cannot Eat Us.</h2>

        <div class="rows" style="flex:1;max-height:340px">
          <div class="row">
            <p class="lbl mono" style="color:var(--z6);padding-top:2px">THE REALITY</p>
            <p class="t-b">OpenAI, Anthropic, and DeepSeek will build smarter models and absorb most vertical AI software. Every feature they ship makes SaaS apps obsolete.</p>
          </div>
          <div class="row">
            <p class="lbl mono" style="color:var(--z4);padding-top:2px">THE MOAT</p>
            <p class="t-b"><strong class="wh">But they cannot legally be the auditor of their own system.</strong><br>That is why KPMG exists. Independence is structural — not a feature.</p>
          </div>
          <div class="row">
            <p class="lbl mono am" style="padding-top:2px">THE GAP</p>
            <p class="t-b mq" style="font-size:18px;color:var(--z3)">We sit in the gap that the frontier labs create by existing. <strong class="wh">The faster they scale, the smarter their agents get, the bigger our mandate becomes.</strong></p>
          </div>
        </div>
      </div>
    </section>

    <!-- 09 TECHNICAL MOAT -->
    <section class="slide">
      <span class="sn">09 / 14</span>
      <div class="lrow"><span class="lbl">↳ THE TECHNICAL MOAT</span></div>

      <h2 class="t-h1" style="margin-bottom:4px">Secure by Design. "The Silicon Leash".</h2>
