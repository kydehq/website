  <script>
    if (localStorage.getItem('kyde_slides_auth') !== 'kyde_2026') {
      window.location.replace('/slides/');
    }

    const sl   = document.getElementById('sl') as HTMLElement;
    const dots = document.querySelectorAll('.nd');
    const cn   = document.getElementById('cn') as HTMLElement;

    function upd() {
      const i = Math.round(sl.scrollTop / window.innerHeight);
      dots.forEach((d, j) => d.classList.toggle('on', j === i));
      cn.textContent = String(Math.min(i + 1, 9)).padStart(2, '0');
    }

    sl.addEventListener('scroll', upd, { passive: true });
    upd();

    document.addEventListener('keydown', (e) => {
      const h = window.innerHeight;
      if (['ArrowDown','PageDown',' '].includes(e.key)) { e.preventDefault(); sl.scrollBy({ top:  h, behavior: 'smooth' }); }
      if (['ArrowUp','PageUp'].includes(e.key))          { e.preventDefault(); sl.scrollBy({ top: -h, behavior: 'smooth' }); }
    });

    function gts(i: number) { sl.scrollTo({ top: i * window.innerHeight, behavior: 'smooth' }); }
    (window as any).gts = gts;
  </script>
