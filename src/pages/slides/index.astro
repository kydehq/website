---
import SlideBase from "../../layouts/SlideBase.astro";
---

<SlideBase title="KYDE — Slides">
  <style slot="head">
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html, body {
      height: 100%;
      background: #09090b;
      color: #f4f4f5;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      -webkit-font-smoothing: antialiased;
    }

    .page {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 48px 24px;
    }

    .logo {
      font-size: 28px;
      font-weight: 900;
      letter-spacing: -0.04em;
      color: #f4f4f5;
      margin-bottom: 32px;
    }

    .gate-label {
      font-family: ui-monospace, monospace;
      font-size: 10px;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: #52525b;
      margin-bottom: 12px;
    }

    .gate-rule { width: 100%; height: 1px; background: #27272a; margin-bottom: 32px; }

    .gate-input {
      width: 100%;
      background: #18181b;
      border: 1px solid #3f3f46;
      color: #f4f4f5;
      font-family: ui-monospace, monospace;
      font-size: 14px;
      letter-spacing: 0.1em;
      padding: 14px 16px;
      outline: none;
      margin-bottom: 12px;
      transition: border-color 0.2s;
    }
    .gate-input:focus { border-color: #71717a; }
    .gate-input::placeholder { color: #3f3f46; }

    .gate-btn {
      width: 100%;
      background: #18181b;
      border: 1px solid #3f3f46;
      color: #f4f4f5;
      font-family: ui-monospace, monospace;
      font-size: 11px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      padding: 12px 16px;
      cursor: pointer;
      transition: border-color 0.2s, color 0.2s;
    }
    .gate-btn:hover { border-color: #fbbf24; color: #fbbf24; }

    .gate-error {
      font-family: ui-monospace, monospace;
      font-size: 11px;
      color: #ef4444;
      letter-spacing: 0.1em;
      margin-top: 12px;
      display: none;
    }

    #gate {
      width: 100%;
      max-width: 420px;
      display: flex;
      flex-direction: column;
      align-items: flex-start;
    }

    #overview {
      width: 100%;
      max-width: 640px;
      display: none;
      flex-direction: column;
    }

    .ov-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 32px;
    }

    .logout-btn {
      font-family: ui-monospace, monospace;
      font-size: 10px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: #52525b;
      background: none;
      border: 1px solid #27272a;
      padding: 6px 12px;
      cursor: pointer;
      transition: color 0.2s, border-color 0.2s;
    }
    .logout-btn:hover { color: #a1a1aa; border-color: #3f3f46; }

    .deck-item {
      display: flex;
      align-items: center;
      justify-content: space-between;
      border: 1px solid #27272a;
      background: #18181b;
      padding: 20px 24px;
      text-decoration: none;
      color: inherit;
      margin-bottom: 1px;
      transition: border-color 0.2s, background 0.2s;
    }
    .deck-item:hover { border-color: #3f3f46; background: #1c1c1f; }

    .deck-title { font-size: 15px; font-weight: 600; color: #f4f4f5; margin-bottom: 4px; }
    .deck-meta  { font-family: ui-monospace, monospace; font-size: 10px; letter-spacing: 0.15em; color: #52525b; }
    .deck-arrow { font-family: ui-monospace, monospace; font-size: 14px; color: #3f3f46; }
  </style>

  <div class="page">

    <div id="gate">
      <div class="logo">KYDE</div>
      <p class="gate-label">↳ SLIDES — RESTRICTED ACCESS</p>
      <div class="gate-rule"></div>
      <form id="authForm" style="width:100%">
        <input type="password" id="pw" class="gate-input" placeholder="Access code" autocomplete="off" autofocus />
        <button type="submit" class="gate-btn">Enter →</button>
        <p id="gateError" class="gate-error">Incorrect access code.</p>
      </form>
    </div>

    <div id="overview">
      <div class="ov-header">
        <div>
          <div class="logo" style="margin-bottom:8px">KYDE</div>
          <p class="gate-label" style="margin-bottom:0">↳ Available Decks</p>
        </div>
        <button class="logout-btn" id="logoutBtn">Logout</button>
      </div>
      <div class="gate-rule"></div>
      <a class="deck-item" href="/slides/berlin-vc">
        <div>
          <p class="deck-title">Berlin VC Circuit</p>
          <p class="deck-meta">SEED ROUND 2026 · 9 SLIDES</p>
        </div>
        <span class="deck-arrow">→</span>
      </a>
    </div>

  </div>

  <script>
    const AUTH_KEY = 'kyde_slides_auth';
    const PASSWORD = 'admin';
    const AUTH_VAL = 'kyde_2026';

    function showOverview() {
      document.getElementById('gate').style.display     = 'none';
      document.getElementById('overview').style.display = 'flex';
    }

    if (localStorage.getItem(AUTH_KEY) === AUTH_VAL) showOverview();

    document.getElementById('authForm').addEventListener('submit', (e) => {
      e.preventDefault();
      const pw = (document.getElementById('pw') as HTMLInputElement).value;
      if (pw === PASSWORD) {
        localStorage.setItem(AUTH_KEY, AUTH_VAL);
        showOverview();
      } else {
        document.getElementById('gateError').style.display = 'block';
        (document.getElementById('pw') as HTMLInputElement).value = '';
        document.getElementById('pw').focus();
      }
    });

    document.getElementById('logoutBtn').addEventListener('click', () => {
      localStorage.removeItem(AUTH_KEY);
      document.getElementById('overview').style.display = 'none';
      document.getElementById('gate').style.display     = 'flex';
      (document.getElementById('pw') as HTMLInputElement).value = '';
      document.getElementById('pw').focus();
    });
  </script>
</SlideBase>
