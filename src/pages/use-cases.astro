---
import Base from '../layouts/Base.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const cases = [
  {
    n: '01',
    sector: 'Financial Services & Fintech',
    tag: 'DORA · EU AI Act · GDPR',
    reality: 'AI agents in finance execute trades, assess creditworthiness, process BNPL decisions, and manage customer interactions — autonomously. Each is a workforce member operating in one of the most heavily regulated environments on earth. A single unexplained automated decision can trigger regulatory inquiry, customer litigation, or license review.\n\nMost financial institutions have no way to answer the basic question: what did this agent do, why, and can you prove the record hasn\'t been altered?',
    resilience: 'Every agent in your financial stack gets an identity and a role. Token budgets prevent runaway costs. API allowlists ensure agents only reach authorized endpoints. Every action is signed and hash-chained — incident investigations resolve in minutes, not weeks. Regulators receive complete, verifiable audit exports. Your compliance team has a source of truth built on a cryptographic root of trust.',
    regs: [
      'DORA — Digital Operational Resilience Act (in force January 2025)',
      'EU AI Act — High-Risk AI (Annex III, §5 Credit Scoring)',
      'BaFin AI Guidance — Supervisory expectations for AI system accountability',
      'GDPR Art. 35 — DPIA for automated financial processing',
    ],
  },
  {
    n: '02',
    sector: 'HR Technology & Recruiting',
    tag: 'EU AI Act — High Risk',
    reality: 'AI agents in HR are classified as High-Risk under the EU AI Act (Annex III). Automated screening, scoring, and shortlisting of candidates are subject to mandatory logging, human oversight requirements, and audit-readiness obligations — with enforcement beginning August 2, 2027.\n\nThese agents are a workforce making decisions about your workforce. Without governance infrastructure, a rejected candidate\'s legal challenge becomes an existential question: can you reconstruct what the agent saw, what it decided, and why?',
    resilience: 'Every candidate interaction, every scoring decision, every tool call is captured with full causal context. Role-based fleet management ensures your recruiting agents operate within defined boundaries. The tamper-evident evidence trail means that when a decision is challenged, the record speaks for itself — and it can\'t be rewritten after the fact.',
    regs: [
      'EU AI Act — High-Risk AI System (Annex III, §4 Employment)',
      'GDPR Art. 22 — Automated Decision-Making',
      'AGG (Germany) — Anti-discrimination compliance for automated hiring',
    ],
  },
  {
    n: '03',
    sector: 'Insurance & Claims Automation',
    tag: 'EU AI Act · NIS-2 · Solvency II',
    reality: 'Claims processing, fraud detection, and underwriting are increasingly automated — and increasingly scrutinized. Insurers face dual exposure: regulatory risk under the EU AI Act for automated decisions, and legal risk when claimants challenge AI-assisted outcomes. In Moffatt v. Air Canada, a tribunal held the company liable for its chatbot\'s incorrect statements. The precedent is set.',
    resilience: 'Kyde provides an unbroken chain of evidence from claim intake to automated decision. Every model call, every tool invocation, every data point considered — recorded, signed, and verifiable. Fleet management ensures claims agents operate within their authorized scope. When a claim is disputed, the evidence trail is your defense — and it\'s tamper-evident by design, not by policy.',
    regs: [
      'EU AI Act — High-Risk AI (Annex III, §5 Insurance)',
      'NIS-2 — Operational resilience for critical sector entities',
      'GDPR Art. 22 — Rights regarding automated decisions',
      'Solvency II — Governance and risk management requirements',
    ],
  },
  {
    n: '04',
    sector: 'Healthcare & MedTech',
    tag: 'Highest EU AI Act Risk Class',
    reality: 'AI in healthcare — clinical decision support, diagnostic tools, patient data processing — carries the highest EU AI Act risk classification. These agents interact with the most sensitive data that exists and make recommendations that affect human lives. "We can\'t access the logs" is not an acceptable answer to a regulator, an auditor, or a court.',
    resilience: 'Every AI-assisted clinical recommendation, every automated data retrieval, every patient interaction touching an LLM is governed with infrastructure-grade rigor. The causal chain — what the model was shown, what it returned, in what context — is preserved in a tamper-evident record. Role-based fleet management ensures clinical agents and administrative agents operate within distinct scopes. Your evidence trail is complete before any incident occurs.',
    regs: [
      'EU AI Act — High-Risk AI (Annex III, §5 Health and Safety)',
      'MDR / IVDR — Medical Device Regulation for AI-assisted diagnostics',
      'GDPR Art. 9 — Processing of special category health data',
      'NIS-2 — Critical health infrastructure requirements',
    ],
  },
  {
    n: '05',
    sector: 'Energy & Critical Infrastructure',
    tag: 'NIS-2 · KRITIS · EU AI Act',
    reality: 'Energy providers, grid operators, and their suppliers are critical infrastructure — by law and by function. AI agents managing load balancing, predictive maintenance, and operational decisions are invisible to most compliance teams until something goes wrong. At that point, the absence of a tamper-evident audit trail is both a regulatory and an operational crisis.\n\nThis is where Kyde started. We understand infrastructure because we come from infrastructure.',
    resilience: 'Kyde wraps every AI agent in your operational stack with a signed, hash-chained record. Fleet management gives every agent a scoped role — your grid-balancing agent and your reporting agent don\'t share permissions. Anomalous behavior and policy deviations are detectable against behavioral baselines. Incident reports to regulators are backed by verifiable, machine-generated evidence.\n\nFor defense-grade and CMMC-aligned environments, Kyde\'s architecture is built for hardware-rooted attestation. PKCS#11 and HSM signing on the roadmap. No re-architecture required.',
    regs: [
      'NIS-2 — Network and Information Security (in force December 2025)',
      'EU AI Act — High-Risk AI for critical infrastructure',
      'KRITIS regulation (Germany) — Critical infrastructure protection',
      'Cyber Resilience Act — Software security requirements',
    ],
  },
];
---

<Base
  title="Use Cases — KYDE"
  description="KYDE WITNESS provides infrastructure-grade fleet management for any organization running AI agents in production — regardless of sector, provider, or use case."
>
  <Navbar />

  <main>

    <!-- ══════════ HERO ══════════ -->
    <section class="relative overflow-hidden pt-36 pb-24 md:pt-48 md:pb-36">
      <div class="bg-grid absolute inset-0 pointer-events-none"></div>
      <div class="relative max-w-7xl mx-auto px-6">

        <div class="mb-10">
          <div class="flex items-center gap-3 mb-3">
            <span class="h-1.5 w-1.5 rounded-full bg-zinc-500 shrink-0"></span>
            <span class="font-mono text-xs uppercase tracking-[0.2em] text-amber-300">↳ Use Cases</span>
          </div>
          <div class="h-px w-full bg-zinc-800"></div>
        </div>

        <h1 class="hero-h1 max-w-5xl text-5xl text-white uppercase tracking-tight md:text-6xl lg:text-7xl">
          Every regulated industry deploys AI agents.<br />
          <span class="gradient-text">None of them are optional to govern.</span>
        </h1>

        <div class="mt-16 border-t border-zinc-800 pt-10 grid md:grid-cols-[200px_1fr] gap-8 items-start">
          <div>
            <p class="text-xs font-bold uppercase tracking-[0.15em] text-white">Coverage</p>
            <p class="mt-2 font-mono text-xs text-zinc-600">[ALL SECTORS]</p>
          </div>
          <div class="space-y-6">
            <p class="text-sm uppercase tracking-wide leading-relaxed text-zinc-400">
              KYDE WITNESS provides infrastructure-grade fleet management for any organization running AI agents in production — regardless of sector, provider, or use case.
            </p>
            <p class="text-sm uppercase tracking-wide leading-relaxed text-zinc-500">
              The <span class="font-mono text-zinc-200">EU AI Act</span>, <span class="font-mono text-zinc-200">NIS-2</span>, <span class="font-mono text-zinc-200">DORA</span>, and <span class="font-mono text-zinc-200">GDPR</span> don't care which LLM vendor you chose. They care whether you can prove what your agents did, explain why, and demonstrate that the record can't be tampered with.
            </p>
          </div>
        </div>

      </div>
    </section>

    <!-- ══════════ USE CASES ══════════ -->
    <section class="border-t border-zinc-800/60 py-16 md:py-24">
      <div class="max-w-7xl mx-auto px-6">

        <!-- Toggle -->
        <div class="flex gap-1 mb-10 border border-zinc-800 bg-zinc-900/60 p-1 w-fit">
          <button
            id="btn-industry"
            onclick="showTab('industry')"
            class="px-5 py-2 text-xs font-mono uppercase tracking-widest transition-all bg-white text-black"
          >By Industry</button>
          <button
            id="btn-role"
            onclick="showTab('role')"
            class="px-5 py-2 text-xs font-mono uppercase tracking-widest transition-all text-zinc-400 hover:text-white"
          >By Role</button>
        </div>

        <!-- BY INDUSTRY -->
        <div id="tab-industry" class="space-y-6">
        {cases.map(({ n, sector, tag, reality, resilience, regs }) => (
          <div class="rounded-sm border border-zinc-800 bg-zinc-900/40 hover:border-zinc-700 transition-all">

            <!-- Header -->
            <div class="flex flex-col sm:flex-row sm:items-center gap-4 border-b border-zinc-800 px-8 py-6">
              <span class="font-mono text-2xl font-bold text-zinc-700 shrink-0">{n}</span>
              <h2 class="flex-1 text-xl font-bold text-white">{sector}</h2>
              <span class="shrink-0 inline-flex items-center border border-amber-400/30 bg-amber-400/5 px-3 py-1 text-xs font-mono text-amber-300">
                {tag}
              </span>
            </div>

            <!-- Body -->
            <div class="grid gap-0 md:grid-cols-2 divide-y md:divide-y-0 md:divide-x divide-zinc-800">
              <div class="px-8 py-8">
                <p class="mb-4 text-xs font-semibold uppercase tracking-widest text-zinc-500">↳ The Operational Reality</p>
                {reality.split('\n\n').map((para: string) => (
                  <p class="text-sm leading-relaxed text-zinc-300 mb-3 last:mb-0">{para}</p>
                ))}
              </div>
              <div class="px-8 py-8">
                <p class="mb-4 text-xs font-semibold uppercase tracking-widest text-zinc-500">↳ How Kyde Builds Resilience</p>
                {resilience.split('\n\n').map((para: string) => (
                  <p class="text-sm leading-relaxed text-zinc-300 mb-3 last:mb-0">{para}</p>
                ))}
              </div>
            </div>

            <!-- Regs -->
            <div class="border-t border-zinc-800 px-8 py-5 flex flex-wrap gap-2">
              {regs.map((r: string) => (
                <span class="border border-zinc-800 bg-zinc-900/60 px-3 py-1 text-xs font-mono text-zinc-500">{r}</span>
              ))}
            </div>

          </div>
        ))}
        </div>

        <!-- BY ROLE -->
        <div id="tab-role" class="hidden grid gap-6 md:grid-cols-2">
          {[
            {
              role: "CISO",
              label: "Chief Information Security Officer",
              quote: "Your vendor's log isn't an independent record.",
              bullets: [
                "A tamper-evident record signed by Anthropic's keys, stored on Anthropic's infrastructure — is a vendor report. A compromised host can rewrite it silently. Kyde's records are cryptographically signed at the point of capture. Alter any entry — every subsequent link breaks.",
                "Your audit trail is yours. Not locked to a provider console, not dependent on vendor uptime, not subject to vendor retention policies.",
                "Audit standing that satisfies regulators, courts, and your own InfoSec review — built before an incident, not assembled after one.",
              ],
            },
            {
              role: "CTO",
              label: "Chief Technology Officer",
              quote: "Your governance layer shouldn't depend on your LLM choice.",
              bullets: [
                "One environment variable. No SDK dependency. No code changes. Full fleet coverage in minutes — your agents see no difference.",
                "Models change monthly. Add a local model for sensitive data, route cheap tasks to a cheaper provider, switch frontier models entirely. Governance follows automatically. No re-integration required.",
                "No per-agent installation. No framework lock-in. Architecture that outlasts your current LLM stack — by design.",
              ],
            },
            {
              role: "Compliance & Legal",
              label: "GC · DPO · CCO",
              quote: "One framework won't be enough. One evidence trail has to cover all of them.",
              bullets: [
                "EU AI Act High-Risk logging, NIS-2, DORA, GDPR Art. 35 — regulators don't coordinate their requirements around your roadmap. Kyde's tamper-evident trail satisfies all of them from day one.",
                "Verifiable audit exports on demand — complete, machine-generated, cryptographically signed. Not a screenshot. Not a filtered vendor report.",
                "Every challenged decision is reconstructable: what the agent was shown, what it decided, which sources it relied on. The record exists before the challenge arrives.",
              ],
            },
            {
              role: "CFO & Ops",
              label: "Chief Financial Officer · Operations",
              quote: "An agent with no budget ceiling is a liability with no ceiling.",
              bullets: [
                "Hard token and cost limits per agent, per role, per day. Enforced before the call is made — not flagged after the bill arrives.",
                "Governance shouldn't force you onto expensive frontier models for every task. Route classification and low-stakes workloads to cheap local models. Reserve frontier capacity for decisions that justify it.",
                "Priority assignment means your production agents never queue behind an intern's research bot. Fleet efficiency is a governance decision.",
              ],
            },
          ].map(({ role, label, quote, bullets }) => (
            <div class="rounded-sm border border-zinc-800 bg-zinc-900/40 hover:border-zinc-700 transition-all p-8">
              <div class="mb-6 pb-6 border-b border-zinc-800">
                <h2 class="font-mono text-2xl font-bold text-white">{role}</h2>
                <p class="mt-1 text-xs text-zinc-500 uppercase tracking-widest">{label}</p>
              </div>
              <p class="mb-6 font-mono text-sm text-zinc-300 border-l-2 border-amber-400/60 pl-4 leading-relaxed">"{quote}"</p>
              <ul class="space-y-4">
                {bullets.map((b: string) => (
                  <li class="flex gap-4 text-sm leading-relaxed text-zinc-400">
                    <span class="font-mono text-amber-400 shrink-0 mt-0.5">→</span>
                    <span>{b}</span>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>

      </div>
    </section>

    <script is:inline>
      function showTab(tab) {
        const industry = document.getElementById('tab-industry');
        const role = document.getElementById('tab-role');
        const btnIndustry = document.getElementById('btn-industry');
        const btnRole = document.getElementById('btn-role');
        if (tab === 'industry') {
          industry?.classList.remove('hidden');
          role?.classList.add('hidden');
          btnIndustry?.classList.add('bg-white', 'text-black');
          btnIndustry?.classList.remove('text-zinc-400');
          btnRole?.classList.remove('bg-white', 'text-black');
          btnRole?.classList.add('text-zinc-400');
        } else {
          role?.classList.remove('hidden');
          industry?.classList.add('hidden');
          btnRole?.classList.add('bg-white', 'text-black');
          btnRole?.classList.remove('text-zinc-400');
          btnIndustry?.classList.remove('bg-white', 'text-black');
          btnIndustry?.classList.add('text-zinc-400');
        }
      }
    </script>

    <!-- ══════════ CLOSING CTA ══════════ -->
    <section class="border-t border-zinc-800/60 py-24 md:py-32">
      <div class="max-w-7xl mx-auto px-6">
        <div class="border border-zinc-700 p-12 md:p-20">
          <div class="max-w-3xl">
            <p class="mb-3 font-mono text-xs uppercase tracking-[0.2em] text-amber-300">↳ Get started</p>
            <div class="mb-8 h-px bg-zinc-800"></div>
            <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-white mb-4">
              Your industry. Your agents.<br />Your critical infrastructure.
            </h2>
            <p class="text-lg text-zinc-400 mb-10">
              Kyde Witness works across every sector, every provider, every framework. Governance isn't the brake. It's what lets you accelerate.
            </p>
            <button
              onclick="openModal()"
              class="inline-flex items-center gap-2 bg-white px-6 py-3.5 text-sm font-semibold text-black hover:bg-zinc-200 transition-all"
            >
              Book a Sector-Specific Demo →
            </button>
          </div>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</Base>
