---
import Base from '../layouts/Base.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const cases = [
  {
    n: '01',
    sector: 'Financial Services & Banking',
    tag: 'DORA · BaFin · EU AI Act',
    scenario: 'A trading agent autonomously rebalances customer portfolios and accesses the trading API via an internal MCP server.',
    pillars: [
      { label: 'IDENTITY', q: 'Who acted?', text: 'No more shared trading_api_keys. The agent receives a cryptographic identity ("Wealth-Agent-Alpha"). When a trade executes, the core banking system knows exactly which agent acted — and can prove it.' },
      { label: 'CAUSAL CONTEXT', q: 'Why that decision?', text: 'The agent sells 1,000 Tesla shares. KYDE logs the context: the agent had just read a Reuters alert and the customer\'s 2024 risk profile PDF. The decision chain is immediately reconstructable for the advisor — and for BaFin.' },
      { label: 'SCOPE & BUDGET', q: 'What were the limits?', text: 'Hard limit: max 5% of portfolio value per day, no margin trading. KYDE blocks any API call that exceeds this firebreak in under 100ms — before it reaches the exchange.' },
      { label: 'TAMPER-EVIDENCE', q: 'What is the proof?', text: 'Every autonomous trade is Ed25519-signed in the ledger. When BaFin demands a review, the bank delivers a mathematical proof of action — not an editable server log.' },
    ],
    regs: ['DORA — Digital Operational Resilience Act', 'EU AI Act — Annex III §5 Credit Scoring', 'BaFin AI Guidance', 'GDPR Art. 35 — DPIA'],
  },
  {
    n: '02',
    sector: 'Industry & Supply Chain',
    tag: 'EU AI Act · NIS-2 · GDPR',
    scenario: 'A procurement agent monitors global supply chains and autonomously reorders raw materials in the ERP system when shortages are detected.',
    pillars: [
      { label: 'IDENTITY', q: 'Who acted?', text: 'The order is not triggered by an anonymous service account, but by a verified agent identity authorized exclusively for the steel procurement department.' },
      { label: 'CAUSAL CONTEXT', q: 'Why that decision?', text: 'The agent suddenly orders triple the usual steel quantity. KYDE logged that it had processed an internal email about a threatened port strike. The purchasing manager sees the reason immediately.' },
      { label: 'SCOPE & BUDGET', q: 'What were the limits?', text: 'Budget limit: max €50,000 per order. If the agent tries to place a €500,000 order due to a hallucination, the proxy rejects the request in under 100ms — before it reaches the supplier API.' },
      { label: 'TAMPER-EVIDENCE', q: 'What is the proof?', text: 'The complete negotiation trail with the supplier API and the final order amount are hash-chained. The CFO has court-admissible proof of every financial commitment the machine entered.' },
    ],
    regs: ['EU AI Act — High-Risk AI for automated procurement', 'NIS-2 — Critical supply chain infrastructure', 'GDPR Art. 35 — DPIA for large-scale processing'],
  },
  {
    n: '03',
    sector: 'Healthcare & Pharma',
    tag: 'EU AI Act · GDPR Art. 9 · HIPAA',
    scenario: 'A medical billing agent scans patient records, assigns ICD-10 diagnosis codes, and submits reimbursement claims to health insurers.',
    pillars: [
      { label: 'IDENTITY', q: 'Who acted?', text: 'The billing agent operates in strict isolation from the triage agent. Every access to the patient API is attributed to a specific machine identity — never a shared service account.' },
      { label: 'CAUSAL CONTEXT', q: 'Why that decision?', text: 'The agent bills for an expensive specialist treatment. KYDE records that it referenced Dr. Müller\'s clinical letter from 08:00. The causal chain is immediately verifiable in any audit or billing dispute.' },
      { label: 'SCOPE & BUDGET', q: 'What were the limits?', text: 'Strict API blocklists. The agent has role "Billing.Read". KYDE enforces that it can never write to clinical findings or delete medical data — scope is enforced at the proxy, not by trust.' },
      { label: 'TAMPER-EVIDENCE', q: 'What is the proof?', text: 'In a GDPR/HIPAA-critical environment, the tamper-evident audit trail guarantees hospitals can prove in any audit exactly which agent processed which patient data and when.' },
    ],
    regs: ['EU AI Act — Annex III §5 Health and Safety (highest risk class)', 'GDPR Art. 9 — Special category health data', 'MDR / IVDR — AI-assisted diagnostics', 'NIS-2 — Critical health infrastructure'],
  },
  {
    n: '04',
    sector: 'Insurance & Claims Automation',
    tag: 'EU AI Act · Solvency II · GDPR',
    scenario: 'A claims agent evaluates uploaded photos of water damage and authorizes payouts to policyholders — autonomously.',
    pillars: [
      { label: 'IDENTITY', q: 'Who acted?', text: 'Clear role boundaries. The claims agent does not have the same rights as the underwriting agent that calculates policy pricing. Separation is enforced by KYDE, not by policy documents.' },
      { label: 'CAUSAL CONTEXT', q: 'Why that decision?', text: 'The agent rejects a water damage claim. KYDE stores the last 5 prompts and tool calls: the agent had read the 2021 policy PDF in which elemental damage was explicitly excluded. The adjuster can explain the logic to the policyholder immediately.' },
      { label: 'SCOPE & BUDGET', q: 'What were the limits?', text: 'Hard limit: maximum automatic claims approval = €2,000. Anything above is blocked by the proxy and routed automatically to human escalation — a hard human-in-the-loop enforcement.' },
      { label: 'TAMPER-EVIDENCE', q: 'What is the proof?', text: 'When a fraud ring floods automated agents with fake images, the KYDE ledger proves immutably on what data basis the agent approved payment — essential for internal fraud investigators and regulators.' },
    ],
    regs: ['EU AI Act — High-Risk AI Annex III §5 Insurance', 'Solvency II — Governance and risk management', 'GDPR Art. 22 — Automated decision-making rights', 'NIS-2 — Operational resilience'],
  },
  {
    n: '05',
    sector: 'Energy & Critical Infrastructure',
    tag: 'NIS-2 · KRITIS · EU AI Act',
    scenario: 'A grid-balancing agent manages electricity procurement and activates local large-scale batteries to compensate for network fluctuations.',
    pillars: [
      { label: 'IDENTITY', q: 'Who acted?', text: 'In NIS-2 critical environments there is no anonymity. The dispatch agent has a signed identity whose priority is ranked above the internal HR bot — fleet management is operational, not bureaucratic.' },
      { label: 'CAUSAL CONTEXT', q: 'Why that decision?', text: 'The agent ramps up a local power plant. The KYDE log shows the cause: grid frequency dropped 0.1 Hz and the agent processed a local weather signal indicating a drop in solar production. Every grid action is explainable.' },
      { label: 'SCOPE & BUDGET', q: 'What were the limits?', text: 'Here, latency and blast radius control matter. KYDE limits API access precisely to the assigned substations. The agent cannot accidentally switch off the wrong grid segment — scope is enforced at the proxy layer.' },
      { label: 'TAMPER-EVIDENCE', q: 'What is the proof?', text: 'When an outage or grid instability occurs, federal authorities (e.g. Bundesnetzagentur) demand complete reports. Vendor cloud logs don\'t suffice. KYDE delivers the cryptographic ledger proving compliant grid management.' },
    ],
    regs: ['NIS-2 — Network and Information Security (in force December 2025)', 'EU AI Act — High-Risk AI for critical infrastructure', 'KRITIS — German critical infrastructure protection', 'Cyber Resilience Act'],
  },
];
---

<Base
  title="Use Cases — KYDE"
  description="KYDE WITNESS provides infrastructure-grade fleet management for any organization running AI agents in production — regardless of sector, provider, or use case."
>
  <Navbar />

  <main>

    <!-- ══════════ HERO ══════════ -->
    <section class="relative overflow-hidden pt-36 pb-24 md:pt-48 md:pb-36">
      <div class="bg-grid absolute inset-0 pointer-events-none"></div>
      <div class="relative max-w-7xl mx-auto px-6">

        <div class="mb-10">
          <div class="flex items-center gap-3 mb-3">
            <span class="h-1.5 w-1.5 rounded-full bg-zinc-500 shrink-0"></span>
            <span class="font-mono text-xs uppercase tracking-[0.2em] text-zinc-500">↳ Use Cases</span>
          </div>
          <div class="h-px w-full bg-zinc-800"></div>
        </div>

        <h1 class="hero-h1 max-w-5xl text-5xl text-white uppercase tracking-tight md:text-6xl lg:text-7xl">
          Every regulated industry deploys AI agents.<br />
          <span class="gradient-text">None of them are optional to govern.</span>
        </h1>

        <div class="mt-16 border-t border-white/40 pt-10 grid md:grid-cols-[200px_1fr] gap-8 items-start">
          <div>
            <p class="text-xs font-bold uppercase tracking-[0.15em] text-white">Coverage</p>
            <p class="mt-2 font-mono text-xs text-zinc-600">[ALL SECTORS]</p>
          </div>
          <div class="space-y-6">
            <p class="text-sm uppercase tracking-wide leading-relaxed text-zinc-400">
              KYDE WITNESS provides infrastructure-grade fleet management for any organization running AI agents in production — regardless of sector, provider, or use case.
            </p>
            <p class="text-sm uppercase tracking-wide leading-relaxed text-zinc-500">
              The <span class="font-mono text-zinc-200">EU AI Act</span>, <span class="font-mono text-zinc-200">NIS-2</span>, <span class="font-mono text-zinc-200">DORA</span>, and <span class="font-mono text-zinc-200">GDPR</span> don't care which LLM vendor you chose. They care whether you can prove what your agents did, explain why, and demonstrate that the record can't be tampered with.
            </p>
          </div>
        </div>

      </div>
    </section>

    <!-- ══════════ USE CASES ══════════ -->
    <section class="border-t border-white/40 py-16 md:py-24">
      <div class="max-w-7xl mx-auto px-6">

        <!-- Toggle -->
        <div class="flex gap-1 mb-10 border-b border-white/40 p-0 pb-0 w-fit gap-0">
          <button
            id="btn-industry"
            onclick="showTab('industry')"
            class="px-5 py-2 text-xs font-mono uppercase tracking-widest transition-all bg-white text-black"
          >By Industry</button>
          <button
            id="btn-role"
            onclick="showTab('role')"
            class="px-5 py-2 text-xs font-mono uppercase tracking-widest transition-all text-zinc-400 hover:text-white"
          >By Role</button>
        </div>

        <!-- BY INDUSTRY -->
        <div id="tab-industry" class="space-y-6">
        {cases.map(({ n, sector, tag, scenario, pillars, regs }) => (
          <div class="border-t border-b border-white/40 transition-all hover:bg-white/[0.02]">

            <!-- Header -->
            <div class="flex flex-col sm:flex-row sm:items-start gap-4 border-b border-white/40 px-6 sm:px-8 py-6">
              <span class="font-mono text-2xl font-bold text-zinc-700 shrink-0">{n}</span>
              <div class="flex-1">
                <h2 class="text-xl font-bold text-white mb-2">{sector}</h2>
                <p class="text-sm text-zinc-500 leading-relaxed">{scenario}</p>
              </div>
              <span class="shrink-0 inline-flex items-center border border-zinc-700 bg-transparent px-3 py-1 text-xs font-mono text-zinc-500 self-start">
                {tag}
              </span>
            </div>

            <!-- 4 Pillars -->
            <div class="divide-y divide-white/20">
              {pillars.map(({ label, q, text }) => (
                <div class="grid grid-cols-1 sm:grid-cols-[180px_1fr] gap-3 sm:gap-6 px-6 sm:px-8 py-5 border-l-2 border-l-zinc-700">
                  <div class="shrink-0">
                    <p class="font-mono text-xs font-bold uppercase tracking-widest text-zinc-400">{label}</p>
                    <p class="font-mono text-xs text-zinc-600 mt-0.5">{q}</p>
                  </div>
                  <p class="text-sm leading-relaxed text-zinc-300">{text}</p>
                </div>
              ))}
            </div>

            <!-- Regs -->
            <div class="border-t border-white/40 px-6 sm:px-8 py-5 flex flex-wrap gap-2">
              {regs.map((r: string) => (
                <span class="border border-white/20 px-3 py-1 text-xs font-mono text-zinc-500">{r}</span>
              ))}
            </div>

          </div>
        ))}
        </div>

        <!-- BY ROLE -->
        <div id="tab-role" class="hidden grid gap-6 md:grid-cols-2">
          {[
            {
              role: "CISO",
              label: "Chief Information Security Officer",
              quote: "Your vendor's log isn't an independent record.",
              bullets: [
                "A tamper-evident record signed by Anthropic's keys, stored on Anthropic's infrastructure — is a vendor report. A compromised host can rewrite it silently. Kyde's records are cryptographically signed at the point of capture. Alter any entry — every subsequent link breaks.",
                "Your audit trail is yours. Not locked to a provider console, not dependent on vendor uptime, not subject to vendor retention policies.",
                "Audit standing that satisfies regulators, courts, and your own InfoSec review — built before an incident, not assembled after one.",
              ],
            },
            {
              role: "CTO",
              label: "Chief Technology Officer",
              quote: "Your governance layer shouldn't depend on your LLM choice.",
              bullets: [
                "One environment variable. No SDK dependency. No code changes. Full fleet coverage in minutes — your agents see no difference.",
                "Models change monthly. Add a local model for sensitive data, route cheap tasks to a cheaper provider, switch frontier models entirely. Governance follows automatically. No re-integration required.",
                "No per-agent installation. No framework lock-in. Architecture that outlasts your current LLM stack — by design.",
              ],
            },
            {
              role: "Compliance & Legal",
              label: "GC · DPO · CCO",
              quote: "One framework won't be enough. One evidence trail has to cover all of them.",
              bullets: [
                "EU AI Act High-Risk logging, NIS-2, DORA, GDPR Art. 35 — regulators don't coordinate their requirements around your roadmap. Kyde's tamper-evident trail satisfies all of them from day one.",
                "Verifiable audit exports on demand — complete, machine-generated, cryptographically signed. Not a screenshot. Not a filtered vendor report.",
                "Every challenged decision is reconstructable: what the agent was shown, what it decided, which sources it relied on. The record exists before the challenge arrives.",
              ],
            },
            {
              role: "CFO & Ops",
              label: "Chief Financial Officer · Operations",
              quote: "An agent with no budget ceiling is a liability with no ceiling.",
              bullets: [
                "Hard token and cost limits per agent, per role, per day. Enforced before the call is made — not flagged after the bill arrives.",
                "Governance shouldn't force you onto expensive frontier models for every task. Route classification and low-stakes workloads to cheap local models. Reserve frontier capacity for decisions that justify it.",
                "Priority assignment means your production agents never queue behind an intern's research bot. Fleet efficiency is a governance decision.",
              ],
            },
          ].map(({ role, label, quote, bullets }) => (
            <div class="rounded-sm border-t border-b border-white/40 transition-all hover:bg-white/[0.02] p-8">
              <div class="mb-6 pb-6 border-b border-white/40">
                <h2 class="font-mono text-2xl font-bold text-white">{role}</h2>
                <p class="mt-1 text-xs text-zinc-500 uppercase tracking-widest">{label}</p>
              </div>
              <p class="mb-6 font-mono text-sm text-zinc-300 border-l-2 border-zinc-600/60 pl-4 leading-relaxed">"{quote}"</p>
              <ul class="space-y-4">
                {bullets.map((b: string) => (
                  <li class="flex gap-4 text-sm leading-relaxed text-zinc-400">
                    <span class="font-mono text-zinc-500 shrink-0 mt-0.5">→</span>
                    <span>{b}</span>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>

      </div>
    </section>

    <script is:inline>
      function showTab(tab) {
        const industry = document.getElementById('tab-industry');
        const role = document.getElementById('tab-role');
        const btnIndustry = document.getElementById('btn-industry');
        const btnRole = document.getElementById('btn-role');
        if (tab === 'industry') {
          industry?.classList.remove('hidden');
          role?.classList.add('hidden');
          btnIndustry?.classList.add('bg-white', 'text-black');
          btnIndustry?.classList.remove('text-zinc-400');
          btnRole?.classList.remove('bg-white', 'text-black');
          btnRole?.classList.add('text-zinc-400');
        } else {
          role?.classList.remove('hidden');
          industry?.classList.add('hidden');
          btnRole?.classList.add('bg-white', 'text-black');
          btnRole?.classList.remove('text-zinc-400');
          btnIndustry?.classList.remove('bg-white', 'text-black');
          btnIndustry?.classList.add('text-zinc-400');
        }
      }
    </script>

    <!-- ══════════ CLOSING CTA ══════════ -->
    <section class="border-t border-white/40 py-24 md:py-32">
      <div class="max-w-7xl mx-auto px-6">
        <div class="border-t border-b border-white/40 p-12 md:p-20">
          <div class="max-w-3xl">
            <p class="mb-3 font-mono text-xs uppercase tracking-[0.2em] text-zinc-500">↳ Get started</p>
            <div class="mb-8 h-px bg-white/40"></div>
            <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-white mb-4">
              Your industry. Your agents.<br />Your critical infrastructure.
            </h2>
            <p class="text-lg text-zinc-400 mb-10">
              Kyde Witness works across every sector, every provider, every framework. Governance isn't the brake. It's what lets you accelerate.
            </p>
            <button
              onclick="openModal()"
              class="inline-flex items-center gap-2 bg-white px-6 py-3.5 text-sm font-semibold text-black hover:bg-zinc-200 transition-all"
            >
              Book a Sector-Specific Demo →
            </button>
          </div>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</Base>
