---
import Base from "../layouts/Base.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import ArchitectureDiagram from "../components/ArchitectureDiagram.astro";
---

<Base
    title="KYDE — Infrastructure-grade fleet management for AI agents."
    description="Your AI agents aren't software. They're an autonomous workforce. Kyde provides fleet management built on a cryptographic root of trust — identity, roles, budgets, and tamper-evident accountability for every agent."
>
    <Navbar />

    <main>
        <!-- ══════════ HERO ══════════ -->
        <section class="relative overflow-hidden pt-36 pb-24 md:pt-48 md:pb-36">
            <div class="bg-grid absolute inset-0 pointer-events-none"></div>

            <div class="relative max-w-7xl mx-auto px-6">
                <!-- label + rule -->
                <div class="mb-10">
                    <div class="flex items-center gap-3 mb-3">
                        <span class="h-1.5 w-1.5 rounded-full bg-zinc-500 shrink-0"></span>
                        <span class="font-mono text-xs uppercase tracking-[0.2em] text-zinc-500">↳ Kyde Witness — Agent Fleet Management</span>
                    </div>
                    <div class="h-px w-full bg-zinc-800"></div>
                </div>

                <!-- Headline -->
                <h1 class="hero-h1 max-w-5xl text-6xl text-white uppercase tracking-tight my-12 md:text-7xl lg:text-8xl">
                    Infrastructure-grade<br />fleet management<br />
                    <span class="gradient-text">for AI agents.</span>
                </h1>

                <!-- two-col metadata -->
                <div class="mt-16 border-t border-zinc-800 pt-10 grid md:grid-cols-[200px_1fr] gap-8 items-start">
                    <div>
                        <p class="text-xs font-bold uppercase tracking-[0.15em] text-white">
                            Governance Proxy
                        </p>
                        <p class="mt-2 font-mono text-xs text-zinc-600">[KYDE WITNESS]</p>
                    </div>
                    <div class="space-y-10">
                        <!-- Subline -->
                        <p class="text-sm uppercase tracking-wide leading-relaxed text-zinc-400">
                            Your AI agents aren't software. They're an autonomous workforce — reasoning, deciding, executing across your production systems. And like any workforce, they need roles, boundaries, supervision, and accountability.
                        </p>

                        <!-- Terminal -->
                        <div class="rounded-sm border border-zinc-800 bg-zinc-900/80">
                            <div class="flex items-center gap-2 border-b border-zinc-700 px-4 py-3">
                                <span class="h-3 w-3 rounded-full bg-red-400/60"></span>
                                <span class="h-3 w-3 rounded-full bg-amber-400/60"></span>
                                <span class="h-3 w-3 rounded-full bg-emerald-400/60"></span>
                                <span class="ml-2 text-xs text-zinc-500 font-mono">terminal</span>
                            </div>
                            <div class="p-5 font-mono text-sm leading-relaxed">
                                <p class="text-zinc-400">
                                    <span class="text-emerald-400">$</span>
                                    <span class="text-zinc-200"> export OPENAI_BASE_URL=https://witness.intranet/v1</span>
                                </p>
                                <p class="mt-1 text-zinc-400">
                                    <span class="text-emerald-400">$</span>
                                    <span class="text-zinc-200"> witness fleet init</span>
                                </p>
                                <p class="mt-1 text-cyan-400">&#10003; Fleet proxy started on :8080</p>
                                <p class="text-cyan-400">&#10003; Agent identities provisioned</p>
                                <p class="text-cyan-400">&#10003; Role boundaries enforced</p>
                                <p class="text-cyan-400">&#10003; Tamper-evident ledger initialized</p>
                                <p class="mt-2 text-zinc-400">
                                    <span class="text-emerald-400">$</span>
                                    <span class="text-zinc-200"> witness fleet status</span>
                                </p>
                                <p class="mt-1 text-emerald-400">&#10003; 12 agents active — all scoped, signed, accountable</p>
                            </div>
                        </div>

                        <!-- Trust markers -->
                        <div class="flex flex-wrap gap-x-8 gap-y-2 font-mono text-xs uppercase tracking-widest text-zinc-500">
                            <span>Ed25519 Signed</span>
                            <span>SHA-256 Hash-Chained</span>
                            <span>&lt;100ms Latency</span>
                            <span>Provider-Agnostic</span>
                        </div>

                        <!-- CTAs -->
                        <div class="flex flex-col sm:flex-row items-start gap-4">
                            <button
                                onclick="openModal()"
                                class="inline-flex items-center gap-2 bg-white px-6 py-3.5 text-sm font-semibold text-black hover:bg-zinc-200 transition-all"
                            >
                                Book Demo →
                            </button>
                            <a
                                href="https://github.com/kydehq"
                                target="_blank"
                                rel="noopener noreferrer"
                                class="inline-flex items-center gap-2 border border-zinc-700 px-6 py-3.5 text-sm font-semibold text-zinc-300 hover:border-zinc-500 hover:text-white transition-all"
                            >
                                View on GitHub
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- ══════════ MINDSET SHIFT ══════════ -->
        <section class="relative border-t border-zinc-800/60 py-24 md:py-32">
            <div class="relative max-w-7xl mx-auto px-6">
                <div class="mb-12">
                    <div class="flex items-center gap-3 mb-3">
                        <span class="h-1.5 w-1.5 rounded-full bg-zinc-600 shrink-0"></span>
                        <span class="font-mono text-xs uppercase tracking-[0.2em] text-zinc-500">↳ The paradigm shift</span>
                    </div>
                    <div class="h-px w-full bg-zinc-800"></div>
                </div>

                <div class="grid md:grid-cols-2 gap-16 items-start">
                    <div>
                        <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight text-white">
                            Stop installing agents.<br />Start managing them.
                        </h2>
                    </div>
                    <div class="space-y-6">
                        <p class="text-zinc-300 leading-relaxed">
                            Traditional software gets deployed and configured. AI agents get hired. They negotiate with customers, move money, access personnel data, and make decisions that bind your organization. The deployment model that worked for SaaS doesn't work for a workforce that acts autonomously.
                        </p>
                        <p class="text-zinc-400 leading-relaxed">
                            Every agent needs an identity. A role. A scope of authority. A budget. Escalation rules. And a tamper-evident record of everything it does. Not because compliance demands it — but because operational resilience requires it.
                        </p>
                        <div class="border-l-2 border-amber-400/60 pl-4">
                            <p class="font-mono text-sm text-zinc-300 leading-relaxed">
                                Governance isn't the brake.<br />
                                <span class="text-white">It's what lets you accelerate.</span>
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- ══════════ PROBLEM ══════════ -->
        <section class="relative border-t border-zinc-800/60 py-24 md:py-32">
            <div class="relative max-w-7xl mx-auto px-6">
                <div class="max-w-3xl mx-auto text-center mb-16">
                    <p class="mb-3 font-mono text-xs uppercase tracking-[0.2em] text-zinc-500">↳ The operational gap</p>
                    <div class="mb-6 h-px bg-zinc-800"></div>
                    <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight text-white">
                        Four questions most enterprises can't answer.
                    </h2>
                </div>

                <div class="grid gap-6 md:grid-cols-2">
                    {[
                        {
                            q: "Who acted?",
                            body: "Agents share service accounts with broad permissions. No traceable identity. No role boundaries. A support agent authorized for €500 refunds issues €5,000 because nobody scoped its authority.",
                            label: "Identity",
                        },
                        {
                            q: "Why did it decide that?",
                            body: "An HR agent retrieves a policy document from 2022 and uses it to guide a termination. The current policy says something different. Nobody logged which source it relied on.",
                            label: "Causal Context",
                        },
                        {
                            q: "What are the boundaries?",
                            body: "Token budgets don't exist. API access is unrestricted. An intern's research agent burns through your entire monthly token allocation while your production agents queue.",
                            label: "Scope & Budget",
                        },
                        {
                            q: "What happened?",
                            body: "A procurement agent posts confidential contract terms in Slack. Leadership needs the full evidence trail. The logs are vendor-provided, self-reported, software-only. A compromised host can rewrite them silently.",
                            label: "Tamper-Evidence",
                        },
                    ].map(({ q, body, label }) => (
                        <div class="rounded-sm border border-zinc-800 bg-zinc-900/50 p-8 hover:bg-zinc-800/50 transition-all">
                            <div class="mb-4 flex items-center justify-between">
                                <span class="font-mono text-xs uppercase tracking-widest text-zinc-500">{label}</span>
                                <span class="h-1.5 w-1.5 rounded-full bg-red-400/60"></span>
                            </div>
                            <h3 class="mb-4 text-xl font-bold text-white">{q}</h3>
                            <p class="leading-relaxed text-zinc-400 text-sm">{body}</p>
                        </div>
                    ))}
                </div>

                <div class="mt-12 border border-zinc-800 bg-zinc-900/30 px-12 py-24 text-center">
                    <p class="text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight text-white mx-auto leading-tight">
                        Resilient organizations don't just detect these failures.<br />They architect systems that prevent them.
                    </p>
                </div>
            </div>
        </section>

        <!-- ══════════ PRODUCT ══════════ -->
        <section class="relative border-t border-zinc-800/60 py-24 md:py-32">
            <div class="relative max-w-7xl mx-auto px-6">
                <div class="mb-16">
                    <div class="flex items-center gap-3 mb-3">
                        <span class="h-1.5 w-1.5 rounded-full bg-zinc-600 shrink-0"></span>
                        <span class="font-mono text-xs uppercase tracking-[0.2em] text-zinc-500">↳ Kyde Witness</span>
                    </div>
                    <div class="h-px w-full bg-zinc-800"></div>
                </div>

                <div class="grid md:grid-cols-2 gap-16 items-start mb-16">
                    <div>
                        <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-white mb-6">
                            Manage your agents like critical infrastructure.
                        </h2>
                        <p class="text-zinc-400 leading-relaxed">
                            Kyde Witness is the governance proxy that sits between your agents and any LLM provider. One deployment point. Every agent covered. Full operational control.
                        </p>
                    </div>
                    <div class="font-mono text-sm border border-zinc-800 bg-zinc-900/40 p-6">
                        <p class="text-zinc-500 mb-1">$ <span class="text-zinc-200">witness fleet status --verbose</span></p>
                        <p class="text-emerald-400 mt-2">&#10003; sales_bot_prod     [ACTIVE]  scope: crm.* budget: €200/day</p>
                        <p class="text-emerald-400">&#10003; hr_agent_v2        [ACTIVE]  scope: hr.read budget: 50k tok/day</p>
                        <p class="text-emerald-400">&#10003; procurement_agent  [ACTIVE]  scope: po.create &lt;€10k</p>
                        <p class="text-zinc-500">  intern_research    [CAPPED]  budget exhausted — queued</p>
                        <p class="mt-3 text-zinc-600">4 agents | 3 active | 1 capped | 0 violations</p>
                    </div>
                </div>

                <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
                    {[
                        {
                            title: "Identity & Fleet Management",
                            body: "Every agent gets a distinct identity, a role, and a scope. Assign priorities — your production infrastructure agent takes precedence over your intern's research bot. Set token and cost budgets per role. Define which API endpoints each agent is permitted to reach.",
                            tag: "Core",
                        },
                        {
                            title: "Cryptographic Root of Trust",
                            body: "Every agent action is Ed25519-signed and SHA-256 hash-chained to the previous entry. Alter any record — every subsequent link breaks. This is not a log. It's a tamper-evident chain of evidence.",
                            tag: "Security",
                        },
                        {
                            title: "Causal Context",
                            body: "Kyde captures not just what the agent did, but why — logging the last five messages before every tool call. When something goes wrong, you can reconstruct the full decision chain.",
                            tag: "Audit",
                        },
                        {
                            title: "Zero-Friction Deployment",
                            body: "One environment variable. One Group Policy push. No code changes. No SDK integration. The agent sees no difference. Latency under 100ms.",
                            tag: "Ops",
                        },
                    ].map(({ title, body, tag }) => (
                        <div class="rounded-sm border border-zinc-800 bg-zinc-900/50 p-6 hover:bg-zinc-800/50 transition-all">
                            <div class="mb-4 flex items-center justify-between">
                                <span class="font-mono text-xs uppercase tracking-widest text-zinc-500">{tag}</span>
                            </div>
                            <h3 class="mb-3 text-base font-semibold text-white">{title}</h3>
                            <p class="text-sm leading-relaxed text-zinc-400">{body}</p>
                        </div>
                    ))}
                </div>

                <!-- Ledger entry -->
                <div class="mx-auto mt-16 max-w-3xl">
                    <h3 class="mb-6 text-center text-lg font-semibold text-white">
                        Every agent action produces a tamper-evident entry
                    </h3>
                    <div class="rounded-sm border border-zinc-800 bg-zinc-900">
                        <div class="flex items-center gap-2 border-b border-zinc-800 px-4 py-3">
                            <span class="h-2 w-2 rounded-full bg-zinc-600"></span>
                            <span class="h-2 w-2 rounded-full bg-zinc-600"></span>
                            <span class="h-2 w-2 rounded-full bg-zinc-600"></span>
                            <span class="ml-2 text-xs text-zinc-500 font-mono">audit_entry.json</span>
                        </div>
                        <pre class="overflow-x-auto p-5 font-mono text-xs leading-relaxed text-zinc-400"><code>{`{
  `}<span class="text-zinc-200">"entry_id"</span>{`: `}<span class="text-zinc-500">"e_7f3a2b1c"</span>{`,
  `}<span class="text-zinc-200">"agent_id"</span>{`: `}<span class="text-zinc-500">"sales_bot_prod"</span>{`,
  `}<span class="text-zinc-200">"role"</span>{`: `}<span class="text-zinc-500">"sales_agent"</span>{`,
  `}<span class="text-zinc-200">"scope"</span>{`: `}<span class="text-zinc-500">"crm.* | refund.max=500"</span>{`,
  `}<span class="text-zinc-200">"action"</span>{`: `}<span class="text-zinc-500">"chat.completion"</span>{`,
  `}<span class="text-zinc-200">"tool_calls"</span>{`: [`}<span class="text-zinc-500">"crm.update_deal"</span>{`, `}<span class="text-zinc-500">"slack.send_message"</span>{`],
  `}<span class="text-zinc-200">"causal_context"</span>{`: `}<span class="text-zinc-500">"[last 5 messages]"</span>{`,
  `}<span class="text-zinc-200">"entry_hash"</span>{`: `}<span class="text-zinc-500">"sha256:7b2e4d..."</span>{`,
  `}<span class="text-zinc-200">"prev_hash"</span>{`: `}<span class="text-zinc-500">"sha256:1c3f8a..."</span>{`,
  `}<span class="text-zinc-200">"signature"</span>{`: `}<span class="text-zinc-500">"ed25519:Mk3nR9..."</span>{`
}`}</code></pre>
                    </div>
                </div>
            </div>
        </section>

        <!-- ══════════ ARCHITECTURE DIAGRAM ══════════ -->
        <ArchitectureDiagram />

        <!-- ══════════ ROOT OF TRUST ══════════ -->
        <section class="relative border-t border-zinc-800/60 py-24 md:py-32">
            <div class="relative max-w-7xl mx-auto px-6">

                <div class="mb-12">
                    <div class="flex items-center gap-3 mb-3">
                        <span class="h-1.5 w-1.5 rounded-full bg-zinc-600 shrink-0"></span>
                        <span class="font-mono text-xs uppercase tracking-[0.2em] text-zinc-500">↳ Tamper-evident by architecture</span>
                    </div>
                    <div class="h-px w-full bg-zinc-800"></div>
                </div>

                <div class="grid md:grid-cols-2 gap-16 items-start">
                    <div>
                        <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-white mb-6">
                            Software logs can be rewritten.<br />Kyde's records can't.
                        </h2>
                        <p class="text-zinc-400 leading-relaxed mb-6">
                            Vendor-provided audit logs are self-reported. They live on infrastructure the vendor controls. A compromised host OS can alter them silently.
                        </p>
                        <p class="text-zinc-400 leading-relaxed mb-6">
                            Kyde Witness is architecturally different. Every entry is cryptographically signed at the point of capture and hash-chained to every entry before it. The record is immutable by design — not by policy.
                        </p>
                        <p class="text-zinc-400 leading-relaxed mb-10">
                            For the highest-stakes environments, Kyde's architecture is built for hardware-rooted attestation from day one. PKCS#11 and HSM signing on the roadmap. No re-architecture required.
                        </p>
                        <p class="font-mono text-sm text-zinc-300 border-l-2 border-amber-400/60 pl-4 leading-relaxed">
                            The same root of trust that satisfies defense-grade requirements satisfies your EU AI Act audit trail. One architecture. Every threat level.
                        </p>
                    </div>

                    <div>
                        <div class="border border-zinc-800 bg-zinc-900/40 p-8 mb-6">
                            <div class="font-mono text-sm text-zinc-400 flex items-center gap-3 flex-wrap">
                                <span class="text-zinc-300">[HSM / TPM]</span>
                                <span class="text-zinc-700">→</span>
                                <span class="text-zinc-300">[Witness Proxy]</span>
                                <span class="text-zinc-700">→</span>
                                <span class="text-zinc-300">[Ledger]</span>
                                <span class="text-zinc-700">→</span>
                                <span class="text-amber-300">[Court]</span>
                            </div>
                        </div>

                        <div class="space-y-3">
                            {[
                                { label: "PKCS#11 / HSM Compatible", desc: "Signing keys isolated in hardware — never exposed to the host OS.", status: "ROADMAP" },
                                { label: "FIPS 140-3 Ready", desc: "Architecture designed for FIPS-validated cryptographic modules.", status: "ROADMAP" },
                                { label: "Ed25519 + SHA-256 Hash Chain", desc: "Cryptographic immutability at the point of capture — available now.", status: "LIVE" },
                            ].map(({ label, desc, status }) => (
                                <div class="border border-zinc-800 bg-zinc-900/20 p-4 flex items-start justify-between gap-4">
                                    <div>
                                        <p class="font-mono text-xs font-semibold tracking-widest text-white uppercase mb-1">{label}</p>
                                        <p class="text-xs text-zinc-600 leading-relaxed">{desc}</p>
                                    </div>
                                    <span class={`font-mono text-[10px] tracking-widest border px-2 py-0.5 shrink-0 ${status === "LIVE" ? "text-emerald-400 border-emerald-900" : "text-zinc-700 border-zinc-800"}`}>{status}</span>
                                </div>
                            ))}
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- ══════════ PHASES ══════════ -->
        <section class="relative border-t border-zinc-800/60 py-24 md:py-32">
            <div class="max-w-7xl mx-auto px-6">
                <div class="max-w-3xl mx-auto text-center mb-16">
                    <p class="mb-3 font-mono text-xs uppercase tracking-[0.2em] text-zinc-500">↳ The product</p>
                    <div class="mb-6 h-px bg-zinc-800"></div>
                    <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight text-white">
                        From visibility to resilience.
                    </h2>
                    <p class="mt-4 text-lg text-zinc-400">
                        Operational resilience isn't about avoiding risk. It's about building systems that keep working when things go wrong — and proving that they did. Kyde grows with your agent fleet.
                    </p>
                </div>

                <div class="mt-16 grid gap-8 lg:grid-cols-3">
                    <!-- OBSERVE -->
                    <div class="relative rounded-sm border border-zinc-800 bg-zinc-900/60 p-8 hover:bg-zinc-800/60 transition-all">
                        <div class="mb-6 flex items-center justify-between">
                            <span class="text-xs font-semibold uppercase tracking-widest text-zinc-500">Phase 1</span>
                            <span class="inline-flex items-center gap-1.5 border border-zinc-700 px-3 py-1 text-xs font-mono text-zinc-400">
                                Available Now
                            </span>
                        </div>
                        <h3 class="mb-1 font-mono text-2xl font-bold text-white">OBSERVE</h3>
                        <p class="mb-2 text-sm font-medium text-amber-400">See everything.</p>
                        <p class="mb-6 text-sm leading-relaxed text-zinc-400">
                            You can't govern what you can't see.
                        </p>
                        <ul class="space-y-4">
                            <li>
                                <h4 class="text-sm font-semibold text-zinc-100">Traceable Identity</h4>
                                <p class="mt-0.5 text-sm leading-relaxed text-zinc-400">Every agent gets a distinct identity. Every action is attributed to a specific agent, not a shared service account.</p>
                            </li>
                            <li>
                                <h4 class="text-sm font-semibold text-zinc-100">Tamper-Evident Ledger</h4>
                                <p class="mt-0.5 text-sm leading-relaxed text-zinc-400">Ed25519-signed and SHA-256 hash-chained append-only log. Tamper with any entry — every subsequent link breaks.</p>
                            </li>
                            <li>
                                <h4 class="text-sm font-semibold text-zinc-100">Causal Context</h4>
                                <p class="mt-0.5 text-sm leading-relaxed text-zinc-400">Not just what happened, but why — capturing the last 5 messages before every tool call.</p>
                            </li>
                            <li>
                                <h4 class="text-sm font-semibold text-zinc-100">Zero Friction Deployment</h4>
                                <p class="mt-0.5 text-sm leading-relaxed text-zinc-400">One environment variable or one Group Policy push. No developer code required.</p>
                            </li>
                        </ul>
                    </div>

                    <!-- GOVERN -->
                    <div class="relative rounded-sm border border-zinc-700 bg-zinc-900/60 p-8 hover:bg-zinc-800/60 transition-all">
                        <div class="mb-6 flex items-center justify-between">
                            <span class="text-xs font-semibold uppercase tracking-widest text-zinc-500">Phase 2</span>
                            <span class="inline-flex items-center gap-1.5 border border-zinc-600 px-3 py-1 text-xs font-mono text-zinc-300">
                                Coming Soon
                            </span>
                        </div>
                        <h3 class="mb-1 font-mono text-2xl font-bold text-white">GOVERN</h3>
                        <p class="mb-2 text-sm font-medium text-amber-400">Control the fleet.</p>
                        <p class="mb-6 text-sm leading-relaxed text-zinc-400">
                            Fleet management with teeth.
                        </p>
                        <ul class="space-y-4">
                            <li>
                                <h4 class="text-sm font-semibold text-zinc-100">Role-Based Identity & Priority</h4>
                                <p class="mt-0.5 text-sm leading-relaxed text-zinc-400">Your production infrastructure agent takes precedence over your intern's research bot.</p>
                            </li>
                            <li>
                                <h4 class="text-sm font-semibold text-zinc-100">Token & Cost Budgets</h4>
                                <p class="mt-0.5 text-sm leading-relaxed text-zinc-400">Per-agent and per-role budget envelopes. Your intern's agent doesn't starve your infrastructure agent.</p>
                            </li>
                            <li>
                                <h4 class="text-sm font-semibold text-zinc-100">API Allowlists & Blocklists</h4>
                                <p class="mt-0.5 text-sm leading-relaxed text-zinc-400">Define which API endpoints each agent is permitted to reach. Enforce without touching agent code.</p>
                            </li>
                            <li>
                                <h4 class="text-sm font-semibold text-zinc-100">Anomaly Detection</h4>
                                <p class="mt-0.5 text-sm leading-relaxed text-zinc-400">Behavioral baselines per agent role. Real-time alerts on deviation.</p>
                            </li>
                        </ul>
                    </div>

                    <!-- DELEGATE -->
                    <div class="relative rounded-sm border border-zinc-800 bg-zinc-900/60 p-8 hover:bg-zinc-800/60 transition-all">
                        <div class="mb-6 flex items-center justify-between">
                            <span class="text-xs font-semibold uppercase tracking-widest text-zinc-500">Phase 3</span>
                            <span class="inline-flex items-center gap-1.5 border border-zinc-700 px-3 py-1 text-xs font-mono text-zinc-500">
                                Roadmap 2027
                            </span>
                        </div>
