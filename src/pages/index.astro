---
import Base from "../layouts/Base.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import ArchitectureDiagram from "../components/ArchitectureDiagram.astro";
---

<Base
    title="KYDE — Governance Tor The Agentic Economy"
    description="AI agents act autonomously across your enterprise — no audit trail, no accountability. Kyde Witness creates the tamper-evident record regulators require. EU AI Act enforcement: August 2, 2026."
>
    <Navbar />

    <main>
        <!-- ══════════ HERO ══════════ -->
        <section class="relative overflow-hidden pt-36 pb-24 md:pt-48 md:pb-36">
            <div class="bg-grid absolute inset-0 pointer-events-none"></div>

            <div class="relative max-w-7xl mx-auto px-6">
                <!-- ↳ label + rule -->
                <div class="mb-10">
                    <div class="flex items-center gap-3 mb-3">
                        <span
                            class="h-1.5 w-1.5 rounded-full bg-amber-400/60 animate-pulse shrink-0"
                        ></span>
                        <span
                            class="font-mono text-xs uppercase tracking-[0.2em] text-amber-300"
                            >↳ EU AI Act Enforcement — August 2, 2026</span
                        >
                    </div>
                    <div class="h-px w-full bg-zinc-800"></div>
                </div>

                <!-- Headline -->
                <h1
                    class="hero-h1 max-w-5xl text-6xl text-white md:text-8xl lg:text-9xl"
                >
                    Governance <br />For The
                    <span class="gradient-text"> Agentic Economy</span>
                </h1>

                <!-- Anduril-style two-col metadata -->
                <div
                    class="mt-12 border-t border-zinc-800 pt-8 grid md:grid-cols-[200px_1fr] gap-8 items-start"
                >
                    <div>
                        <p
                            class="text-xs font-bold uppercase tracking-[0.15em] text-white"
                        >
                            Governance Proxy
                        </p>
                        <p class="mt-2 font-mono text-xs text-zinc-600">
                            [KYDE WITNESS]
                        </p>
                    </div>
                    <div>
                        <p
                            class="text-sm uppercase tracking-wide leading-relaxed text-zinc-400"
                        >
                            AI agents act autonomously across your enterprise — calling APIs, reading data, making decisions. No audit trail. No accountability. Kyde Witness creates the tamper-evident record regulators require. EU AI Act enforcement: August 2, 2026.
                        </p>
                        <div
                            class="mt-8 flex flex-col sm:flex-row items-start gap-4"
                        >
                            <button
                                onclick="openModal()"
                                class="inline-flex items-center gap-2 bg-white px-6 py-3.5 text-sm font-semibold text-black hover:bg-zinc-200 transition-all"
                            >
                                Book Compliance Demo →
                            </button>
                            <a
                                href="/platform"
                                class="inline-flex items-center gap-2 border border-zinc-700 px-6 py-3.5 text-sm font-semibold text-zinc-300 hover:border-zinc-500 hover:text-white transition-all"
                            >
                                Explore Platform
                            </a>
                        </div>
                    </div>
                </div>

                <!-- Terminal -->
                <div class="mt-16 max-w-2xl">
                    <div
                        class="rounded-sm border border-zinc-800 bg-zinc-900/80"
                    >
                        <div
                            class="flex items-center gap-2 border-b border-zinc-700 px-4 py-3"
                        >
                            <span class="h-3 w-3 rounded-full bg-red-400/60"
                            ></span>
                            <span class="h-3 w-3 rounded-full bg-amber-400/60"
                            ></span>
                            <span class="h-3 w-3 rounded-full bg-emerald-400/60"
                            ></span>
                            <span class="ml-2 text-xs text-zinc-500 font-mono"
                                >terminal</span
                            >
                        </div>
                        <div class="p-5 font-mono text-sm leading-relaxed">
                            <p class="text-zinc-400">
                                <span class="text-emerald-400">$</span>
                                <span class="text-zinc-200"
                                    >export
                                    OPENAI_BASE_URL=https://witness.intranet/v1</span
                                >
                            </p>
                            <p class="mt-1 text-zinc-400">
                                <span class="text-emerald-400">$</span>
                                <span class="text-zinc-200">witness init</span>
                            </p>
                            <p class="mt-1 text-cyan-400">
                                &#10003; Proxy started on :8080
                            </p>
                            <p class="text-cyan-400">
                                &#10003; Ed25519 keypair generated
                            </p>
                            <p class="text-cyan-400">
                                &#10003; Append-only database initialized
                            </p>
                            <p class="mt-2 text-zinc-400">
                                <span class="text-emerald-400">$</span>
                                <span class="text-zinc-200">witness verify</span
                                >
                            </p>
                            <p class="mt-1 text-emerald-400">
                                &#10003; Data integrity verified — 0 entries, 0
                                anomalies
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Trust markers — Anduril-style inline list -->
                <div
                    class="mt-8 flex flex-wrap gap-x-8 gap-y-2 font-mono text-xs uppercase tracking-widest text-zinc-400"
                >
                    <span>Ed25519 Signed</span>
                    <span>SHA-256 Hash-Chained</span>
                    <span>&lt;100ms Latency</span>
                    <span>Provider-Agnostic</span>
                </div>
            </div>
        </section>

        <!-- ══════════ PROBLEM ══════════ -->
        <section class="relative border-t border-zinc-800/60 py-24 md:py-32">
            <div class="relative max-w-7xl mx-auto px-6">
                <div class="max-w-3xl mx-auto text-center">
                    <p
                        class="mb-3 font-mono text-xs uppercase tracking-[0.2em] text-zinc-500"
                    >
                        ↳ The compliance gap
                    </p>
                    <div class="mb-6 h-px bg-zinc-800"></div>
                    <h2
                        class="text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight text-white"
                    >
                        Regulators now require verifiable audit trails for AI
                        systems.
                    </h2>
                    <p class="mt-4 text-lg text-zinc-300">
                        Most enterprises have neither the visibility nor the
                        tamper-evidence to comply.
                    </p>
                </div>

                <div class="mt-16 grid gap-6 md:grid-cols-3">
                    <div
                        class="rounded-sm border border-zinc-800 bg-zinc-900/50 p-8 hover:bg-zinc-800/50 transition-all"
                    >
                        <div
                            class="mb-5 inline-flex rounded-sm bg-zinc-800 p-3 text-zinc-400"
                        >
                            <svg
                                class="h-6 w-6"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                                stroke-width="1.5"
                            >
                                <path
                                    d="M3.98 8.223A10.477 10.477 0 001.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.45 10.45 0 0112 4.5c4.756 0 8.773 3.162 10.065 7.498a10.523 10.523 0 01-4.293 5.774M6.228 6.228L3 3m3.228 3.228l3.65 3.65m7.894 7.894L21 21m-3.228-3.228l-3.65-3.65m0 0a3 3 0 10-4.243-4.243m4.242 4.242L9.88 9.88"
                                ></path>
                            </svg>
                        </div>
                        <h3 class="mb-3 text-xl font-semibold text-white">
                            No Visibility
                        </h3>
                        <p class="leading-relaxed text-zinc-300">
                            AI agents take autonomous actions across systems,
                            leaving security teams blind to what ran, when, or
                            why.
                        </p>
                    </div>
                    <div
                        class="rounded-sm border border-zinc-800 bg-zinc-900/50 p-8 hover:bg-zinc-800/50 transition-all"
                    >
                        <div
                            class="mb-5 inline-flex rounded-sm bg-zinc-800 p-3 text-zinc-400"
                        >
                            <svg
                                class="h-6 w-6"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                                stroke-width="1.5"
                            >
                                <path
                                    d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"
                                ></path>
                            </svg>
                        </div>
                        <h3 class="mb-3 text-xl font-semibold text-white">
                            Tamperable Logs
                        </h3>
                        <p class="leading-relaxed text-zinc-300">
                            Vendor-provided audit logs are self-reported and
                            software-only. A compromised host OS can silently
                            alter them.
                        </p>
                    </div>
                    <div
                        class="rounded-sm border border-zinc-800 bg-zinc-900/50 p-8 hover:bg-zinc-800/50 transition-all"
                    >
                        <div
                            class="mb-5 inline-flex rounded-sm bg-zinc-800 p-3 text-blue-400"
                        >
                            <svg
                                class="h-6 w-6"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                                stroke-width="1.5"
                            >
                                <path
                                    d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"
                                ></path>
                            </svg>
                        </div>
                        <h3 class="mb-3 text-xl font-semibold text-white">
                            Compliance Exposure
                        </h3>
                        <p class="leading-relaxed text-zinc-300">
                            SEC, HIPAA, CMMC, and NIS-2 frameworks require
                            verifiable audit trails. The EU AI Act mandates
                            logging for High-Risk AI Systems by August 2, 2026.
                        </p>
                    </div>
                </div>
            </div>
        </section>

        <!-- ══════════ ARCHITECTURE ══════════ -->
        <ArchitectureDiagram />

        <!-- ══════════ PRODUCT PHASES ══════════ -->
        <section class="relative border-t border-zinc-800/60 py-24 md:py-32">
            <div class="max-w-7xl mx-auto px-6">
                <div class="max-w-3xl mx-auto text-center">
                    <p
                        class="mb-3 font-mono text-xs uppercase tracking-[0.2em] text-zinc-500"
                    >
                        ↳ The product
                    </p>
                    <div class="mb-6 h-px bg-zinc-800"></div>
                    <h2
                        class="text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight text-white"
                    >
                        The Governance Stack. <span class="text-zinc-400"
                            >Built in Phases.</span
                        >
                    </h2>
                </div>

                <div class="mt-16 grid gap-8 lg:grid-cols-3">
                    <!-- Phase 1: AUDIT -->
                    <div
                        class="relative rounded-sm border border-zinc-800 bg-zinc-900/60 p-8 hover:bg-zinc-800/60 transition-all"
                    >
                        <div class="mb-6 flex items-center justify-between">
                            <span
                                class="text-xs font-semibold uppercase tracking-widest text-zinc-500"
                                >Phase 1</span
                            >
                            <span
                                class="inline-flex items-center gap-1.5 border border-zinc-700 px-3 py-1 text-xs font-mono text-zinc-400"
                            >
                                Available Now
                            </span>
                        </div>
                        <h3
                            class="mb-1 font-mono text-2xl font-bold text-white"
                        >
                            AUDIT
                        </h3>
                        <p class="mb-2 text-sm font-medium text-amber-400">
                            Prove what happened
                        </p>
                        <p class="mb-6 text-sm leading-relaxed text-zinc-400">
                            The Foundation: Passive Observation and Evidence
                            Preservation.
                        </p>
                        <ul class="space-y-4">
                            <li>
                                <h4 class="text-sm font-semibold text-zinc-100">
                                    The Append-Only Database
                                </h4>
                                <p
                                    class="mt-0.5 text-sm leading-relaxed text-zinc-400"
                                >
                                    Ed25519-signed and SHA-256 hash-chained
                                    append-only log. Tamper with any entry —
                                    every subsequent link breaks.
                                </p>
                            </li>
                            <li>
                                <h4 class="text-sm font-semibold text-zinc-100">
                                    Provider-Agnostic
                                </h4>
                                <p
                                    class="mt-0.5 text-sm leading-relaxed text-zinc-400"
                                >
                                    Intercepts traffic to OpenAI, Anthropic,
                                    Azure, or any compatible endpoint.
                                </p>
                            </li>
                            <li>
                                <h4 class="text-sm font-semibold text-zinc-100">
                                    The Causal Chain
                                </h4>
                                <p
                                    class="mt-0.5 text-sm leading-relaxed text-zinc-400"
                                >
                                    Logs not just what the agent did, but why —
                                    capturing the last 5 messages before every
                                    tool call.
                                </p>
                            </li>
                            <li>
                                <h4 class="text-sm font-semibold text-zinc-100">
                                    Zero Friction Deployment
                                </h4>
                                <p
                                    class="mt-0.5 text-sm leading-relaxed text-zinc-400"
                                >
                                    One environment variable or one Group Policy
                                    push. No developer code required.
                                </p>
                            </li>
                        </ul>
                    </div>

                    <!-- Phase 2: GOVERN -->
                    <div
                        class="relative rounded-sm border border-zinc-700 bg-zinc-900/60 p-8 hover:bg-zinc-800/60 transition-all"
                    >
                        <div class="mb-6 flex items-center justify-between">
                            <span
                                class="text-xs font-semibold uppercase tracking-widest text-zinc-500"
                                >Phase 2</span
                            >
                            <span
                                class="inline-flex items-center gap-1.5 border border-zinc-600 px-3 py-1 text-xs font-mono text-zinc-300"
                            >
                                Coming Soon
                            </span>
                        </div>
                        <h3
                            class="mb-1 font-mono text-2xl font-bold text-white"
                        >
                            GOVERN
                        </h3>
                        <p class="mb-2 text-sm font-medium text-amber-400">
                            Control what happens
                        </p>
                        <p class="mb-6 text-sm leading-relaxed text-zinc-400">
                            The First Intervention: Economic Envelopes and
                            Behavioral Monitoring.
                        </p>
                        <ul class="space-y-4">
                            <li>
                                <h4 class="text-sm font-semibold text-zinc-100">
                                    Cost & Resource Control
                                </h4>
                                <p
                                    class="mt-0.5 text-sm leading-relaxed text-zinc-400"
                                >
                                    Active limits on token counts and API spend
                                    to prevent runaway costs.
                                </p>
                            </li>
                            <li>
                                <h4 class="text-sm font-semibold text-zinc-100">
                                    Anomaly Detection
                                </h4>
                                <p
                                    class="mt-0.5 text-sm leading-relaxed text-zinc-400"
                                >
                                    Real-time monitoring of behavioral baselines
                                    and API usage alerts.
                                </p>
                            </li>
                            <li>
                                <h4 class="text-sm font-semibold text-zinc-100">
                                    Data Integrity Verification
                                </h4>
                                <p
                                    class="mt-0.5 text-sm leading-relaxed text-zinc-400"
                                >
                                    Continuous automated validation of database
                                    integrity.
                                </p>
                            </li>
                            <li>
                                <h4 class="text-sm font-semibold text-zinc-100">
                                    Allowlists / Blocklists
                                </h4>
                                <p
                                    class="mt-0.5 text-sm leading-relaxed text-zinc-400"
                                >
                                    Define which API endpoints each agent is
                                    permitted to reach.
                                </p>
                            </li>
                        </ul>
                    </div>

                    <!-- Phase 3: ATTEST -->
                    <div
                        class="relative rounded-sm border border-zinc-800 bg-zinc-900/60 p-8 hover:bg-zinc-800/60 transition-all"
                    >
                        <div class="mb-6 flex items-center justify-between">
                            <span
                                class="text-xs font-semibold uppercase tracking-widest text-zinc-500"
                                >Phase 3</span
                            >
                            <span
                                class="inline-flex items-center gap-1.5 border border-zinc-700 px-3 py-1 text-xs font-mono text-zinc-500"
                            >
                                Roadmap 2027
                            </span>
                        </div>
                        <h3
                            class="mb-1 font-mono text-2xl font-bold text-white"
                        >
                            DELEGATE
                        </h3>
                        <p class="mb-2 text-sm font-medium text-amber-400">
                            Grant autonomous authority
                        </p>
                        <p class="mb-6 text-sm leading-relaxed text-zinc-400">
                            The Final Layer: Semantic Policy Enforcement.
                        </p>
                        <ul class="space-y-4">
                            <li>
                                <h4 class="text-sm font-semibold text-zinc-100">
                                    Policy Enforcement Point
                                </h4>
                                <p
                                    class="mt-0.5 text-sm leading-relaxed text-zinc-400"
                                >
                                    Hard circuit breakers with block/allow logic
                                    for specific agent actions — before they
                                    reach external systems.
                                </p>
                            </li>
                            <li>
                                <h4 class="text-sm font-semibold text-zinc-100">
                                    Hardware-Rooted
                                </h4>
                                <p
                                    class="mt-0.5 text-sm leading-relaxed text-zinc-400"
                                >
                                    PKCS#11 / HSM signing layer and TEE
                                    attestation (TDX/SEV-SNP).
                                </p>
                            </li>
                            <li>
                                <h4 class="text-sm font-semibold text-zinc-100">
                                    Machine-Readable PoA
                                </h4>
                                <p
                                    class="mt-0.5 text-sm leading-relaxed text-zinc-400"
                                >
                                    Cryptographically signed policies that
                                    travel with every agent. Verifiable by any
                                    counterparty.
                                </p>
                            </li>
                            <li>
                                <h4 class="text-sm font-semibold text-zinc-100">
                                    Agent-to-Agent Commerce
                                </h4>
                                <p
                                    class="mt-0.5 text-sm leading-relaxed text-zinc-400"
                                >
                                    Delegation model enabling agents to prove
                                    their authority to other agents.
                                </p>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </section>

        <!-- ══════════ HOW IT WORKS ══════════ -->
        <section class="relative border-t border-zinc-800/60 py-24 md:py-32">
            <div class="relative max-w-7xl mx-auto px-6">
                <div class="max-w-3xl mx-auto text-center">
                    <p
                        class="mb-3 font-mono text-xs uppercase tracking-[0.2em] text-zinc-500"
                    >
                        ↳ Integration
                    </p>
                    <div class="mb-6 h-px bg-zinc-800"></div>
                    <h2
                        class="text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight text-white"
                    >
                        Deployed in minutes. <span class="text-zinc-400"
                            >Covering everything.</span
                        >
                    </h2>
                </div>

                <div class="mt-16 grid gap-8 md:grid-cols-2 lg:grid-cols-4">
                    {
                        [
                            {
                                n: "01",
                                title: "Deploy via Group Policy",
                                body: "IT pushes one policy, routing all LLM API traffic through KYDE WITNESS. Zero developer action required.",
                                code: "LLM_BASE_URL=https://witness.intranet/v1",
                                icon: "M7.5 7.5h-.75A2.25 2.25 0 004.5 9.75v7.5a2.25 2.25 0 002.25 2.25h7.5a2.25 2.25 0 002.25-2.25v-7.5a2.25 2.25 0 00-2.25-2.25h-.75m-6 3.75l3 3m0 0l3-3m-3 3V1.5",
                            },
                            {
                                n: "02",
                                title: "Proxy intercepts every call",
                                body: "KYDE WITNESS sits transparently between your agents and the LLM provider, capturing prompts, tool calls, and responses.",
                                code: "The agent sees no difference.",
                                icon: "M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5",
                            },
                            {
                                n: "03",
                                title: "Sign & chain each entry",
                                body: "Every interaction is Ed25519-signed and linked to the previous entry via SHA-256 hash chain.",
                                code: "Tampering breaks all subsequent links.",
                                icon: "M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m9.86-2.026a4.5 4.5 0 00-6.364-6.364L4.5 8.257",
                            },
                            {
                                n: "04",
                                title: "Audit anytime",
                                body: "Forensically complete records: who (user/machine), what (action + model + tool calls), why (causal context), from where (machine ID).",
                                code: "witness audit --from 2026-01-01",
                                icon: "M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15a2.25 2.25 0 012.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25z",
                            },
                        ].map(({ n, title, body, code, icon }) => (
                            <div class="group relative rounded-sm border border-zinc-700 bg-zinc-900/40 p-6 hover:border-zinc-600 hover:bg-zinc-800/40 transition-all">
                                <div class="mb-4 flex items-center gap-3">
                                    <span class="font-mono text-3xl font-bold text-zinc-700 group-hover:text-zinc-400 transition-colors">
                                        {n}
                                    </span>
                                    <svg
                                        class="h-6 w-6 text-zinc-500"
                                        fill="none"
                                        viewBox="0 0 24 24"
                                        stroke="currentColor"
                                        stroke-width="1.5"
                                    >
                                        <path d={icon} />
                                    </svg>
                                </div>
                                <h3 class="mb-2 text-lg font-semibold text-white">
                                    {title}
                                </h3>
                                <p class="mb-3 text-sm leading-relaxed text-zinc-300">
                                    {body}
                                </p>
                                <p class="font-mono text-xs text-zinc-500 break-all">
                                    {code}
                                </p>
                            </div>
                        ))
                    }
                </div>

                <!-- Ledger entry -->
                <div class="mx-auto mt-20 max-w-3xl">
                    <h3
                        class="mb-6 text-center text-lg font-semibold text-white"
                    >
                        Every action produces a tamper-evident database entry
                    </h3>
                    <div class="rounded-sm border border-zinc-800 bg-zinc-900">
                        <div
                            class="flex items-center gap-2 border-b border-zinc-800 px-4 py-3"
                        >
                            <span class="h-2 w-2 rounded-full bg-zinc-600"
                            ></span>
                            <span class="h-2 w-2 rounded-full bg-zinc-600"
                            ></span>
                            <span class="h-2 w-2 rounded-full bg-zinc-600"
                            ></span>
                            <span class="ml-2 text-xs text-zinc-500 font-mono"
                                >audit_entry.json</span
                            >
                        </div>
                        <pre
                            class="overflow-x-auto p-5 font-mono text-xs leading-relaxed text-zinc-400"><code>{`{
