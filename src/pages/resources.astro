---
import Base from "../layouts/Base.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";

const regulations = [
    {
        name: "EU AI Act",
        desc: "Risk-based framework for AI systems. High-Risk AI System logging requirements.",
        deadline: "High-Risk enforcement: August 2, 2026",
        urgency: true,
    },
    {
        name: "NIS-2 Directive",
        desc: "Network and Information Security for essential and important entities.",
        deadline: "In force: December 2025",
        urgency: false,
    },
    {
        name: "DORA",
        desc: "Digital Operational Resilience Act for financial sector entities.",
        deadline: "In force: January 2025",
        urgency: false,
    },
    {
        name: "GDPR",
        desc: "General Data Protection Regulation. Art. 22 covers automated decision-making. Art. 35 requires DPIA for high-risk processing.",
        deadline: "In force",
        urgency: false,
    },
];
---

<Base
    title="Resources — KYDE"
    description="Documentation, guides, and regulatory context for KYDE WITNESS and AI governance."
>
    <Navbar />

    <main>
        <!-- ══════════ HERO ══════════ -->
        <section class="relative overflow-hidden pt-36 pb-24 md:pt-48 md:pb-36">
            <div class="bg-grid absolute inset-0 pointer-events-none"></div>
            <div class="relative max-w-7xl mx-auto px-6">
                <p
                    class="mb-3 font-mono text-xs uppercase tracking-[0.2em] text-zinc-500"
                >
                    Resources
                </p>
                <div class="mb-8 h-px bg-zinc-800"></div>
                <h1
                    class="hero-h1 max-w-2xl text-5xl text-white md:text-6xl lg:text-7xl"
                >
                    Documentation, Guides, and Research.
                </h1>
                <p class="mt-6 max-w-xl text-sm uppercase tracking-wide leading-snug text-zinc-400">
                    We're building. Docs arrive with the product.
                </p>
            </div>
        </section>

        <!-- ══════════ DOCS COMING SOON ══════════ -->
        <section class="relative pb-16">
            <div class="max-w-7xl mx-auto px-6">
                <div
                    class="rounded-sm border border-zinc-700 bg-zinc-900/60 p-10 max-w-2xl"
                >
                    <div
                        class="mb-4 inline-flex items-center gap-2 border border-zinc-700 px-3 py-1"
                    >
                        <span
                            class="h-1.5 w-1.5 rounded-full bg-white/40 animate-pulse"
                        ></span>
                        <span class="text-xs font-mono text-zinc-500"
                            >In development</span
                        >
                    </div>
                    <h2 class="text-2xl font-bold text-white">
                        KYDE WITNESS Documentation
                    </h2>
                    <p class="mt-3 text-zinc-300 leading-relaxed">
                        Full integration guides, CLI reference, and API
                        documentation will be published when KYDE WITNESS
                        reaches public availability.
                    </p>
                    <div class="mt-6">
                        <button
                            onclick="openModal()"
                            class="inline-flex items-center gap-2 bg-white px-5 py-2.5 text-sm font-semibold text-black hover:bg-zinc-200 transition-all"
                        >
                            Join the Early Access List →
                        </button>
                    </div>
                </div>
            </div>
        </section>

        <!-- ══════════ REGULATORY CONTEXT ══════════ -->
        <section class="py-24 md:py-32">
            <div class="max-w-7xl mx-auto px-6">
                <div class="max-w-2xl mb-12">
                    <p
                        class="mb-4 font-mono text-xs uppercase tracking-[0.2em] text-zinc-500"
                    >
                        Regulatory Context
                    </p>
                    <h2
                        class="text-3xl md:text-4xl font-bold tracking-tight text-white"
                    >
                        The frameworks KYDE WITNESS is designed to address.
                    </h2>
                </div>

                <div class="max-w-3xl space-y-4">
                    {
                        regulations.map(({ name, desc, deadline, urgency }) => (
                            <div
                                class={`rounded-sm border p-6 transition-colors ${urgency ? "border-zinc-600 bg-zinc-800/50 hover:border-zinc-500" : "border-zinc-700 bg-zinc-900/40 hover:border-zinc-600"}`}
                            >
                                <div class="flex items-start justify-between gap-4">
                                    <div>
                                        <h3 class="font-mono text-lg font-bold text-white">
                                            {name}
                                        </h3>
                                        <p class="mt-1 text-sm text-zinc-300">
                                            {desc}
                                        </p>
                                    </div>
                                    {urgency && (
                                        <span class="shrink-0 border border-zinc-600 px-2.5 py-1 text-xs font-mono text-white">
                                            Urgent
                                        </span>
                                    )}
                                </div>
                                <div class="mt-3 flex items-center gap-2 text-xs text-zinc-500">
                                    <svg
                                        class="h-3.5 w-3.5"
                                        fill="none"
                                        viewBox="0 0 24 24"
                                        stroke="currentColor"
                                        stroke-width="2"
                                    >
                                        <path d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                                    </svg>
                                    {deadline}
                                </div>
                            </div>
                        ))
                    }
                </div>
            </div>
        </section>

        <!-- ══════════ CTA ══════════ -->
        <section class="py-24 md:py-32">
            <div class="max-w-7xl mx-auto px-6">
                <div
                    class="rounded-sm border border-zinc-700 bg-zinc-900/40 p-12 md:p-16 max-w-2xl"
                >
                    <h2
                        class="text-2xl md:text-3xl font-bold tracking-tight text-white"
                    >
                        Questions before the docs arrive?
                    </h2>
                    <p class="mt-3 text-zinc-300">
                        We respond to every message.
                    </p>
                    <div class="mt-6">
                        <a
                            href="mailto:hello@kyde.com"
                            class="inline-flex items-center gap-2 rounded-sm border border-zinc-600 px-6 py-3 text-sm font-semibold text-zinc-200 hover:border-zinc-400 hover:text-white transition-all"
                        >
                            hello@kyde.com →
                        </a>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <Footer />
</Base>
