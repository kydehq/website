---
interface Props {
  title?: string;
}
const { title = 'KYDE — Slides' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="robots" content="noindex, nofollow" />
    <slot name="head" />
  </head>
  <body>
    <slot />
  </body>
</html>
